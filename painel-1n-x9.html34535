    el.innerHTML = h + '</tbody></table>';
  } catch(e) { el.innerHTML = '<div class="empty">Erro: ' + e.message + '</div>'; }
}

// ── CAL.COM ──
var CAL_KEY_SK = '1n_cal';
function getCalKey() { return sessionStorage.getItem(CAL_KEY_SK) || ''; }

function abrirCalKey() {
  document.getElementById('ovCalKey').style.display = 'flex';
  var k = getCalKey();
  if (k) document.getElementById('cal-kinp').value = k;
  document.getElementById('cal-kstatus').textContent = '';
  setTimeout(function() { document.getElementById('cal-kinp').focus(); }, 100);
}
function fecharCalKey() { document.getElementById('ovCalKey').style.display = 'none'; }
function salvarCalKey() {
  var v = document.getElementById('cal-kinp').value.trim();
  if (!v || !v.startsWith('cal_')) {
    document.getElementById('cal-kstatus').textContent = 'Chave inválida — deve começar com cal_live_';
    document.getElementById('cal-kstatus').className = 'kstatus err';
    return;
  }
  sessionStorage.setItem(CAL_KEY_SK, v);
  document.getElementById('cal-kstatus').textContent = '✓ Salvo!';
  document.getElementById('cal-kstatus').className = 'kstatus ok';
  setTimeout(function() {
    fecharCalKey();
    done.agenda = false;
    loadAgenda(true);
    // também atualiza painel
    done.painel = false;
    loadPainel();
  }, 600);
}

async function calApi(path) {
  var k = getCalKey();
  if (!k) throw new Error('CAL_KEY_MISSING');
  var r = await fetch('https://api.cal.com/v2' + path, {
    headers: {
      'Authorization': 'Bearer ' + k,
      'cal-api-version': '2024-08-13',
      'Content-Type': 'application/json'
    }
  });
  if (!r.ok) throw new Error('Cal.com API error ' + r.status);
  return r.json();
}

function fmtHora(iso) {
  if (!iso) return '—';
  var d = new Date(iso);
  return d.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit', timeZone: 'America/Sao_Paulo' });
}
function fmtDataCurta(iso) {
  if (!iso) return '—';
  var d = new Date(iso);
  return d.toLocaleDateString('pt-BR', { weekday: 'short', day: '2-digit', month: '2-digit', timeZone: 'America/Sao_Paulo' });
}
function isAgora(start, end) {
  var now = Date.now();
  return new Date(start).getTime() <= now && new Date(end).getTime() >= now;
}
function isPassado(end) { return new Date(end).getTime() < Date.now(); }

function renderSlot(b, showDate) {
  var hora = fmtHora(b.start);
  var horaEnd = fmtHora(b.end);
  var attendee = b.attendees && b.attendees[0];
  var nome = attendee ? attendee.name : '—';
  var email = attendee ? attendee.email : '';
  var tipo = (b.eventType && b.eventType.title) || b.title || '—';
  var agora = isAgora(b.start, b.end);
  var passado = isPassado(b.end);
  var horaClass = agora ? 'agora' : passado ? 'passado' : '';
  var dotClass = agora ? 'dot-green' : passado ? 'dot-dim' : 'dot-amber';
  var statusBdg = agora
    ? '<span class="bdg bg">AO VIVO</span>'
    : passado
    ? '<span class="bdg bd">ENCERRADA</span>'
    : '<span class="bdg ba">CONFIRMADA</span>';
  var wppBtn = attendee && attendee.phone
    ? '<a href="https://wa.me/' + attendee.phone.replace(/\D/g,'') + '" target="_blank" class="btn btng" style="font-size:9px;text-decoration:none">WPP</a>'
    : '';
  var dataLabel = showDate ? '<div style="font-size:9px;color:var(--dim);margin-top:2px">' + fmtDataCurta(b.start) + '</div>' : '';
  return '<div class="agenda-slot">' +
    '<div class="agenda-dot ' + dotClass + '"></div>' +
    '<div class="agenda-hora ' + horaClass + '">' + hora + '<div style="font-size:9px;color:var(--dim);font-weight:400">' + horaEnd + '</div></div>' +
    '<div class="agenda-info"><div class="agenda-nome">' + nome + '</div>' +
    '<div class="agenda-tipo">' + tipo + (email ? ' · ' + email : '') + '</div>' + dataLabel + '</div>' +
    '<div class="agenda-status">' + statusBdg + '</div>' +
    '<div class="agenda-actions">' + wppBtn + '</div>' +
    '</div>';
}

async function loadAgenda(force) {
  if (!force && done.agenda) return;
  done.agenda = true;
  var elHoje = document.getElementById('tbl-agenda-hoje');
  var elProx = document.getElementById('tbl-agenda-proximas');
  var elMini = document.getElementById('painel-agenda-mini');
  var elStat = document.getElementById('st-agenda');
  var elLabel = document.getElementById('agenda-data-label');

  var now = new Date();
  var tzOff = -3 * 60; // BRT UTC-3
  // Hoje em BRT
  var hojeBRT = new Date(now.getTime() + (now.getTimezoneOffset() + (-tzOff)) * 60000 * -1);
  var dataHoje = now.toLocaleDateString('pt-BR', { weekday: 'long', day: '2-digit', month: 'long', timeZone: 'America/Sao_Paulo' });
  if (elLabel) elLabel.textContent = dataHoje;

  // Datas para filtro
  var inicioHoje = new Date(now);
  inicioHoje.setHours(0,0,0,0);
  var fimHoje = new Date(now);
  fimHoje.setHours(23,59,59,999);
  var fimSemana = new Date(now);
  fimSemana.setDate(fimSemana.getDate() + 7);

  var calKey = getCalKey();
  if (!calKey) {
    var semChave = '<div class="agenda-vazio">🔑 Configure a chave do Cal.com para ver sua agenda.<br><br><button class="btn btnk" onclick="abrirCalKey()">Configurar chave →</button></div>';
    if (elHoje) elHoje.innerHTML = semChave;
    if (elProx) elProx.innerHTML = '';
    if (elMini) elMini.innerHTML = semChave;
    if (elStat) elStat.textContent = '—';
    return;
  }

  if (elHoje) elHoje.innerHTML = '<div class="ld">carregando...</div>';
  if (elProx) elProx.innerHTML = '<div class="ld">carregando...</div>';
  if (elMini) elMini.innerHTML = '<div class="ld">carregando...</div>';

  try {
    // Busca bookings upcoming + past da semana
    var [resUp, resPast] = await Promise.all([
      calApi('/bookings?status=upcoming&limit=50&afterStart=' + encodeURIComponent(now.toISOString())),
      calApi('/bookings?status=past&limit=20&afterStart=' + encodeURIComponent(inicioHoje.toISOString()) + '&beforeStart=' + encodeURIComponent(now.toISOString()))
    ]);

    var todos = [];
    if (resUp && resUp.data) todos = todos.concat(resUp.data);
    if (resPast && resPast.data) todos = todos.concat(resPast.data);
    todos.sort(function(a, b) { return new Date(a.start) - new Date(b.start); });

    // Filtra hoje (BRT)
    var hoje = todos.filter(function(b) {
      var d = new Date(b.start);
      var dBRT = new Date(d.toLocaleString('en-US', { timeZone: 'America/Sao_Paulo' }));
      var ref = new Date(now.toLocaleString('en-US', { timeZone: 'America/Sao_Paulo' }));
      return dBRT.getFullYear() === ref.getFullYear() &&
             dBRT.getMonth() === ref.getMonth() &&
             dBRT.getDate() === ref.getDate();
    });

    // Próximas (excluindo hoje)
    var proximas = todos.filter(function(b) {
      var d = new Date(b.start);
      var dBRT = new Date(d.toLocaleString('en-US', { timeZone: 'America/Sao_Paulo' }));
      var ref = new Date(now.toLocaleString('en-US', { timeZone: 'America/Sao_Paulo' }));
      return dBRT > fimHoje && d <= fimSemana;
    }).filter(function(b) {
      var dBRT = new Date(new Date(b.start).toLocaleString('en-US', { timeZone: 'America/Sao_Paulo' }));
      var ref = new Date(now.toLocaleString('en-US', { timeZone: 'America/Sao_Paulo' }));
      return !(dBRT.getFullYear() === ref.getFullYear() && dBRT.getMonth() === ref.getMonth() && dBRT.getDate() === ref.getDate());
    });

    // Stat
    var ativas = hoje.filter(function(b) { return !isPassado(b.end); }).length;
    if (elStat) {
      elStat.textContent = hoje.length;
      elStat.style.color = ativas > 0 ? 'var(--green)' : 'var(--ink)';
    }
    // Badge sidebar
    var bAgenda = document.getElementById('b-agenda');
    if (bAgenda) { bAgenda.textContent = ativas > 0 ? ativas : ''; }

    // Renderiza hoje
    if (elHoje) {
      if (!hoje.length) {
        elHoje.innerHTML = '<div class="agenda-vazio">Nenhuma reunião hoje.</div>';
      } else {
        // Linha "agora" se tiver reunião em curso
        var emCurso = hoje.filter(function(b) { return isAgora(b.start, b.end); });
        var h = '';
        if (emCurso.length) {
          h += '<div class="agenda-now-line"><span style="font-size:10px">●</span><span class="agenda-now-txt">REUNIÃO EM ANDAMENTO</span></div>';
        }
        h += hoje.map(function(b) { return renderSlot(b, false); }).join('');
        elHoje.innerHTML = h;
      }
    }

    // Mini no painel
    if (elMini) {
      if (!hoje.length) {
        elMini.innerHTML = '<div class="agenda-vazio" style="padding:20px">Nenhuma reunião hoje.</div>';
        document.getElementById('card-agenda-painel').style.display = 'none';
      } else {
        document.getElementById('card-agenda-painel').style.display = 'block';
        elMini.innerHTML = hoje.slice(0, 4).map(function(b) { return renderSlot(b, false); }).join('') +
          (hoje.length > 4 ? '<div style="padding:10px 18px;font-size:10px;color:var(--dim)">+ ' + (hoje.length - 4) + ' mais reuniões</div>' : '');
      }
    }

    // Próximas
    if (elProx) {
      if (!proximas.length) {
        elProx.innerHTML = '<div class="agenda-vazio">Nenhuma reunião nos próximos 7 dias.</div>';
      } else {
        elProx.innerHTML = proximas.map(function(b) { return renderSlot(b, true); }).join('');
      }
    }

  } catch(e) {
    var errMsg = e.message === 'CAL_KEY_MISSING'
      ? '<div class="agenda-vazio">🔑 Chave do Cal.com não configurada.<br><br><button class="btn btnk" onclick="abrirCalKey()">Configurar →</button></div>'
      : '<div class="agenda-vazio">Erro ao carregar agenda: ' + e.message + '<br><br><button class="btn" onclick="done.agenda=false;loadAgenda(true)">Tentar novamente</button></div>';
    if (elHoje) elHoje.innerHTML = errMsg;
    if (elProx) elProx.innerHTML = '';
    if (elMini) elMini.innerHTML = errMsg;
    if (elStat) elStat.textContent = '!';
  }
}


// ══ DOSSIÊ — CONST ══════════════════════════════════════════════════════
var DIMS_SAUDE = [
  {id:'fin',label:'FINANCEIRO',peso:20},
