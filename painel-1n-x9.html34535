];

var DRE_DEFS = [
  {id:'ds-rec',  label:'RECEITA BRUTA MENSAL',           inv:false},
  {id:'ds-imp',  label:'(−) IMPOSTOS S/ RECEITA',        inv:true},
  {id:'ds-cmv',  label:'(−) CMV / CPV / CSP',            inv:true},
  {id:'ds-folha',label:'(−) PESSOAL (excl. pró-labore)', inv:true},
  {id:'ds-pro',  label:'(−) PRÓ-LABORE (ajustado)',      inv:true},
  {id:'ds-alq',  label:'(−) ALUGUEL E OCUPAÇÃO',         inv:true},
  {id:'ds-mkt',  label:'(−) MARKETING',                  inv:true},
  {id:'ds-tec',  label:'(−) TECNOLOGIA/SISTEMAS',        inv:true},
  {id:'ds-out',  label:'(−) OUTRAS DESPESAS',            inv:true},
  {id:'ds-fin',  label:'(−) DESPESAS FINANCEIRAS',       inv:true},
];

if (sessionStorage.getItem(SK) === '1') { showApp(); }
</script>
