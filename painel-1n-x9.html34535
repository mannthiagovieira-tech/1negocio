<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>1Negócio — Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#0a0a0a;--s1:#111;--s2:#161616;--b1:rgba(255,255,255,.08);--ink:#f5f5f0;--dim:rgba(255,255,255,.4);--green:#10b981;--blue:#60a5fa;--amber:#f59e0b;--red:#ef4444}
body{background:var(--bg);color:var(--ink);font-family:Inter,sans-serif;font-size:13px;min-height:100vh}
#login{position:fixed;inset:0;background:#0a0a0a;z-index:9999;display:flex;align-items:center;justify-content:center}
.lbox{background:var(--s1);border:1px solid var(--b1);border-radius:10px;padding:40px;width:320px;text-align:center}
.llogo{font-family:Syne,sans-serif;font-weight:800;font-size:18px;letter-spacing:.12em;margin-bottom:8px}
.llogo em{color:var(--dim);font-style:normal}
.lsub{font-size:10px;color:var(--dim);letter-spacing:.1em;margin-bottom:28px}
.linp{width:100%;background:var(--s2);border:1px solid var(--b1);border-radius:6px;padding:11px 14px;color:var(--ink);font-size:13px;text-align:center;letter-spacing:.15em;outline:none;margin-bottom:12px}
.linp:focus{border-color:rgba(255,255,255,.2)}
.lbtn{width:100%;background:var(--ink);color:#0a0a0a;border:none;border-radius:6px;padding:11px;font-family:Syne,sans-serif;font-weight:700;font-size:11px;letter-spacing:.12em;cursor:pointer}
.lbtn:hover{opacity:.85}
.lerr{font-size:10px;color:var(--red);margin-top:8px;min-height:16px;letter-spacing:.08em}
#app{display:none;height:100vh;flex-direction:column}
#topbar{height:48px;background:var(--s1);border-bottom:1px solid var(--b1);display:flex;align-items:center;padding:0 20px;gap:12px;flex-shrink:0}
.tlogo{font-family:Syne,sans-serif;font-weight:800;font-size:13px;letter-spacing:.1em}
.tlogo em{color:var(--dim);font-style:normal}
.tsep{width:1px;height:16px;background:var(--b1)}
.tcur{font-size:10px;color:var(--dim);letter-spacing:.1em;text-transform:uppercase}
.tr{margin-left:auto;display:flex;align-items:center;gap:10px}
.tonline{font-size:9px;color:var(--green);letter-spacing:.08em}
.tav{width:28px;height:28px;background:rgba(96,165,250,.15);border:1px solid rgba(96,165,250,.3);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:var(--blue)}
#body{display:flex;flex:1;overflow:hidden}
#sidebar{width:200px;background:var(--s1);border-right:1px solid var(--b1);padding:16px 0;flex-shrink:0;overflow-y:auto}
.sg{font-size:8px;color:var(--dim);letter-spacing:.12em;padding:12px 16px 6px;text-transform:uppercase}
.si{display:flex;align-items:center;gap:8px;padding:9px 16px;cursor:pointer;font-size:11px;color:var(--dim);letter-spacing:.05em;transition:all .15s;border-left:2px solid transparent}
.si:hover{color:var(--ink);background:rgba(255,255,255,.03)}
.si.on{color:var(--ink);background:rgba(255,255,255,.05);border-left-color:var(--blue)}
.badge{background:var(--red);color:#fff;font-size:8px;font-weight:700;padding:1px 5px;border-radius:10px;margin-left:auto}
#main{flex:1;overflow-y:auto;padding:24px}
.view{display:none}.view.on{display:block}
.stats{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:12px;margin-bottom:24px}
.stat{background:var(--s1);border:1px solid var(--b1);border-radius:8px;padding:16px}
.stat-l{font-size:9px;color:var(--dim);letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px}
.stat-v{font-family:Syne,sans-serif;font-size:22px;font-weight:700}
.card{background:var(--s1);border:1px solid var(--b1);border-radius:8px;overflow:hidden;margin-bottom:20px}
.card-hd{padding:14px 18px;border-bottom:1px solid var(--b1);font-size:10px;letter-spacing:.1em;color:var(--dim);text-transform:uppercase;display:flex;align-items:center;gap:10px}
.card-hd .btn{margin-left:auto}
table{width:100%;border-collapse:collapse}
th{font-size:9px;color:var(--dim);letter-spacing:.1em;text-transform:uppercase;padding:10px 18px;text-align:left;border-bottom:1px solid var(--b1)}
td{padding:11px 18px;border-bottom:1px solid rgba(255,255,255,.04);font-size:12px}
tr:last-child td{border-bottom:none}
tr:hover td{background:rgba(255,255,255,.02)}
.bdg{display:inline-block;font-size:8px;font-weight:700;letter-spacing:.08em;padding:2px 7px;border-radius:4px}
.bg{background:rgba(16,185,129,.15);color:var(--green);border:1px solid rgba(16,185,129,.3)}
.ba{background:rgba(245,158,11,.1);color:var(--amber);border:1px solid rgba(245,158,11,.2)}
.bb{background:rgba(96,165,250,.15);color:var(--blue);border:1px solid rgba(96,165,250,.3)}
.bd{background:rgba(255,255,255,.05);color:var(--dim);border:1px solid var(--b1)}
.empty{padding:48px;text-align:center;color:var(--dim);font-size:11px}
.btn{background:rgba(255,255,255,.06);border:1px solid var(--b1);color:var(--ink);font-size:10px;padding:5px 10px;border-radius:4px;cursor:pointer;font-weight:600}
.btn:hover{background:rgba(255,255,255,.1)}
.btng{background:rgba(16,185,129,.1);border-color:rgba(16,185,129,.3);color:var(--green)}
.btnr{background:rgba(239,68,68,.1);border-color:rgba(239,68,68,.3);color:var(--red)}
.btnk{background:rgba(245,158,11,.1);border-color:rgba(245,158,11,.3);color:var(--amber)}
#toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%) translateY(60px);background:var(--ink);color:#0a0a0a;padding:9px 20px;border-radius:4px;font-size:10px;font-weight:700;letter-spacing:.1em;z-index:9999;transition:transform .2s;pointer-events:none}
#toast.on{transform:translateX(-50%) translateY(0)}
.ld{padding:40px;text-align:center;color:var(--dim);font-size:11px}

/* ── DOSSIÊ ── */
.ds-tab{background:rgba(255,255,255,.04);border:1px solid var(--b1);color:var(--dim);font-size:9px;letter-spacing:.1em;padding:6px 12px;border-radius:4px;cursor:pointer;transition:all .15s}
.ds-tab:hover{color:var(--ink)}
.ds-tab.on{background:rgba(245,158,11,.1);border-color:rgba(245,158,11,.3);color:var(--amber)}
.ds-body{display:none}.ds-body.on{display:block}
.ds-fr{display:flex;gap:10px;flex-wrap:wrap}
.ds-fg{display:flex;flex-direction:column;gap:4px;flex:1;min-width:160px}
.ds-fl{font-size:7.5px;letter-spacing:.12em;color:var(--dim)}
.ds-fi{background:var(--s2);border:1px solid var(--b1);border-radius:4px;padding:8px 10px;color:var(--ink);font-family:Inter,sans-serif;font-size:12px;outline:none;width:100%;transition:border-color .15s}
.ds-fi:focus{border-color:rgba(255,255,255,.2)}
.ds-tag{display:inline-block;font-size:8px;letter-spacing:.1em;padding:3px 9px;border-radius:3px;border:1px solid var(--b1);color:var(--dim);cursor:pointer;transition:all .15s}
.ds-tag.on{background:rgba(245,158,11,.1);border-color:rgba(245,158,11,.3);color:var(--amber)}
.ds-dim-card{padding:10px 12px;border-radius:5px;border:1px solid}

/* Cal.com agenda */
.agenda-hoje { margin-bottom: 20px; }
.agenda-slot {
  display: flex; align-items: center; gap: 14px;
  padding: 14px 18px; border-bottom: 1px solid rgba(255,255,255,.04);
  transition: background .1s;
}
.agenda-slot:hover { background: rgba(255,255,255,.02); }
.agenda-slot:last-child { border-bottom: none; }
.agenda-hora {
  font-family: 'Syne', monospace; font-size: 13px; font-weight: 700;
  color: var(--ink); min-width: 52px; flex-shrink: 0;
}
.agenda-hora.passado { color: var(--dim); }
.agenda-hora.agora { color: var(--green); }
.agenda-info { flex: 1; min-width: 0; }
.agenda-nome { font-size: 13px; font-weight: 600; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.agenda-tipo { font-size: 10px; color: var(--dim); letter-spacing: .05em; }
.agenda-status { flex-shrink: 0; }
.agenda-actions { display: flex; gap: 6px; flex-shrink: 0; }
.agenda-vazio { padding: 36px; text-align: center; color: var(--dim); font-size: 11px; }
.cal-key-nota { font-size: 9px; color: var(--dim); margin-top: 10px; line-height: 1.6; }
.agenda-dot {
  width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
}
.dot-green { background: var(--green); box-shadow: 0 0 6px rgba(16,185,129,.5); }
.dot-amber { background: var(--amber); }
.dot-dim { background: var(--dim); opacity: .4; }
.agenda-now-line {
  display: flex; align-items: center; gap: 8px; padding: 6px 18px;
  background: rgba(16,185,129,.05); border-bottom: 1px solid rgba(16,185,129,.15);
}
.agenda-now-txt { font-size: 9px; color: var(--green); letter-spacing: .1em; }
.stat-cal { cursor: pointer; transition: border-color .15s; }
.stat-cal:hover { border-color: rgba(16,185,129,.3); }

#ovSrvKey{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:10000;display:none;align-items:center;justify-content:center}
#ovSrvKey.on{display:flex}
.kbox{background:var(--s1);border:1px solid var(--b1);border-radius:10px;padding:32px;width:460px;max-width:94vw}
.kbox h3{font-family:Syne,sans-serif;font-size:13px;letter-spacing:.1em;margin-bottom:6px}
.kbox p{font-size:11px;color:var(--dim);margin-bottom:20px;line-height:1.6}
.kinp{width:100%;background:var(--s2);border:1px solid var(--b1);border-radius:6px;padding:10px 14px;color:var(--ink);font-size:11px;font-family:monospace;outline:none;margin-bottom:14px;letter-spacing:.03em}
.kinp:focus{border-color:rgba(255,255,255,.2)}
.kbtns{display:flex;gap:8px;justify-content:flex-end}
.kstatus{font-size:10px;margin-bottom:12px;min-height:16px}
.kstatus.ok{color:var(--green)}
.kstatus.err{color:var(--red)}
</style>
</head>
<body>

<div id="login">
  <div class="lbox">
    <div class="llogo">1NEGÓCIO<em>ADMIN</em></div>
    <div class="lsub">ACESSO RESTRITO</div>
    <input class="linp" id="lpwd" type="password" placeholder="••••••••" autocomplete="current-password">
    <button class="lbtn" id="lbtn">ENTRAR</button>
    <div class="lerr" id="lerr"></div>
  </div>
</div>

<!-- Modal: Chave API -->
<div id="ovSrvKey">
  <div class="kbox">
    <h3>🔑 CHAVE SERVICE ROLE</h3>
    <p>Cole a <b>service_role key</b> do Supabase para liberar acesso admin completo.<br>
    Supabase → Project Settings → API → service_role.</p>
    <input class="kinp" id="kinp" type="password" placeholder="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...">
    <div class="kstatus" id="kstatus"></div>
    <div class="kbtns">
      <button class="btn" id="kcancel">Cancelar</button>
      <button class="btn btng" id="ksave">Salvar e conectar</button>
    </div>
  </div>
</div>

<!-- Modal: Chave Cal.com -->
<div id="ovCalKey" style="position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:10000;display:none;align-items:center;justify-content:center">
  <div class="kbox">
    <h3>📅 CHAVE CAL.COM</h3>
    <p>Cole sua <b>API Key</b> do Cal.com para ver sua agenda no painel.<br>
    Cal.com → Settings → Developer → API Keys → New API Key</p>
    <input class="kinp" id="cal-kinp" type="password" placeholder="cal_live_...">
    <div class="kstatus" id="cal-kstatus"></div>
    <div class="kbtns">
      <button class="btn" onclick="fecharCalKey()">Cancelar</button>
      <button class="btn btng" onclick="salvarCalKey()">Salvar</button>
    </div>
    <div class="cal-key-nota">A chave é salva apenas nesta sessão do navegador.</div>
  </div>
</div>

<div id="app">
  <div id="topbar">
    <div class="tlogo">1NEGÓCIO<em>ADMIN</em></div>
    <div class="tsep"></div>
    <div class="tcur" id="vcur">PAINEL</div>
    <div class="tr">
      <div class="tonline" id="keyIndicator">● SEM CHAVE</div>
      <button class="btn btnk" id="btnChave" style="font-size:9px;padding:4px 8px">🔑 Chave API</button>
      <div class="tav">TH</div>
    </div>
  </div>
  <div id="body">
    <div id="sidebar">
      <div class="sg">PRINCIPAL</div>
      <div class="si on" data-view="painel">◈ Painel</div>
      <div class="si" data-view="agenda">📅 Agenda <span class="badge" id="b-agenda" style="background:var(--green)"></span></div>
      <div class="si" data-view="dossie" style="color:var(--amber)">◆ Novo Dossiê</div>
      <div class="si" data-view="dossie" style="color:var(--amber)">◆ Novo Dossiê</div>
      <div class="si" data-view="negocios">⊡ Negócios</div>
      <div class="sg">LEADS</div>
      <div class="si" data-view="leads">◎ Leads Site <span class="badge" id="b-leads"></span></div>
      <div class="si" data-view="chatdrafts">◌ Chat Drafts <span class="badge" id="b-chats"></span></div>
      <div class="sg">PORTAL</div>
      <div class="si" data-view="solicitacoes">⊞ Solicitações <span class="badge" id="b-sol"></span></div>
      <div class="si" data-view="mesas">⊟ Mesas</div>
      <div class="si" data-view="usuarios">◉ Usuários</div>
      <div class="sg">CONFIG</div>
      <div class="si" id="sideChave">🔑 Chave API</div>
    </div>
    <div id="main">
      <div class="view on" id="view-painel">
        <div class="stats">
          <div class="stat stat-cal" onclick="showView('agenda')" title="Ver agenda">
            <div class="stat-l">Reuniões Hoje</div>
            <div class="stat-v" id="st-agenda">—</div>
          </div>
          <div class="stat"><div class="stat-l">Negócios Pub.</div><div class="stat-v" id="st-neg">—</div></div>
          <div class="stat"><div class="stat-l">Leads Site</div><div class="stat-v" id="st-leads">—</div></div>
          <div class="stat"><div class="stat-l">Chat Drafts</div><div class="stat-v" id="st-chats">—</div></div>
          <div class="stat"><div class="stat-l">Usuários</div><div class="stat-v" id="st-users">—</div></div>
          <div class="stat"><div class="stat-l">Solicitações</div><div class="stat-v" id="st-sol">—</div></div>
          <div class="stat"><div class="stat-l">Mesas Ativas</div><div class="stat-v" id="st-mesas">—</div></div>
        </div>
        <div class="card" id="card-agenda-painel" style="display:none">
          <div class="card-hd">
            📅 Agenda de Hoje
            <button class="btn" style="margin-left:auto;font-size:9px" onclick="showView('agenda')">Ver tudo →</button>
          </div>
          <div id="painel-agenda-mini"><div class="ld">carregando...</div></div>
        </div>
        <div class="card"><div class="card-hd">Negócios</div><div id="painel-negs"><div class="ld">carregando...</div></div></div>
      </div>
      <div class="view" id="view-agenda">
        <div class="card" style="margin-bottom:20px">
          <div class="card-hd">
            📅 Agenda — <span id="agenda-data-label"></span>
            <button class="btn" style="margin-left:8px;font-size:9px" onclick="loadAgenda(true)">↺ Atualizar</button>
            <button class="btn btnk" style="margin-left:auto;font-size:9px" onclick="abrirCalKey()">🔑 Chave Cal.com</button>
          </div>
          <div id="tbl-agenda-hoje"></div>
        </div>
        <div class="card">
          <div class="card-hd">Próximas Reuniões <span style="color:var(--dim);font-weight:400">(7 dias)</span></div>
          <div id="tbl-agenda-proximas"></div>
        </div>
      </div>

      <!-- ══ DOSSIÊ ══ -->
      <div class="view" id="view-dossie">
        <div id="ds-status-bar" style="display:none;padding:8px 16px;background:rgba(245,158,11,.07);border:1px solid rgba(245,158,11,.2);border-radius:6px;margin-bottom:16px;font-size:8px;letter-spacing:.1em;display:flex;gap:16px;align-items:center">
          <span id="ds-b1" style="opacity:.3;color:var(--amber)">◆ BLOCO 1</span>
          <span style="color:rgba(255,255,255,.15)">→</span>
          <span id="ds-b2" style="opacity:.3;color:#a78bfa">◆ BLOCO 2</span>
          <span style="color:rgba(255,255,255,.15)">→</span>
          <span id="ds-b3" style="opacity:.3;color:var(--green)">◆ BLOCO 3</span>
          <span style="flex:1"></span>
          <span id="ds-status-txt" style="color:var(--dim);text-transform:none"></span>
        </div>
        <div style="display:flex;gap:6px;margin-bottom:16px;flex-wrap:wrap">
          <button class="ds-tab on" data-tab="t-trans" onclick="dsTab(this)">Transcrição</button>
          <button class="ds-tab" data-tab="t-ident" onclick="dsTab(this)">Identidade</button>
          <button class="ds-tab" data-tab="t-op" onclick="dsTab(this)">Operação</button>
          <button class="ds-tab" data-tab="t-fin" onclick="dsTab(this)">Financeiro</button>
          <button class="ds-tab" data-tab="t-aval" onclick="dsTab(this)">Avaliação</button>
          <button class="ds-tab" data-tab="t-venda" onclick="dsTab(this)">Venda</button>
          <button class="ds-tab" data-tab="t-pub" onclick="dsTab(this)">Publicação</button>
        </div>

        <!-- TRANSCRIÇÃO -->
        <div class="ds-body on" id="t-trans">
          <div class="card"><div class="card-hd">◆ BLOCO 1 — TRANSCRIÇÃO DA REUNIÃO</div><div style="padding:16px">
            <div style="font-size:7.5px;color:var(--dim);letter-spacing:.1em;margin-bottom:8px">COLE A TRANSCRIÇÃO DA LIGAÇÃO COM O VENDEDOR</div>
            <textarea id="ds-trans" style="width:100%;height:220px;background:var(--s2);border:1px solid var(--b1);border-radius:5px;padding:12px;color:var(--ink);font-family:Inter,sans-serif;font-size:12px;resize:vertical;outline:none;line-height:1.65" placeholder="Cole a transcrição da reunião de diagnóstico. A IA irá extrair os dados do negócio, preencher a DRE, calcular o score de saúde e gerar o texto do anúncio..."></textarea>
            <div style="display:flex;gap:8px;margin-top:10px;align-items:center;flex-wrap:wrap">
              <button class="btn btnk" id="ds-btn-extrair" onclick="dsExtrair()" style="font-size:10px;padding:7px 16px">◆ EXTRAIR COM IA</button>
              <button class="btn" style="font-size:9px" onclick="dsLimpar()">↺ Limpar</button>
              <div id="ds-ia-status" style="display:none;flex:1;min-width:200px;padding:8px 12px;border-radius:5px;font-size:8.5px;line-height:1.8"></div>
            </div>
          </div></div>
          <div style="margin-top:10px;padding:12px 14px;background:rgba(245,158,11,.04);border:1px solid rgba(245,158,11,.12);border-radius:5px;font-size:8.5px;color:rgba(255,255,255,.35);line-height:1.8;text-transform:none">
            <b style="color:var(--amber)">Fluxo:</b> Cole transcrição → Extrair com IA → revise cada aba → Validar Bloco 1 → Gerar Avaliação → Gerar Anúncio → Salvar Standby
          </div>
        </div>

        <!-- IDENTIDADE -->
        <div class="ds-body" id="t-ident"><div class="card"><div class="card-hd">IDENTIDADE</div><div style="padding:16px;display:flex;flex-direction:column;gap:10px">
          <div class="ds-fr">
            <div class="ds-fg" style="flex:2"><div class="ds-fl">NOME / TAG INTERNA</div><input class="ds-fi" id="ds-nome" placeholder="Ex: Rede de Cafeterias — 4 unidades" style="text-transform:none"></div>
            <div class="ds-fg"><div class="ds-fl">CATEGORIA</div><select class="ds-fi" id="ds-cat"><option value="">Selecione</option><option>ALIMENTAÇÃO</option><option>TECNOLOGIA</option><option>SAÚDE</option><option>SERVIÇOS B2B</option><option>VAREJO</option><option>INDÚSTRIA</option><option>EDUCAÇÃO</option><option>OUTRO</option></select></div>
          </div>
          <div class="ds-fr">
            <div class="ds-fg" style="flex:2"><div class="ds-fl">CIDADE</div><input class="ds-fi" id="ds-cidade" placeholder="São Paulo"></div>
            <div class="ds-fg" style="max-width:90px"><div class="ds-fl">ESTADO</div><input class="ds-fi" id="ds-estado" placeholder="SP"></div>
            <div class="ds-fg"><div class="ds-fl">REGIME FISCAL</div><select class="ds-fi" id="ds-regime"><option>SIMPLES NACIONAL</option><option>LUCRO PRESUMIDO</option><option>LUCRO REAL</option><option>MEI</option></select></div>
          </div>
          <div class="ds-fr">
            <div class="ds-fg"><div class="ds-fl">ANO DE FUNDAÇÃO</div><input class="ds-fi" id="ds-ano" type="number" placeholder="2018"></div>
            <div class="ds-fg" style="flex:2"><div class="ds-fl">SÓCIOS ATUAIS</div><input class="ds-fi" id="ds-socios" placeholder="Nome e % de participação" style="text-transform:none"></div>
          </div>
          <div class="ds-fg"><div class="ds-fl">TRAJETÓRIA RESUMIDA</div><textarea class="ds-fi" id="ds-trajetoria" rows="3" placeholder="Como surgiu, marcos, crises..." style="resize:vertical;text-transform:none"></textarea></div>
          <div style="border-top:1px solid var(--b1);padding-top:12px;margin-top:2px">
            <div style="font-size:7.5px;letter-spacing:.12em;color:var(--amber);margin-bottom:10px">DADOS DO PROPRIETÁRIO — NUNCA EXIBIDO AO PÚBLICO</div>
            <div class="ds-fr">
              <div class="ds-fg"><div class="ds-fl">NOME REAL</div><input class="ds-fi" id="ds-prop-nome" placeholder="Nome do dono" style="text-transform:none"></div>
              <div class="ds-fg"><div class="ds-fl">WHATSAPP</div><input class="ds-fi" id="ds-prop-wpp" placeholder="+55 11 99999-9999" style="text-transform:none"></div>
              <div class="ds-fg"><div class="ds-fl">E-MAIL</div><input class="ds-fi" id="ds-prop-email" placeholder="email@dominio.com" style="text-transform:none"></div>
            </div>
            <div class="ds-fg" style="margin-top:8px"><div class="ds-fl">PERFIL / OBS. INTERNA</div><textarea class="ds-fi" id="ds-prop-obs" rows="2" placeholder="Tom da abordagem, sensibilidades..." style="resize:none;text-transform:none"></textarea></div>
          </div>
        </div></div></div>

        <!-- OPERAÇÃO -->
        <div class="ds-body" id="t-op"><div class="card"><div class="card-hd">OPERAÇÃO</div><div style="padding:16px;display:flex;flex-direction:column;gap:10px">
          <div class="ds-fr">
            <div class="ds-fg"><div class="ds-fl">Nº FUNCIONÁRIOS</div><input class="ds-fi" id="ds-func" type="number" placeholder="18"></div>
            <div class="ds-fg" style="flex:2"><div class="ds-fl">REGIME (CLT/PJ)</div><input class="ds-fi" id="ds-clt" placeholder="Ex: 12 CLT, 4 PJ, 2 familiares" style="text-transform:none"></div>
          </div>
          <div class="ds-fr">
            <div class="ds-fg"><div class="ds-fl">ALUGUEL MENSAL (R$)</div><input class="ds-fi" id="ds-aluguel" type="number" placeholder="8500"></div>
            <div class="ds-fg" style="flex:2"><div class="ds-fl">PRAZO DO CONTRATO</div><input class="ds-fi" id="ds-prazo-loc" placeholder="Ex: 22 meses (vence mar/27)" style="text-transform:none"></div>
          </div>
          <div class="ds-fg"><div class="ds-fl">PRODUTO / SERVIÇO PRINCIPAL</div><textarea class="ds-fi" id="ds-produto" rows="2" placeholder="O que vende, como funciona no dia a dia..." style="resize:none;text-transform:none"></textarea></div>
          <div class="ds-fr">
            <div class="ds-fg"><div class="ds-fl">TICKET MÉDIO (R$)</div><input class="ds-fi" id="ds-ticket" type="number" placeholder="85"></div>
            <div class="ds-fg"><div class="ds-fl">CANAL DE VENDA</div><input class="ds-fi" id="ds-canal" placeholder="Ex: Físico + Delivery" style="text-transform:none"></div>
            <div class="ds-fg"><div class="ds-fl">DEPENDÊNCIA DO DONO (0–10)</div><input class="ds-fi" id="ds-dep" type="number" min="0" max="10" placeholder="7 = muito dependente"></div>
          </div>
        </div></div></div>

        <!-- FINANCEIRO -->
        <div class="ds-body" id="t-fin"><div class="card"><div class="card-hd">DRE GERENCIAL</div><div style="padding:16px">
          <div style="font-size:7.5px;color:var(--dim);letter-spacing:.1em;margin-bottom:12px">VALORES MENSAIS MÉDIOS (R$) — BORDA ÂMBAR = DEDUZIDO PELA IA</div>
          <div id="dre-rows" style="display:flex;flex-direction:column;gap:8px"></div>
          <div style="margin-top:14px;display:flex;gap:20px;padding:12px;background:var(--s2);border-radius:6px">
            <div><div style="font-size:7.5px;color:var(--dim);margin-bottom:4px">FATURAMENTO BRUTO</div><div id="dre-receita" style="font-family:Syne,sans-serif;font-size:18px;color:var(--green)">—</div></div>
            <div><div style="font-size:7.5px;color:var(--dim);margin-bottom:4px">EBITDA EST.</div><div id="dre-ebitda" style="font-family:Syne,sans-serif;font-size:18px;color:var(--amber)">—</div></div>
            <div><div style="font-size:7.5px;color:var(--dim);margin-bottom:4px">MARGEM</div><div id="dre-mg" style="font-family:Syne,sans-serif;font-size:18px;color:var(--ink)">—</div></div>
          </div>
        </div></div></div>

        <!-- AVALIAÇÃO -->
        <div class="ds-body" id="t-aval">
          <div id="ds-aval-lock" style="padding:40px;text-align:center;border:1px dashed rgba(255,255,255,.1);border-radius:8px">
            <div style="font-size:10px;font-weight:700;letter-spacing:.18em;color:var(--dim)">BLOCO 1 NÃO VALIDADO</div>
            <div style="font-size:8.5px;color:rgba(255,255,255,.2);margin-top:6px">Extraia e valide as informações antes de gerar a avaliação.</div>
          </div>
          <div id="ds-aval-content" style="display:none;flex-direction:column;gap:14px">
            <div style="background:rgba(167,139,250,.05);border:1px solid rgba(167,139,250,.2);border-radius:6px;padding:14px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px">
              <div><div style="font-size:9px;font-weight:700;letter-spacing:.12em;color:#a78bfa">◆ BLOCO 2 — AVALIAÇÃO ASSISTIDA POR IA</div><div style="font-size:8px;color:var(--dim);margin-top:3px">Calcula WACC, DCF, score de saúde (8 dimensões) e múltiplo implícito.</div></div>
              <button class="btn" id="ds-btn-aval" onclick="dsGerarAval()" style="border-color:rgba(167,139,250,.4);color:#a78bfa">◆ GERAR AVALIAÇÃO</button>
            </div>
            <div id="ds-aval-status" style="display:none;padding:10px 14px;border-radius:5px;font-size:8.5px;line-height:1.8"></div>
            <!-- Score -->
            <div id="ds-score-bloco" style="display:none"><div class="card"><div class="card-hd">SCORE DE SAÚDE</div><div style="padding:16px">
              <div style="display:flex;align-items:center;gap:20px;margin-bottom:16px;flex-wrap:wrap">
                <div style="text-align:center"><div id="ds-score-num" style="font-family:Syne,sans-serif;font-size:44px;color:var(--green);line-height:1">—</div><div style="font-size:7px;color:var(--dim);letter-spacing:.1em;margin-top:2px">SCORE GERAL</div></div>
                <div style="flex:1;min-width:200px"><div style="height:8px;background:rgba(255,255,255,.06);border-radius:4px;overflow:hidden;margin-bottom:6px"><div id="ds-score-bar" style="height:100%;width:0%;background:var(--green);transition:width .6s;border-radius:4px"></div></div><div id="ds-score-label" style="font-size:9px;font-weight:700;color:var(--green);letter-spacing:.1em">—</div><div id="ds-score-trava" style="display:none;margin-top:6px;padding:5px 8px;background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.2);border-radius:4px;font-size:7.5px;color:var(--red)">⚠ TRAVA DUPLA ATIVADA — Score limitado a 40</div></div>
              </div>
              <div id="ds-score-dims" style="display:grid;grid-template-columns:1fr 1fr;gap:6px"></div>
              <div id="ds-score-interp" style="margin-top:10px;padding:10px;background:rgba(255,255,255,.02);border:1px solid var(--b1);border-radius:5px;font-size:8.5px;color:rgba(255,255,255,.45);line-height:1.7;text-transform:none"></div>
            </div></div></div>
            <!-- DCF -->
            <div class="card"><div class="card-hd">DCF — FLUXO DE CAIXA DESCONTADO</div><div style="padding:16px;display:flex;flex-direction:column;gap:10px">
              <div class="ds-fr">
                <div class="ds-fg"><div class="ds-fl">FCL ANO 1 (R$)</div><input class="ds-fi" id="ds-fcl1" type="number" placeholder="Auto" style="text-transform:none"></div>
                <div class="ds-fg"><div class="ds-fl">CRESCIMENTO (%)</div><input class="ds-fi" id="ds-cresc" type="number" placeholder="Auto"></div>
                <div class="ds-fg"><div class="ds-fl">WACC (%)</div><select class="ds-fi" id="ds-wacc"><option value="15">15% — SaaS/Tech</option><option value="18">18% — Saúde/Educação</option><option value="22">22% — Serviços B2B</option><option value="24" selected>24% — Varejo/Alimentação</option><option value="26">26% — Indústria</option><option value="28">28% — Construção</option></select></div>
              </div>
              <div id="ds-dcf-result" style="padding:12px;background:var(--s2);border-radius:6px;font-size:11px;color:var(--dim);text-transform:none">Gere a avaliação para ver o resultado.</div>
            </div></div>
          </div>
        </div>

        <!-- VENDA -->
        <div class="ds-body" id="t-venda"><div class="card"><div class="card-hd">CONDIÇÕES DE VENDA</div><div style="padding:16px;display:flex;flex-direction:column;gap:10px">
          <div class="ds-fr">
            <div class="ds-fg"><div class="ds-fl">MOTIVO DA VENDA</div><select class="ds-fi" id="ds-motivo"><option value="">Selecione</option><option>CANSAÇO / BURNOUT</option><option>NOVO PROJETO</option><option>APOSENTADORIA</option><option>CONFLITO SOCIETÁRIO</option><option>DIFICULDADE FINANCEIRA</option><option>OPORTUNIDADE ESTRATÉGICA</option><option>OUTRO</option></select></div>
            <div class="ds-fg"><div class="ds-fl">URGÊNCIA</div><select class="ds-fi" id="ds-urgencia"><option>BAIXA — SEM PRESSA</option><option>MÉDIA — 6–12 MESES</option><option>ALTA — ATÉ 3 MESES</option></select></div>
          </div>
          <div class="ds-fg"><div class="ds-fl">CONTEXTO REAL (PERCEPÇÃO DO CONSULTOR)</div><textarea class="ds-fi" id="ds-contexto" rows="2" placeholder="O que foi dito além das palavras. Há pressão? O motivo declarado bate com o real?" style="resize:none;text-transform:none"></textarea></div>
          <div class="ds-fr">
            <div class="ds-fg"><div class="ds-fl">EXPECTATIVA DO VENDEDOR (R$)</div><input class="ds-fi" id="ds-expect" placeholder="Ex: R$ 1,2M" style="text-transform:none"></div>
            <div class="ds-fg"><div class="ds-fl">PRAZO DE TRANSIÇÃO</div><input class="ds-fi" id="ds-transicao" placeholder="Ex: 90 dias" style="text-transform:none"></div>
          </div>
          <div class="ds-fg"><div class="ds-fl">CONDIÇÕES ACEITAS</div>
            <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:5px">
              <span class="ds-tag on" onclick="this.classList.toggle('on')">À VISTA</span>
              <span class="ds-tag" onclick="this.classList.toggle('on')">PARCELADO</span>
              <span class="ds-tag" onclick="this.classList.toggle('on')">EARN-OUT</span>
              <span class="ds-tag" onclick="this.classList.toggle('on')">PERMUTA</span>
            </div>
          </div>
          <div class="ds-fg"><div class="ds-fl">RISCOS E PASSIVOS OCULTOS</div><textarea class="ds-fi" id="ds-riscos" rows="2" placeholder="Passivos trabalhistas, dívidas, irregularidades..." style="resize:none;text-transform:none"></textarea></div>
          <div class="ds-fg"><div class="ds-fl">POTENCIAL (O QUE UM NOVO DONO PODERIA FAZER)</div><textarea class="ds-fi" id="ds-potencial" rows="2" placeholder="Canais não explorados, eficiências, expansão..." style="resize:none;text-transform:none"></textarea></div>
        </div></div></div>

        <!-- PUBLICAÇÃO -->
        <div class="ds-body" id="t-pub">
          <div id="ds-pub-lock" style="padding:40px;text-align:center;border:1px dashed rgba(255,255,255,.1);border-radius:8px">
            <div style="font-size:10px;font-weight:700;letter-spacing:.18em;color:var(--dim)">BLOCO 2 NÃO GERADO</div>
            <div style="font-size:8.5px;color:rgba(255,255,255,.2);margin-top:6px">Gere a avaliação primeiro.</div>
          </div>
          <div id="ds-pub-content" style="display:none;flex-direction:column;gap:14px">
            <div style="background:rgba(16,185,129,.05);border:1px solid rgba(16,185,129,.2);border-radius:6px;padding:14px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px">
              <div><div style="font-size:9px;font-weight:700;letter-spacing:.12em;color:var(--green)">◆ BLOCO 3 — GERAR ANÚNCIO</div><div style="font-size:8px;color:var(--dim);margin-top:3px">IA gera tag, análise, ponto de atenção e tese a partir do Bloco 2.</div></div>
              <button class="btn btng" id="ds-btn-pub" onclick="dsGerarAnuncio()">◆ GERAR ANÚNCIO</button>
            </div>
            <div id="ds-pub-status" style="display:none;padding:10px 14px;border-radius:5px;font-size:8.5px;line-height:1.8"></div>
            <div class="card"><div class="card-hd">DADOS DE PUBLICAÇÃO</div><div style="padding:16px;display:flex;flex-direction:column;gap:10px">
              <div class="ds-fr">
                <div class="ds-fg"><div class="ds-fl">PREÇO PEDIDO (R$)</div><input class="ds-fi" id="ds-preco" type="number" placeholder="Ex: 800000"></div>
                <div class="ds-fg"><div class="ds-fl">SCORE SAÚDE (0–100)</div><input class="ds-fi" id="ds-score-pub" type="number" min="0" max="100" placeholder="Auto"></div>
              </div>
              <div class="ds-fg"><div class="ds-fl">ANÁLISE 1NEGÓCIO (EXIBIDA NO ANÚNCIO)</div><textarea class="ds-fi" id="ds-analise" rows="3" placeholder="Análise de oportunidade para o comprador..." style="resize:vertical;text-transform:none"></textarea></div>
              <div class="ds-fg"><div class="ds-fl">PONTO DE ATENÇÃO (EXIBIDO AO COMPRADOR)</div><textarea class="ds-fi" id="ds-ponto" rows="2" placeholder="Risco + sugestão de mitigação..." style="resize:none;text-transform:none"></textarea></div>
              <div class="ds-fg"><div class="ds-fl">TESE DE INVESTIMENTO (INTERNA)</div><textarea class="ds-fi" id="ds-tese" rows="2" placeholder="Visão do consultor para guiar o match com compradores..." style="resize:none;text-transform:none"></textarea></div>
            </div></div>
            <div style="display:flex;gap:8px"><button class="btn btng" onclick="dsSalvarNegocio()">✓ SALVAR COMO STANDBY</button><button class="btn" style="font-size:9px" onclick="dsLimpar()">↺ Novo Dossiê</button></div>
          </div>
        </div>

        <!-- RODAPÉ -->
        <div style="margin-top:20px;display:flex;gap:8px;border-top:1px solid var(--b1);padding-top:16px;flex-wrap:wrap;align-items:center">
          <button class="btn btnk" id="ds-btn-validar" onclick="dsValidarB1()">✓ VALIDAR BLOCO 1</button>
          <button class="btn" id="ds-btn-gerar-aval-ft" onclick="dsGerarAval()" style="display:none;border-color:rgba(167,139,250,.4);color:#a78bfa">◆ GERAR AVALIAÇÃO</button>
          <button class="btn btng" id="ds-btn-pub-ft" onclick="dsSalvarNegocio()" style="display:none">✓ SALVAR STANDBY</button>
          <span style="font-size:8px;color:var(--dim);margin-left:auto;text-transform:none" id="ds-footer-txt"></span>
        </div>
      </div>

      <div class="view" id="view-negocios"><div class="card"><div class="card-hd">Todos os Negócios</div><div id="tbl-negocios"><div class="ld">carregando...</div></div></div></div>
      <div class="view" id="view-leads"><div class="card"><div class="card-hd">Leads do Site</div><div id="tbl-leads"><div class="ld">carregando...</div></div></div></div>
      <div class="view" id="view-chatdrafts"><div class="card"><div class="card-hd">Chat Drafts</div><div id="tbl-chats"><div class="ld">carregando...</div></div></div></div>
      <div class="view" id="view-solicitacoes"><div class="card"><div class="card-hd">Solicitações de Dossiê</div><div id="tbl-sol"><div class="ld">carregando...</div></div></div></div>
      <div class="view" id="view-mesas"><div class="card"><div class="card-hd">Mesas de Negociação</div><div id="tbl-mesas"><div class="ld">carregando...</div></div></div></div>
      <div class="view" id="view-usuarios"><div class="card"><div class="card-hd">Usuários do Portal</div><div id="tbl-usuarios"><div class="ld">carregando...</div></div></div></div>
    </div>
  </div>
</div>
<div id="toast"></div>

<script>
var SB = 'https://dbijmgqlcrgjlcfrastg.supabase.co';
var PWD = '1negocio2025';
var SK = '1n_adm';
var KK = '1n_srv';

function getKey() { return sessionStorage.getItem(KK) || ''; }

function updateKeyIndicator() {
  var k = getKey();
  var ind = document.getElementById('keyIndicator');
  if (k && k.length > 20) {
    ind.textContent = '● CONECTADO';
    ind.style.color = 'var(--green)';
  } else {
    ind.textContent = '● SEM CHAVE';
    ind.style.color = 'var(--red)';
  }
}

function openSrvKeyModal() {
  var k = getKey();
  document.getElementById('kinp').value = k || '';
  document.getElementById('kstatus').textContent = '';
  document.getElementById('kstatus').className = 'kstatus';
  document.getElementById('ovSrvKey').classList.add('on');
  setTimeout(function() { document.getElementById('kinp').focus(); }, 100);
}

document.getElementById('btnChave').onclick = openSrvKeyModal;
document.getElementById('sideChave').onclick = openSrvKeyModal;
document.getElementById('kcancel').onclick = function() {
  document.getElementById('ovSrvKey').classList.remove('on');
};
document.getElementById('ovSrvKey').onclick = function(e) {
  if (e.target === this) this.classList.remove('on');
};

document.getElementById('ksave').onclick = async function() {
  var v = document.getElementById('kinp').value.trim();
  var st = document.getElementById('kstatus');
  if (!v || v.length < 20) {
    st.textContent = 'Chave inválida.';
    st.className = 'kstatus err';
    return;
  }
  st.textContent = 'Verificando...';
  st.className = 'kstatus';
  try {
    var r = await fetch(SB + '/rest/v1/negocios?select=id&limit=1', {
      headers: { 'apikey': v, 'Authorization': 'Bearer ' + v }
    });
    if (r.ok || r.status === 406) {
      sessionStorage.setItem(KK, v);
      st.textContent = '✓ Chave válida! Conectado.';
      st.className = 'kstatus ok';
      updateKeyIndicator();
      setTimeout(function() {
        document.getElementById('ovSrvKey').classList.remove('on');
        done = {};
        init();
      }, 900);
    } else {
      st.textContent = 'Erro ' + r.status + ': chave rejeitada.';
      st.className = 'kstatus err';
    }
  } catch(e) {
    st.textContent = 'Erro de rede: ' + e.message;
    st.className = 'kstatus err';
  }
};

function showApp() {
  document.getElementById('login').style.display = 'none';
  document.getElementById('app').style.display = 'flex';
  updateKeyIndicator();
  setupNav();
  var k = getKey();
  if (!k || k.length < 20) {
    setTimeout(openSrvKeyModal, 400);
  } else {
    init();
  }
}

function doLogin() {
  if (document.getElementById('lpwd').value === PWD) {
    sessionStorage.setItem(SK, '1');
    showApp();
  } else {
    document.getElementById('lerr').textContent = 'SENHA INCORRETA';
    document.getElementById('lpwd').value = '';
    document.getElementById('lpwd').focus();
  }
}

document.getElementById('lbtn').onclick = doLogin;
document.getElementById('lpwd').onkeydown = function(e) { if (e.key === 'Enter') doLogin(); };

function setupNav() {
  document.querySelectorAll('.si[data-view]').forEach(function(el) {
    el.onclick = function() {
      var v = this.getAttribute('data-view');
      document.querySelectorAll('.view').forEach(function(x) { x.classList.remove('on'); });
      document.querySelectorAll('.si').forEach(function(x) { x.classList.remove('on'); });
      document.getElementById('view-' + v).classList.add('on');
      this.classList.add('on');
      document.getElementById('vcur').textContent = v.toUpperCase();
      load(v);
    };
  });
}

var done = {};
function load(v) {
  if (done[v]) return;
  done[v] = true;
  if (v === 'painel') loadPainel();
  else if (v === 'agenda') loadAgenda(false);
  else if (v === 'negocios') loadNegocios();
  else if (v === 'leads') loadLeads();
  else if (v === 'chatdrafts') loadChats();
  else if (v === 'solicitacoes') loadSol();
  else if (v === 'mesas') loadMesas();
  else if (v === 'usuarios') loadUsers();
}

function showView(v) {
  document.querySelectorAll('.view').forEach(function(x) { x.classList.remove('on'); });
  document.querySelectorAll('.si').forEach(function(x) { x.classList.remove('on'); });
  document.getElementById('view-' + v).classList.add('on');
  var si = document.querySelector('.si[data-view="' + v + '"]');
  if (si) si.classList.add('on');
  document.getElementById('vcur').textContent = v.toUpperCase();
  load(v);
}

async function api(path) {
  var KEY = getKey();
  if (!KEY) { openSrvKeyModal(); throw new Error('Chave não configurada'); }
  var r = await fetch(SB + '/rest/v1/' + path, {
    headers: { 'apikey': KEY, 'Authorization': 'Bearer ' + KEY, 'Content-Type': 'application/json' }
  });
  if (!r.ok) throw new Error(await r.text());
  return r.json();
}
async function patch(path, body) {
  var KEY = getKey();
  if (!KEY) return false;
  var r = await fetch(SB + '/rest/v1/' + path, {
    method: 'PATCH',
    headers: { 'apikey': KEY, 'Authorization': 'Bearer ' + KEY, 'Content-Type': 'application/json', 'Prefer': 'return=minimal' },
    body: JSON.stringify(body)
  });
  return r.ok;
}

function fmt(v) { if (!v) return '—'; v = Number(v); if (v >= 1e6) return 'R$ ' + (v/1e6).toFixed(1).replace('.',',') + 'M'; if (v >= 1e3) return 'R$ ' + (v/1e3).toFixed(0) + 'K'; return 'R$ ' + v; }
function fd(d) { if (!d) return '—'; return new Date(d).toLocaleDateString('pt-BR'); }
function b(s, lbl) {
  var l = lbl || (s || '—').toUpperCase();
  if (s === 'publicado' || s === 'liberado' || s === 'ativa') return '<span class="bdg bg">' + l + '</span>';
  if (s === 'em_avaliacao' || s === 'aguardando' || s === 'novo') return '<span class="bdg ba">' + l + '</span>';
  if (s === 'sell' || s === 'buy') return '<span class="bdg bb">' + l + '</span>';
  return '<span class="bdg bd">' + l + '</span>';
}
function toast(m) { var t = document.getElementById('toast'); t.textContent = m; t.classList.add('on'); setTimeout(function() { t.classList.remove('on'); }, 2500); }

function init() {
  api('negocios?select=id,status&status=eq.publicado').then(function(d) { document.getElementById('st-neg').textContent = d.length; }).catch(function() {});
  api('leads_site?select=id').then(function(d) { document.getElementById('st-leads').textContent = d.length; if (d.length) document.getElementById('b-leads').textContent = d.length; }).catch(function() {});
  api('chat_drafts?select=id').then(function(d) { document.getElementById('st-chats').textContent = d.length; if (d.length) document.getElementById('b-chats').textContent = d.length; }).catch(function() {});
  api('usuarios?select=id').then(function(d) { document.getElementById('st-users').textContent = d.length; }).catch(function() {});
  api('solicitacoes_info?select=id&status=eq.aguardando').then(function(d) { document.getElementById('st-sol').textContent = d.length; if (d.length) document.getElementById('b-sol').textContent = d.length; }).catch(function() {});
  api('mesas_negociacao?select=id&status=eq.ativa').then(function(d) { document.getElementById('st-mesas').textContent = d.length; }).catch(function() {});
  loadAgenda(false);
  load('painel');
}

if (sessionStorage.getItem(SK) === '1') { showApp(); }

async function loadPainel() {
  var el = document.getElementById('painel-negs');
  try {
    var d = await api('negocios?select=nome,categoria,cidade,estado,status,preco_pedido,faturamento_anual,score_saude,created_at&order=created_at.desc');
    if (!d.length) { el.innerHTML = '<div class="empty">Nenhum negócio ainda.</div>'; return; }
    var h = '<table><thead><tr><th>Nome</th><th>Categoria</th><th>Status</th><th>Preço</th><th>Faturamento</th><th>Data</th></tr></thead><tbody>';
    d.forEach(function(n) { h += '<tr><td><b>' + (n.nome||'—') + '</b></td><td>' + (n.categoria||'—') + '</td><td>' + b(n.status) + '</td><td>' + fmt(n.preco_pedido) + '</td><td>' + fmt(n.faturamento_anual) + '</td><td>' + fd(n.created_at) + '</td></tr>'; });
    el.innerHTML = h + '</tbody></table>';
  } catch(e) { el.innerHTML = '<div class="empty">Erro: ' + e.message + '</div>'; }
}

async function loadNegocios() {
  var el = document.getElementById('tbl-negocios');
  try {
    var d = await api('negocios?select=nome,categoria,cidade,estado,status,preco_pedido,faturamento_anual,score_saude,created_at&order=created_at.desc');
    if (!d.length) { el.innerHTML = '<div class="empty">Nenhum negócio.</div>'; return; }
    var h = '<table><thead><tr><th>Nome</th><th>Categoria</th><th>Cidade</th><th>Status</th><th>Preço</th><th>Faturamento</th><th>Saúde</th><th>Data</th></tr></thead><tbody>';
    d.forEach(function(n) { h += '<tr><td><b>' + (n.nome||'—') + '</b></td><td>' + (n.categoria||'—') + '</td><td>' + (n.cidade ? n.cidade+'/'+n.estado : '—') + '</td><td>' + b(n.status) + '</td><td>' + fmt(n.preco_pedido) + '</td><td>' + fmt(n.faturamento_anual) + '</td><td>' + (n.score_saude||'—') + '</td><td>' + fd(n.created_at) + '</td></tr>'; });
    el.innerHTML = h + '</tbody></table>';
  } catch(e) { el.innerHTML = '<div class="empty">Erro: ' + e.message + '</div>'; }
}

async function loadLeads() {
  var el = document.getElementById('tbl-leads');
  try {
    var d = await api('leads_site?select=*&order=created_at.desc');
    if (!d.length) { el.innerHTML = '<div class="empty">Nenhum lead ainda.</div>'; return; }
    var h = '<table><thead><tr><th>Nome</th><th>WhatsApp</th><th>Tipo</th><th>Status</th><th>Data</th><th></th></tr></thead><tbody>';
    d.forEach(function(l) {
      h += '<tr><td><b>' + (l.nome||'—') + '</b></td><td>' + (l.whatsapp||'—') + '</td><td>' + (l.corretor ? b('','CORRETOR') : b('buy','COMPRADOR')) + '</td><td>' + b(l.status||'novo') + '</td><td>' + fd(l.created_at) + '</td><td><button class="btn btng" data-id="' + l.id + '">Contatado ✓</button></td></tr>';
    });
    el.innerHTML = h + '</tbody></table>';
    el.querySelectorAll('button[data-id]').forEach(function(btn) {
      btn.onclick = async function() {
        this.disabled = true;
        if (await patch('leads_site?id=eq.' + this.dataset.id, { status: 'contatado' })) { this.textContent = '✓ Feito'; toast('Marcado ✓'); } else { this.disabled = false; toast('Erro'); }
      };
    });
  } catch(e) { el.innerHTML = '<div class="empty">Erro: ' + e.message + '</div>'; }
}

async function loadChats() {
  var el = document.getElementById('tbl-chats');
  try {
    var d = await api('chat_drafts?select=*&order=created_at.desc');
    if (!d.length) { el.innerHTML = '<div class="empty">Nenhuma conversa ainda.</div>'; return; }
    var h = '';
    d.forEach(function(c, i) {
      var campos = {}; try { campos = typeof c.campos_json === 'string' ? JSON.parse(c.campos_json) : (c.campos_json || {}); } catch(e) {}
      var pct = c.progresso_pct || 0;
      var pctColor = pct >= 70 ? 'var(--green)' : pct >= 40 ? '#f59e0b' : 'var(--red)';
      var vinculado = !!c.usuario_id;
      var camposHtml = '';
      var campoLabels = {
        nome_negocio:'Negócio',setor_tipo:'Setor',modelo_receita:'Modelo',cidade_estado:'Cidade/UF',
        unidades:'Unidades',tempo_operacao:'Tempo',faturamento_mensal:'Faturamento',
        tendencia:'Tendência',margem_estimada:'Margem',folha_pagamento:'Folha',
        aluguel_mensal:'Aluguel',dividas_passivos:'Dívidas',situacao_fiscal:'Fiscal',
        funcionarios:'Funcionários',socios:'Sócios',dependencia_do_dono:'Dep. Dono',
        motivo_venda:'Motivo',urgencia:'Urgência',expectativa_valor:'Expectativa R$',
        condicoes_pagamento:'Condições',periodo_transicao:'Transição',informacao_extra:'Extra'
      };
      Object.keys(campoLabels).forEach(function(k) {
        if (campos[k] && campos[k] !== 'null') {
          camposHtml += '<span style="display:inline-block;margin:2px 4px 2px 0;padding:2px 8px;background:var(--s2);border-radius:4px;font-size:11px"><b style="color:var(--dim)">' + campoLabels[k] + ':</b> ' + campos[k] + '</span>';
        }
      });
      var wppLink = c.whatsapp ? '<a href="https://wa.me/55' + c.whatsapp.replace(/\D/g,'') + '" target="_blank" style="color:var(--green);text-decoration:none">' + c.whatsapp + ' ↗</a>' : '—';
      var emailHtml = c.email
        ? '<span style="color:var(--ink)">' + c.email + '</span>'
        : '<span style="color:var(--dim);font-style:italic">sem email</span>';
      var vinculoHtml = vinculado
        ? '<span class="bdg bg" style="font-size:9px">USUÁRIO ✓</span>'
        : '<span class="bdg bd" style="font-size:9px">SEM CONTA</span>';

      h += '<div style="border:1px solid var(--b1);border-radius:6px;margin-bottom:10px;overflow:hidden">';
      // Header do card
      h += '<div style="display:flex;align-items:center;padding:12px 14px;cursor:pointer;gap:12px" onclick="toggleChat(' + i + ')">';
      h += '<div style="flex:1;min-width:0">';
      h += '<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">';
      h += '<b style="font-size:13px">' + (c.nome||'—') + '</b>';
      h += emailHtml;
      h += vinculoHtml;
      h += '</div>';
      h += '<div style="font-size:10px;color:var(--dim);margin-top:2px">' + fd(c.created_at) + (campos.nome_negocio && campos.nome_negocio !== 'null' ? ' · ' + campos.nome_negocio : '') + '</div>';
      h += '</div>';
      h += '<div style="font-size:13px;font-weight:700;color:' + pctColor + ';min-width:38px;text-align:right">' + pct + '%</div>';
      h += (c.convertido ? '<span class="bdg bg" style="font-size:10px">CRIADO</span>' : '<span class="bdg ba" style="font-size:10px">RASCUNHO</span>');
      h += '<span style="color:var(--dim);font-size:13px;margin-left:6px">▾</span>';
      h += '</div>';

      // Body expansível
      h += '<div id="cc-body-' + i + '" style="display:none;padding:14px;border-top:1px solid var(--b1)">';

      // Linha de contato
      h += '<div style="display:flex;gap:16px;margin-bottom:12px;flex-wrap:wrap">';
      h += '<div><div style="font-size:7.5px;letter-spacing:.12em;color:var(--dim);margin-bottom:3px">WHATSAPP</div>' + wppLink + '</div>';
      h += '<div><div style="font-size:7.5px;letter-spacing:.12em;color:var(--dim);margin-bottom:3px">E-MAIL</div>' + emailHtml + '</div>';
      h += '<div><div style="font-size:7.5px;letter-spacing:.12em;color:var(--dim);margin-bottom:3px">USUÁRIO</div>' + (vinculado ? '<span style="color:var(--green);font-size:11px">✓ Conta criada</span>' : '<span style="color:var(--amber);font-size:11px">Não criou conta</span>') + '</div>';
      h += '</div>';

      if (camposHtml) {
        h += '<div style="margin-bottom:12px">' + camposHtml + '</div>';
      } else {
        h += '<div style="color:var(--dim);font-size:12px;margin-bottom:12px">Nenhum campo coletado.</div>';
      }
      if (c.transcricao) {
        h += '<div style="margin-bottom:12px"><button class="btn" style="font-size:11px" onclick="toggleTranscricao(' + i + ')">📋 Ver transcrição</button><div id="tr-' + i + '" style="display:none;margin-top:8px;background:var(--s2);padding:10px;border-radius:4px;font-size:11px;white-space:pre-wrap;max-height:220px;overflow-y:auto;line-height:1.6">' + escHtml(c.transcricao) + '</div></div>';
      }
      // Ações
      h += '<div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:4px">';
      if (!c.convertido) {
        h += '<button class="btn btng" onclick="criarNegocioDeChat(\'' + c.id + '\',' + i + ')">✦ Criar Negócio</button>';
      } else if (c.negocio_id) {
        h += '<span style="color:var(--green);font-size:12px;padding:5px 0">✓ Negócio criado</span>';
      }
      if (c.whatsapp) {
        h += '<a href="https://wa.me/55' + c.whatsapp.replace(/\D/g,'') + '?text=Olá ' + encodeURIComponent(c.nome||'') + '%2C+tudo+bem%3F+Sou+da+equipe+1Negócio+e+estou+entrando+em+contato+sobre+a+avaliação+do+seu+negócio." target="_blank" class="btn" style="text-decoration:none;font-size:10px">💬 WhatsApp</a>';
      }
      h += '</div>';
      h += '</div></div>';
    });
    el.innerHTML = h;
  } catch(e) { el.innerHTML = '<div class="empty">Erro: ' + e.message + '</div>'; }
}

function toggleChat(i) {
  var body = document.getElementById('cc-body-' + i);
  body.style.display = body.style.display === 'none' ? 'block' : 'none';
}

function toggleTranscricao(i) {
  var tr = document.getElementById('tr-' + i);
  tr.style.display = tr.style.display === 'none' ? 'block' : 'none';
}

function escHtml(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

async function criarNegocioDeChat(chatId, idx) {
  var btn = event.target; btn.disabled = true; btn.textContent = 'Criando...';
  var KEY = getKey();
  if (!KEY) { toast('Chave API não configurada'); btn.disabled = false; return; }

  // Busca o draft completo
  var r = await fetch(SB + '/rest/v1/chat_drafts?id=eq.' + chatId + '&select=*', {
    headers: { 'apikey': KEY, 'Authorization': 'Bearer ' + KEY }
  });
  var drafts = await r.json();
  var draft = drafts[0];
  if (!draft) { toast('Draft não encontrado'); btn.disabled = false; return; }

  var campos = {}; try { campos = typeof draft.campos_json === 'string' ? JSON.parse(draft.campos_json) : (draft.campos_json || {}); } catch(e) {}

  // Monta negocio com o que temos
  var nomeFinal = campos.nome_negocio && campos.nome_negocio !== 'null' ? campos.nome_negocio : ('Conversa ' + (draft.nome || '') + ' — ' + new Date().toLocaleDateString('pt-BR'));
  var negocio = {
    nome: nomeFinal,
    categoria: campos.setor_tipo && campos.setor_tipo !== 'null' ? campos.setor_tipo : null,
    cidade: campos.cidade_estado && campos.cidade_estado !== 'null' ? campos.cidade_estado.split('/')[0] : null,
    estado: campos.cidade_estado && campos.cidade_estado !== 'null' ? (campos.cidade_estado.split('/')[1] || null) : null,
    motivo_venda: campos.motivo_venda && campos.motivo_venda !== 'null' ? campos.motivo_venda : null,
    urgencia: campos.urgencia && campos.urgencia !== 'null' ? campos.urgencia : null,
    expectativa_valor: campos.expectativa_valor && campos.expectativa_valor !== 'null' ? campos.expectativa_valor : null,
    prazo_transicao: campos.periodo_transicao && campos.periodo_transicao !== 'null' ? campos.periodo_transicao : null,
    analise_1n: 'Rascunho criado a partir de conversa de chat (' + (draft.progresso_pct||0) + '% de progresso).\n\nVendedor: ' + (draft.nome||'—') + ' | WPP: ' + (draft.whatsapp||'—'),
    status: 'em_avaliacao'
  };

  // Parse faturamento mensal → anual estimado
  if (campos.faturamento_mensal && campos.faturamento_mensal !== 'null') {
    var raw = campos.faturamento_mensal.replace(/[^\d,\.]/g,'').replace(',','.');
    var v = parseFloat(raw);
    if (!isNaN(v) && v > 0) negocio.faturamento_anual = v * 12;
  }
  if (campos.funcionarios && campos.funcionarios !== 'null') {
    var fn = parseInt(campos.funcionarios);
    if (!isNaN(fn)) negocio.funcionarios = fn;
  }
  if (campos.folha_pagamento && campos.folha_pagamento !== 'null') {
    var fp = parseFloat(campos.folha_pagamento.replace(/[^\d,\.]/g,'').replace(',','.'));
    if (!isNaN(fp)) negocio.folha_pagamento = fp;
  }
  if (campos.aluguel_mensal && campos.aluguel_mensal !== 'null') {
    var am = parseFloat(campos.aluguel_mensal.replace(/[^\d,\.]/g,'').replace(',','.'));
    if (!isNaN(am)) negocio.aluguel_mensal = am;
  }

  var nr = await fetch(SB + '/rest/v1/negocios', {
    method: 'POST',
    headers: { 'apikey': KEY, 'Authorization': 'Bearer ' + KEY, 'Content-Type': 'application/json', 'Prefer': 'return=representation' },
    body: JSON.stringify(negocio)
  });
  if (!nr.ok) { var err = await nr.text(); toast('Erro ao criar negócio'); btn.textContent = '✦ Criar Negócio'; btn.disabled = false; console.error(err); return; }
  var novos = await nr.json();
  var novoId = novos[0] && novos[0].id;

  // Atualiza chat_draft como convertido
  await fetch(SB + '/rest/v1/chat_drafts?id=eq.' + chatId, {
    method: 'PATCH',
    headers: { 'apikey': KEY, 'Authorization': 'Bearer ' + KEY, 'Content-Type': 'application/json', 'Prefer': 'return=minimal' },
    body: JSON.stringify({ convertido: true, negocio_id: novoId })
  });

  toast('Negócio criado em Em Avaliação ✓');
  done.chatdrafts = false;
  loadChats();
  done.negocios = false;
  done.painel = false;
}

async function loadSol() {
  var el = document.getElementById('tbl-sol');
  try {
    var d = await api('solicitacoes_info?select=*,negocios(nome),usuarios(nome,email)&order=created_at.desc');
    if (!d.length) { el.innerHTML = '<div class="empty">Nenhuma solicitação ainda.</div>'; return; }
    var h = '<table><thead><tr><th>Comprador</th><th>Negócio</th><th>CNPJ</th><th>Status</th><th>Data</th><th></th></tr></thead><tbody>';
    d.forEach(function(s) {
      var btns = s.status === 'aguardando'
        ? '<button class="btn btng" data-action="lib" data-id="' + s.id + '">Liberar</button> <button class="btn btnr" data-action="rec" data-id="' + s.id + '">Recusar</button>'
        : '—';
      h += '<tr><td><b>' + (s.usuarios&&s.usuarios.nome||'—') + '</b></td><td>' + (s.negocios&&s.negocios.nome||'—') + '</td><td>' + (s.cnpj_informado||'—') + '</td><td>' + b(s.status) + '</td><td>' + fd(s.created_at) + '</td><td>' + btns + '</td></tr>';
    });
    el.innerHTML = h + '</tbody></table>';
    el.querySelectorAll('button[data-id]').forEach(function(btn) {
      btn.onclick = async function() {
        var id = this.dataset.id; this.disabled = true;
        var ok = this.dataset.action === 'lib'
          ? await patch('solicitacoes_info?id=eq.' + id, { status: 'liberado', liberado_em: new Date().toISOString() })
          : await patch('solicitacoes_info?id=eq.' + id, { status: 'recusado' });
        if (ok) { toast('Atualizado ✓'); done.solicitacoes = false; loadSol(); } else toast('Erro');
      };
    });
  } catch(e) { el.innerHTML = '<div class="empty">Erro: ' + e.message + '</div>'; }
}

