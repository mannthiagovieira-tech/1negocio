function setStepUI(n){
  [1,2,3].forEach(i=>{
    const el = $('step'+i);
    if(!el) return;
    el.classList.remove('active','done');
    const dot = el.querySelector('.step-dot');
    if(i < n){ el.classList.add('done'); if(dot) dot.textContent = '✓'; }
    else if(i === n){ el.classList.add('active'); if(dot) dot.textContent = n === 1 ? '1' : String(n); }
    else { if(dot) dot.textContent = String(i); }
  });
  // Passo 1 é ✓ quando a gente já passou dele
  if(n > 1){ const d1 = $('step1').querySelector('.step-dot'); if(d1) d1.textContent = '✓'; }
  else { const d1 = $('step1').querySelector('.step-dot'); if(d1) d1.textContent = '1'; }
}

// ═══════════════════════════════════════════════
// UPLOAD DE DOCUMENTO (Supabase Storage)
// ═══════════════════════════════════════════════
async function fazerUploadDoc(){
  if(!ctx.docFile) return ctx.docUrl || null;
  
  // Garante sessão válida (refresh se necessário)
  const sessaoOk = await garantirSessaoValida();
  if(!sessaoOk){
    throw new Error('Sua sessão expirou. Por favor, acesse /portal-usuario.html, faça login novamente e depois volte a este link.');
  }

  const userId = ctx.solicitacao.usuario_id;
  if(!userId) throw new Error('Usuário não identificado');

  // Nome do arquivo
  const ext = (ctx.docFile.name.split('.').pop() || 'jpg').toLowerCase();
  const ts = Date.now();
  const path = userId + '/doc_' + ts + '.' + ext;

  // Mostra progress
  const progEl = $('upload-progress');
  const barEl = $('upload-progress-bar');
  progEl.style.display = 'block';
  barEl.style.width = '20%';

  // Upload
  const uploadUrl = SUPABASE_URL + '/storage/v1/object/nda-docs/' + encodeURIComponent(path);
  const res = await fetch(uploadUrl, {
    method: 'POST',
    headers: {
      'Authorization': 'Bearer ' + ctx.session.token,
      'apikey': SUPABASE_ANON,
      'Content-Type': ctx.docFile.type || 'application/octet-stream',
      'x-upsert': 'true'
    },
    body: ctx.docFile
  });
  barEl.style.width = '100%';

  if(!res.ok){
    const txt = await res.text();
    console.error('[Termo] Upload falhou:', res.status, txt);
    throw new Error('Upload falhou');
  }

  // Path do arquivo (não URL pública, pois bucket é privado)
  return path;
}

// ═══════════════════════════════════════════════
// ASSINATURA FINAL
// ═══════════════════════════════════════════════
function toggleAceite(){
  // chamado pelo clique no label (não precisa fazer nada — só garantir botão)
  setTimeout(()=>{
    const cb = $('cb-aceite');
    $('btn-assinar').disabled = !cb.checked;
  }, 0);
}
// Também observa mudança direta no checkbox
document.addEventListener('change', (e)=>{
  if(e.target && e.target.id === 'cb-aceite'){
    $('btn-assinar').disabled = !e.target.checked;
  }
});

async function assinar(){
  hideErr('passo3-erro');
  const cb = $('cb-aceite');
  if(!cb.checked){
    showErr('passo3-erro','É preciso marcar o aceite antes de assinar.');
    return;
  }

  const btn = $('btn-assinar');
  const loading = $('loading-assinar');
  btn.disabled = true;
  loading.classList.add('show');

  // Garante sessão válida logo no início (refresh se necessário)
  const sessaoOk = await garantirSessaoValida();
  if(!sessaoOk){
    showErr('passo3-erro','Sua sessão expirou. Por favor, acesse /portal-usuario.html, faça login novamente e depois volte a este link.');
    btn.disabled = false; loading.classList.remove('show');
    return;
  }

  try {
    // 1) Upload do doc se houver
    let docPath = ctx.docUrl;
    if(ctx.docFile && !ctx.docUrl){
      try {
        docPath = await fazerUploadDoc();
      } catch(e){
        showErr('passo3-erro','Erro ao enviar o documento. Tente novamente.');
        btn.disabled = false; loading.classList.remove('show');
        return;
      }
    }

    // 2) Montar payload de dados pessoais
    const dadosPessoais = {
      cpf: $('f-cpf').value.trim(),
      rg: $('f-rg').value.trim(),
      profissao: $('f-profissao').value.trim(),
      estado_civil: $('f-estado-civil').value,
      endereco: {
        cep: $('f-cep').value.trim(),
        logradouro: $('f-logradouro').value.trim(),
        bairro: $('f-bairro').value.trim(),
        cidade: $('f-cidade').value.trim(),
        estado: $('f-estado').value.trim().toUpperCase()
      },
      doc_foto_url: docPath
    };
    const autorizaSalvar = $('cb-lgpd').checked;

    const headersAuth = {
      'Content-Type': 'application/json',
      'apikey': SUPABASE_ANON,
      'Authorization': 'Bearer ' + (ctx.session && ctx.session.token ? ctx.session.token : SUPABASE_ANON)
    };

    // 3) Atualizar usuarios.dados_pessoais (se autorizou)
    if(autorizaSalvar && ctx.solicitacao.usuario_id && ctx.session){
      await fetch(SUPABASE_URL + '/rest/v1/usuarios?id=eq.' + ctx.solicitacao.usuario_id, {
        method:'PATCH',
        headers: { ...headersAuth, 'Prefer':'return=minimal' },
        body: JSON.stringify({
          nome: $('f-nome').value.trim(),
          dados_pessoais: dadosPessoais,
          dados_pessoais_autorizado: true,
          dados_pessoais_autorizado_em: new Date().toISOString(),
          updated_at: new Date().toISOString()
        })
      });
    }

    // 4) Atualizar nda_solicitacoes com os dados do signatário
    await fetch(SUPABASE_URL + '/rest/v1/nda_solicitacoes?id=eq.' + ctx.solicitacao.id, {
      method:'PATCH',
      headers: { ...headersAuth, 'Prefer':'return=minimal' },
      body: JSON.stringify({
        nome_completo: $('f-nome').value.trim(),
        cpf: $('f-cpf').value.trim(),
        endereco: $('f-logradouro').value.trim() + ', ' + $('f-bairro').value.trim(),
        cidade: $('f-cidade').value.trim(),
        estado: $('f-estado').value.trim().toUpperCase(),
        cep: $('f-cep').value.trim(),
        profissao: $('f-profissao').value.trim(),
        doc_url: docPath,
        doc_nome: ctx.docFile ? ctx.docFile.name : null,
        doc_enviado_em: (ctx.docFile || docPath) ? new Date().toISOString() : null,
        status: 'em_analise',
        updated_at: new Date().toISOString()
      })
    });

    // 5) Criar registro em nda_assinaturas (auditoria)
    const assinPayload = {
      usuario_id: ctx.solicitacao.usuario_id,
      negocio_id: ctx.solicitacao.negocio_id,
      solicitacao_id: ctx.solicitacao.solicitacao_info_id || null,
      nda_solicitacao_id: ctx.solicitacao.id,
      tipo: 'dossie',
      tipo_termo: 'nda_habilitacao',
      doc_url: docPath,
      doc_nome: ctx.docFile ? ctx.docFile.name : null,
      ip: ctx.ip,
      ip_assinatura: ctx.ip,
      user_agent: navigator.userAgent,
      assinado_em: new Date().toISOString()
    };
    const assinRes = await fetch(SUPABASE_URL + '/rest/v1/nda_assinaturas', {
      method:'POST',
      headers: { ...headersAuth, 'Prefer':'return=minimal' },
      body: JSON.stringify(assinPayload)
    });
    if(!assinRes.ok){
      const txt = await assinRes.text();
      console.error('[Termo] Erro ao gravar nda_assinaturas:', assinRes.status, txt);
      // Não interrompe o fluxo — é auditoria, não crítico
    }

    // 6) Atualizar solicitacoes_info → status 'nda_assinado'
    if(ctx.solicitacao.solicitacao_info_id){
      await fetch(SUPABASE_URL + '/rest/v1/solicitacoes_info?id=eq.' + ctx.solicitacao.solicitacao_info_id, {
        method:'PATCH',
        headers: { ...headersAuth, 'Prefer':'return=minimal' },
        body: JSON.stringify({
          status: 'nda_assinado',
          updated_at: new Date().toISOString()
        })
      });
    }

    // 7) Registrar evento (tracking)
    try {
      await fetch(SUPABASE_URL + '/rest/v1/eventos_usuario', {
        method:'POST',
        headers: { ...headersAuth, 'Prefer':'return=minimal' },
        body: JSON.stringify({
          usuario_id: ctx.solicitacao.usuario_id,
          tipo: 'termo_sigilo_assinado',
          entidade_tipo: 'negocio',
          entidade_id: ctx.solicitacao.negocio_id,
          ip: ctx.ip,
          user_agent: navigator.userAgent,
          meta: { token: ctx.token, solicitacao_id: ctx.solicitacao.id }
        })
      });
    } catch(e){ /* tracking não crítico */ }

    // 8) Notifica admin (Thiago) via WhatsApp — não bloqueia o fluxo se falhar
    try {
      const nomeComprador = $('f-nome').value.trim() || (ctx.usuario && ctx.usuario.nome) || 'Comprador';
      const wppComprador = (ctx.usuario && ctx.usuario.whatsapp)
        ? (function(w){
            const d = String(w).replace(/\D/g,'');
            if (d.length === 13) return '+' + d.slice(0,2) + ' (' + d.slice(2,4) + ') ' + d.slice(4,9) + '-' + d.slice(9);
            if (d.length === 11) return '(' + d.slice(0,2) + ') ' + d.slice(2,7) + '-' + d.slice(7);
            return w;
          })(ctx.usuario.whatsapp)
        : '—';
      const codigoNeg = (ctx.negocio && ctx.negocio.tag) || '—';
      const msgAdmin = `Termo assinado - 1Negócio

${nomeComprador} (${wppComprador}) assinou o Termo de Confidencialidade sobre o negócio ${codigoNeg}.

Revise a documentação no painel admin e libere o material quando tudo estiver OK.`;
      await fetch(SUPABASE_URL + '/functions/v1/zapi-relay', {
        method:'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + SUPABASE_ANON,
          'apikey': SUPABASE_ANON
        },
        body: JSON.stringify({ phone: '5548999279320', message: msgAdmin })
      });
    } catch(e){ /* notificação admin não crítica */ }

    // 9) FIX 2 — Notifica comprador (Mariah/Thiago/etc) via WhatsApp com link da área privada
    try {
      const wppDestino = (ctx.usuario && ctx.usuario.whatsapp) ? String(ctx.usuario.whatsapp).replace(/\D/g,'') : null;
      if (wppDestino && wppDestino.length >= 10){
        const codigoAnuncio = ctx.anuncioCodigo || ((ctx.negocio && ctx.negocio.codigo_diagnostico) || '');
        const linkPrivado = codigoAnuncio
          ? ('https://1negocio.com.br/negocios/' + codigoAnuncio + '?aba=privado')
          : 'https://1negocio.com.br/portal-usuario.html';
        const codigoNeg2 = (ctx.negocio && (ctx.negocio.codigo_diagnostico || ctx.negocio.tag)) || '—';
        const nomeUser = (ctx.usuario && ctx.usuario.nome) ? String(ctx.usuario.nome).split(' ')[0] : 'olá';
        const msgComprador = `Oi ${nomeUser}! Termo de Confidencialidade do negócio ${codigoNeg2} assinado com sucesso ✓

O material completo (área privada do anúncio) já está liberado pra você acessar:
${linkPrivado}

Qualquer dúvida, é só responder aqui.

— 1Negócio`;
        await fetch(SUPABASE_URL + '/functions/v1/zapi-relay', {
          method:'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer ' + SUPABASE_ANON,
            'apikey': SUPABASE_ANON
          },
          body: JSON.stringify({ phone: wppDestino, message: msgComprador })
        });
      }
    } catch(e){ /* notificação comprador não crítica */ }

    // 10) FIX 2 — Configura CTA do estado sucesso pra apontar pra área privada
    try {
      const cta = $('sucesso-cta-anuncio');
      const sucessoText = $('sucesso-text');
      if (ctx.anuncioCodigo){
        if (cta) cta.setAttribute('href', '/negocios/' + ctx.anuncioCodigo + '?aba=privado');
      } else {
        // sem anuncio público publicado — mantém fallback portal e ajusta texto
        if (cta) cta.setAttribute('href', '/portal-usuario.html');
        if (sucessoText) sucessoText.innerHTML = 'Seu termo foi registrado com sucesso. Nossa equipe está conferindo sua documentação e em até <strong>24 horas</strong> você recebe o material completo do negócio por WhatsApp.<br><br>Você também pode acompanhar na sua área de usuário.';
      }
    } catch(e){}

    // Sucesso!
    showState('state-sucesso');
  } catch(e){
    console.error('[Termo] Erro assinando:', e);
    showErr('passo3-erro','Erro ao registrar assinatura. Tente novamente ou fale conosco.');
    btn.disabled = false; loading.classList.remove('show');
  }
}

