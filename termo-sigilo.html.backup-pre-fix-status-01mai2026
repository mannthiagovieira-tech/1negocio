(async function init(){
  // 1) Pegar token
  const url = new URL(window.location.href);
  ctx.token = url.searchParams.get('token');
  if(!ctx.token){
    showState('state-invalid');
    return;
  }

  // 2) Detectar IP em paralelo
  fetch('https://api.ipify.org?format=json').then(r=>r.json()).then(d=>{
    ctx.ip = d.ip;
    if($('reg-ip')) $('reg-ip').textContent = d.ip || '—';
  }).catch(()=>{ ctx.ip = null; });

  // 3) Carregar sessão (se existir)
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if(raw){
      const s = JSON.parse(raw);
      if(s && s.token && s.user_id) ctx.session = s;
    }
  } catch(e){}

  // 4) Buscar a solicitação pelo token
  try {
    const r = await fetch(SUPABASE_URL + '/rest/v1/nda_solicitacoes?token=eq.' + ctx.token + '&select=*', {
      headers: { 'apikey': SUPABASE_ANON, 'Authorization':'Bearer '+SUPABASE_ANON }
    });
    const data = await r.json();
    if(!data || data.length === 0){
      showState('state-invalid');
      return;
    }
    ctx.solicitacao = data[0];

    // Já assinou ou já foi processado?
    if(ctx.solicitacao.status === 'em_analise' || ctx.solicitacao.status === 'aprovado' || ctx.solicitacao.status === 'reprovado'){
      showState('state-already');
      return;
    }

    // Expirou?
    if(ctx.solicitacao.expira_em){
      const exp = new Date(ctx.solicitacao.expira_em);
      if(exp < new Date()){
        showState('state-expired');
        return;
      }
    }

    // 5) Buscar negócio
    if(ctx.solicitacao.negocio_id){
      const rn = await fetch(SUPABASE_URL + '/rest/v1/negocios?id=eq.' + ctx.solicitacao.negocio_id + '&select=id,tag,nome,categoria,setor,cidade,estado,preco_pedido,faturamento_anual,codigo_diagnostico', {
        headers: { 'apikey': SUPABASE_ANON, 'Authorization':'Bearer '+SUPABASE_ANON }
      });
      const negs = await rn.json();
      if(negs && negs[0]) ctx.negocio = negs[0];

      // FIX 2 — busca anúncio público publicado pra montar link pós-NDA
      try {
        const ra = await fetch(SUPABASE_URL + '/rest/v1/anuncios_v2'
          + '?negocio_id=eq.' + ctx.solicitacao.negocio_id
          + '&status=eq.publicado&select=id,codigo&limit=1',
          { headers: { 'apikey': SUPABASE_ANON, 'Authorization':'Bearer '+SUPABASE_ANON } });
        const ans = await ra.json();
        if(ans && ans[0] && ans[0].codigo) ctx.anuncioCodigo = ans[0].codigo;
      } catch(e){ /* anúncio público não crítico aqui */ }
    }

    // 6) Buscar dados do usuário (se já tiver dados pessoais salvos)
    if(ctx.solicitacao.usuario_id){
      const ru = await fetch(SUPABASE_URL + '/rest/v1/usuarios?id=eq.' + ctx.solicitacao.usuario_id + '&select=id,nome,whatsapp,dados_pessoais,dados_pessoais_autorizado', {
        headers: { 'apikey': SUPABASE_ANON, 'Authorization':'Bearer '+SUPABASE_ANON }
      });
      const us = await ru.json();
      if(us && us[0]) ctx.usuario = us[0];
    }

    // Tudo carregado — mostra o formulário
    preencherFormulario();
    showState('main-content');
  } catch(e){
    console.error('[Termo] Erro carregando:', e);
    showState('state-invalid');
  }
})();

// Garante que a sessão está válida — faz refresh se necessário
// Retorna true se tem sessão válida, false se não conseguiu renovar
async function garantirSessaoValida(){
  let saved = ctx.session;
  if(!saved){
    try { const raw = localStorage.getItem(STORAGE_KEY); if(raw) saved = JSON.parse(raw); } catch(e){}
  }
  if(!saved || !saved.token){
    return false;
  }

  // Testa se o token atual funciona
  try {
    const res = await fetch(SUPABASE_URL + '/auth/v1/user', {
      headers: { 'apikey': SUPABASE_ANON, 'Authorization': 'Bearer ' + saved.token }
    });
    if(res.ok){
      ctx.session = saved;
      return true;
    }
    if(res.status !== 401 && res.status !== 403) return false;
  } catch(e){ return false; }

  // Token expirado — tenta refresh
  if(!saved.refresh) return false;
  try {
    const res = await fetch(SUPABASE_URL + '/auth/v1/token?grant_type=refresh_token', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_ANON },
      body: JSON.stringify({ refresh_token: saved.refresh })
    });
    if(!res.ok){
      try { localStorage.removeItem(STORAGE_KEY); } catch(e){}
      ctx.session = null;
      return false;
    }
    const data = await res.json();
    if(!data.access_token) return false;
    saved.token = data.access_token;
    if(data.refresh_token) saved.refresh = data.refresh_token;
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(saved)); } catch(e){}
    ctx.session = saved;
    return true;
  } catch(e){ return false; }
}

function preencherFormulario(){
  // Resumo do negócio
  if(ctx.negocio){
    // FIX 7 — código_diagnostico é o campo real (tag pode estar vazio em legacy)
    const codigoExibido = ctx.negocio.codigo_diagnostico || ctx.negocio.tag || '—';
    $('r-codigo').textContent = codigoExibido;
    $('r-setor').textContent = ctx.negocio.categoria || ctx.negocio.setor || '—';
    $('r-local').textContent = [ctx.negocio.cidade, ctx.negocio.estado].filter(Boolean).join(', ') || '—';
    $('r-valor').textContent = fmtMoney(ctx.negocio.preco_pedido);
    $('aceite-codigo').textContent = codigoExibido;
  }

  // Dados do usuário
  if(ctx.usuario){
    if(ctx.usuario.nome) $('f-nome').value = ctx.usuario.nome;
    const dp = ctx.usuario.dados_pessoais;
    if(dp){
      if(dp.cpf){ $('f-cpf').value = dp.cpf; marcarSalvo('cpf'); }
      if(dp.rg){ $('f-rg').value = dp.rg; marcarSalvo('rg'); }
      if(dp.profissao){ $('f-profissao').value = dp.profissao; marcarSalvo('profissao'); }
      if(dp.estado_civil){ $('f-estado-civil').value = dp.estado_civil; }
      if(dp.endereco){
        const e = dp.endereco;
        if(e.cep) $('f-cep').value = e.cep;
        if(e.logradouro){ $('f-logradouro').value = e.logradouro; marcarSalvo('endereco'); }
        if(e.bairro) $('f-bairro').value = e.bairro;
        if(e.cidade) $('f-cidade').value = e.cidade;
        if(e.estado) $('f-estado').value = e.estado;
      }
      if(dp.doc_foto_url){
        ctx.docUrl = dp.doc_foto_url;
        // Se já tem doc, esconde o upload obrigatório
        $('bloco-upload').style.display = 'none';
      }
      if(ctx.usuario.nome) marcarSalvo('nome');
    }
  }

  // Data/hora + device
  $('reg-datetime').textContent = fmtDateTime();
  $('reg-device').textContent = detectDevice();
}

function marcarSalvo(field){
  const el = document.querySelector('.saved[data-field="'+field+'"]');
  if(el) el.style.display = 'inline';
}

