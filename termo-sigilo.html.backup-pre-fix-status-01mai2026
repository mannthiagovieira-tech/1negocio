<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>1Negócio · Termo de Confidencialidade</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Mono:wght@400;500&family=Cabinet+Grotesk:wght@400;500;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#eef5f0;--bg1:#fff;--bg2:#f4f9f5;--bg3:#e8f2eb;
  --em:#1a7a4a;--em-d:rgba(26,122,74,.08);--em-l:rgba(26,122,74,.22);
  --ink:#0d2b1e;--ink2:#2d5a3d;--ink3:#4a7c5c;--ink4:#8aaa96;
  --line:rgba(13,43,30,.07);--line2:rgba(13,43,30,.13);
  --rd:#dc2626;--amber:#f59e0b
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{background:var(--bg);color:var(--ink);font-family:'Cabinet Grotesk',sans-serif;min-height:100vh}
.nav{display:flex;align-items:center;justify-content:space-between;padding:14px 24px;border-bottom:1px solid var(--line);background:rgba(238,245,240,.95);position:sticky;top:0;z-index:10}
.nav-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:18px;letter-spacing:-.02em;color:var(--ink);text-decoration:none}
.nav-logo em{color:var(--em);font-style:normal}
.nav-meta{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:var(--ink4)}

.wrap{max-width:680px;margin:0 auto;padding:40px 24px 80px}

/* Barra de passos */
.step-bar{display:flex;align-items:center;gap:0;margin-bottom:40px}
.step{display:flex;align-items:center;gap:8px;font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink4)}
.step.active{color:var(--em)}
.step.done{color:var(--em);opacity:.5}
.step-dot{width:24px;height:24px;border-radius:50%;border:1.5px solid currentColor;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0}
.step.active .step-dot{background:var(--em);border-color:var(--em);color:#fff}
.step.done .step-dot{background:var(--em);border-color:var(--em);color:#fff}
.step-line{flex:1;height:1px;background:var(--line2);margin:0 8px}

.sec-title{font-family:'Syne',sans-serif;font-weight:800;font-size:26px;letter-spacing:-.02em;color:var(--ink);margin-bottom:6px}
.sec-sub{font-size:14px;color:var(--ink3);line-height:1.6;margin-bottom:28px}

.field{margin-bottom:18px}
.field-label{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.15em;text-transform:uppercase;color:var(--ink4);margin-bottom:6px;display:flex;align-items:center;gap:8px}
.field-label .opt{font-size:8px;color:var(--ink4);font-weight:400;letter-spacing:.05em;text-transform:none}
.field-label .saved{display:none;color:var(--em);font-size:8px;font-weight:600;letter-spacing:.05em;text-transform:none}
.field input,.field select,.field textarea{width:100%;padding:12px 16px;background:var(--bg1);border:1px solid var(--line2);border-radius:6px;font-family:'Cabinet Grotesk',sans-serif;font-size:15px;color:var(--ink);outline:none;transition:border-color .15s}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--em)}
.field input[readonly]{background:var(--bg2);color:var(--ink3);cursor:default}
.field textarea{min-height:64px;resize:vertical;font-family:'Cabinet Grotesk',sans-serif;line-height:1.5}
.field-err{font-size:12px;color:var(--rd);margin-top:5px;display:none}
.field-err.show{display:block}

.field-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.field-row-3{display:grid;grid-template-columns:2fr 1fr 1fr;gap:14px}
@media(max-width:480px){.field-row,.field-row-3{grid-template-columns:1fr}}

/* Resumo do negócio */
.resumo{background:var(--bg1);border:1px solid var(--line2);border-radius:8px;padding:20px;margin-bottom:28px}
.resumo-title{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.15em;text-transform:uppercase;color:var(--em);margin-bottom:14px}
.resumo-item{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--line);font-size:13px}
.resumo-item:last-child{border:none}
.resumo-item-lbl{color:var(--ink4)}
.resumo-item-val{color:var(--ink);font-weight:600}

/* Upload de documento */
.upload-area{
  display:flex;align-items:center;justify-content:center;flex-direction:column;gap:8px;
  padding:28px 20px;
  background:var(--bg1);
  border:1.5px dashed var(--line2);
  border-radius:8px;
  cursor:pointer;
  transition:all .15s;
  text-align:center;
}
.upload-area:hover{border-color:var(--em);background:var(--em-d)}
.upload-area.has-file{border-color:var(--em);border-style:solid;background:var(--em-d)}
.upload-icon{width:36px;height:36px;color:var(--em);margin-bottom:4px}
.upload-title{font-family:'Cabinet Grotesk',sans-serif;font-weight:600;font-size:14px;color:var(--ink)}
.upload-hint{font-size:12px;color:var(--ink3)}
.upload-filename{font-family:'DM Mono',monospace;font-size:12px;color:var(--em);font-weight:500;word-break:break-all;display:none}
.upload-area.has-file .upload-icon{display:none}
.upload-area.has-file .upload-title{color:var(--em)}
.upload-area.has-file .upload-filename{display:block}
.upload-area input[type=file]{display:none}

.upload-progress{display:none;margin-top:10px;height:4px;background:var(--line2);border-radius:2px;overflow:hidden}
.upload-progress-bar{height:100%;background:var(--em);width:0%;transition:width .3s}

/* Termo (caixa com scroll) */
.termo-box{background:var(--bg1);border:1px solid var(--line2);border-radius:8px;padding:24px;margin-bottom:20px;max-height:380px;overflow-y:auto}
.termo-box h3{font-family:'Syne',sans-serif;font-weight:700;font-size:16px;color:var(--ink);margin-bottom:16px;letter-spacing:-.01em}
.termo-clausula{margin-bottom:18px}
.termo-clausula:last-child{margin-bottom:0}
.termo-clausula-title{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:var(--em);margin-bottom:6px}
.termo-clausula p{font-size:13px;color:var(--ink3);line-height:1.7}
.termo-clausula p + p{margin-top:8px}

/* Aviso LGPD */
.lgpd-row{
  display:flex;align-items:flex-start;gap:12px;
  padding:14px 16px;
  background:var(--em-d);
  border:1px solid var(--em-l);
  border-radius:8px;
  margin-bottom:20px;
  cursor:pointer
}
.lgpd-row input{flex-shrink:0;margin-top:3px;accent-color:var(--em);width:18px;height:18px}
.lgpd-txt{font-size:13px;color:var(--ink2);line-height:1.55}
.lgpd-txt strong{color:var(--em)}

/* Bloco de IP/registro (explícito) */
.registro-box{
  background:var(--bg1);
  border:1px solid var(--line2);
  border-radius:8px;
  padding:16px 18px;
  margin-bottom:20px;
}
.registro-title{
  font-family:'DM Mono',monospace;
  font-size:9px;letter-spacing:.15em;text-transform:uppercase;
  color:var(--ink4);margin-bottom:10px;
  display:flex;align-items:center;gap:6px;
}
.registro-title svg{width:12px;height:12px;color:var(--em)}
.registro-item{
  display:flex;justify-content:space-between;
  padding:5px 0;
  font-size:12px;
}
.registro-item-lbl{color:var(--ink3)}
.registro-item-val{color:var(--ink);font-family:'DM Mono',monospace;font-weight:500}

/* Aceite final */
.aceite-row{display:flex;align-items:flex-start;gap:12px;padding:16px;background:var(--em-d);border:1px solid var(--em-l);border-radius:8px;margin-bottom:20px;cursor:pointer}
.aceite-row input{flex-shrink:0;margin-top:3px;accent-color:var(--em);width:18px;height:18px}
.aceite-txt{font-size:13px;color:var(--ink2);line-height:1.6}
.aceite-txt strong{color:var(--em)}

/* Botões */
.btn-p{display:block;width:100%;padding:16px;background:var(--em);color:#fff;font-family:'Cabinet Grotesk',sans-serif;font-weight:700;font-size:15px;border-radius:8px;border:none;cursor:pointer;transition:opacity .15s;text-align:center}
.btn-p:hover{opacity:.85}
.btn-p:disabled{opacity:.4;cursor:not-allowed}
.btn-s{display:block;width:100%;padding:14px;background:transparent;color:var(--ink3);font-family:'Cabinet Grotesk',sans-serif;font-weight:600;font-size:14px;border:1px solid var(--line2);border-radius:8px;cursor:pointer;margin-top:10px;text-align:center}

/* Loading */
.loading-row{display:none;text-align:center;margin-top:12px;font-size:12px;color:var(--ink3);font-family:'DM Mono',monospace}
.loading-row.show{display:block}

/* Estados de tela */
.state-loading,.state-invalid,.state-expired,.state-already,.state-sucesso{display:none;padding:48px 24px;text-align:center}
.state-loading.show,.state-invalid.show,.state-expired.show,.state-already.show,.state-sucesso.show{display:block}

.state-icon{width:64px;height:64px;border-radius:50%;background:var(--em-d);border:2px solid var(--em-l);display:flex;align-items:center;justify-content:center;font-size:28px;margin:0 auto 20px;color:var(--em)}
.state-icon.warn{background:rgba(245,158,11,.08);border-color:rgba(245,158,11,.3);color:#d97706}
.state-icon.err{background:rgba(220,38,38,.08);border-color:rgba(220,38,38,.3);color:var(--rd)}
.state-title{font-family:'Syne',sans-serif;font-weight:800;font-size:26px;color:var(--ink);margin-bottom:10px;letter-spacing:-.02em}
.state-text{font-size:14px;color:var(--ink3);line-height:1.7;max-width:440px;margin:0 auto 28px}

/* Inline error */
.inline-error{
  padding:12px 14px;
  background:rgba(220,38,38,.06);
  border-left:3px solid var(--rd);
  border-radius:0 6px 6px 0;
  color:var(--rd);
  font-size:13px;
  line-height:1.5;
  margin-bottom:16px;
  display:none;
}
.inline-error.show{display:block}
</style>
</head>
<body>

<nav class="nav">
  <a href="/" class="nav-logo"><em>1</em>NEGÓCIO</a>
  <span class="nav-meta">Termo de Confidencialidade</span>
</nav>

<div class="wrap">

  <!-- Estado: carregando -->
  <div class="state-loading show" id="state-loading">
    <div style="font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink3);padding-top:40px">carregando...</div>
  </div>

  <!-- Estado: token inválido -->
  <div class="state-invalid" id="state-invalid">
    <div class="state-icon err">✕</div>
    <div class="state-title">Link inválido</div>
    <div class="state-text">Este link não foi encontrado ou já foi utilizado. Se você recebeu este link por WhatsApp, verifique se copiou o endereço completo. Em caso de dúvida, fale com nossa equipe.</div>
    <a href="/" class="btn-p" style="text-decoration:none;display:inline-block;width:auto;padding:14px 32px">Voltar ao início</a>
  </div>

  <!-- Estado: token expirado -->
  <div class="state-expired" id="state-expired">
    <div class="state-icon warn">⏱</div>
    <div class="state-title">Link expirado</div>
    <div class="state-text">Este link expirou. Por segurança, cada link de assinatura é válido por 72 horas. Se ainda tem interesse neste negócio, fale com nossa equipe para gerarmos um novo link.</div>
    <a href="/portal-usuario.html" class="btn-p" style="text-decoration:none;display:inline-block;width:auto;padding:14px 32px">Acessar minha área</a>
  </div>

  <!-- Estado: já assinado -->
  <div class="state-already" id="state-already">
    <div class="state-icon">✓</div>
    <div class="state-title">Termo já assinado</div>
    <div class="state-text">Você já assinou o Termo de Confidencialidade para este negócio. Nossa equipe está analisando sua documentação e em breve libera o material completo.</div>
    <a href="/portal-usuario.html" class="btn-p" style="text-decoration:none;display:inline-block;width:auto;padding:14px 32px">Acessar minha área</a>
  </div>

  <!-- CONTEÚDO PRINCIPAL (só aparece com token válido) -->
  <div id="main-content" style="display:none">

    <!-- Barra de passos -->
    <div class="step-bar">
      <div class="step active" id="step1"><div class="step-dot">1</div><span>Seus dados</span></div>
      <div class="step-line"></div>
      <div class="step" id="step2"><div class="step-dot">2</div><span>Termo</span></div>
      <div class="step-line"></div>
      <div class="step" id="step3"><div class="step-dot">3</div><span>Assinar</span></div>
    </div>

    <!-- PASSO 1 — Seus dados -->
    <div id="passo1">
      <div class="sec-title">Seus dados</div>
      <div class="sec-sub">Confirme suas informações. Na próxima vez que você assinar um termo na 1Negócio, estes dados serão preenchidos automaticamente.</div>

      <!-- Resumo do negócio -->
      <div class="resumo">
        <div class="resumo-title">Sobre o negócio</div>
        <div class="resumo-item"><span class="resumo-item-lbl">Código</span><span class="resumo-item-val" id="r-codigo">—</span></div>
        <div class="resumo-item"><span class="resumo-item-lbl">Setor</span><span class="resumo-item-val" id="r-setor">—</span></div>
        <div class="resumo-item"><span class="resumo-item-lbl">Localização</span><span class="resumo-item-val" id="r-local">—</span></div>
        <div class="resumo-item"><span class="resumo-item-lbl">Valor de venda</span><span class="resumo-item-val" id="r-valor">—</span></div>
      </div>

      <div class="inline-error" id="passo1-erro"></div>

      <!-- Dados pessoais -->
      <div class="field-row">
        <div class="field">
          <div class="field-label"><span>Nome completo *</span> <span class="saved" data-field="nome">✓ salvo</span></div>
          <input type="text" id="f-nome" placeholder="Como consta no RG ou CNH">
        </div>
        <div class="field">
          <div class="field-label"><span>CPF *</span> <span class="saved" data-field="cpf">✓ salvo</span></div>
          <input type="text" id="f-cpf" placeholder="000.000.000-00" maxlength="14" oninput="mascaraCPF(this)">
        </div>
      </div>

      <div class="field-row">
        <div class="field">
          <div class="field-label"><span>RG *</span> <span class="saved" data-field="rg">✓ salvo</span></div>
          <input type="text" id="f-rg" placeholder="00.000.000-0" maxlength="15">
        </div>
        <div class="field">
          <div class="field-label"><span>Profissão *</span> <span class="saved" data-field="profissao">✓ salvo</span></div>
          <input type="text" id="f-profissao" placeholder="Ex: Empresário, Advogado">
        </div>
      </div>

      <div class="field-row">
        <div class="field">
          <div class="field-label">Estado civil *</div>
          <select id="f-estado-civil">
            <option value="">Selecione</option>
            <option value="solteiro">Solteiro(a)</option>
            <option value="casado">Casado(a)</option>
            <option value="divorciado">Divorciado(a)</option>
            <option value="viuvo">Viúvo(a)</option>
            <option value="uniao_estavel">União estável</option>
          </select>
        </div>
        <div class="field">
          <div class="field-label">CEP *</div>
          <input type="text" id="f-cep" placeholder="00000-000" maxlength="9" oninput="mascaraCEP(this); buscarCEP(this)">
        </div>
      </div>

      <div class="field">
        <div class="field-label"><span>Endereço *</span> <span class="saved" data-field="endereco">✓ salvo</span></div>
        <input type="text" id="f-logradouro" placeholder="Rua, avenida, número">
      </div>

      <div class="field-row-3">
        <div class="field">
          <div class="field-label">Bairro *</div>
          <input type="text" id="f-bairro" placeholder="Bairro">
        </div>
        <div class="field">
          <div class="field-label">Cidade *</div>
          <input type="text" id="f-cidade" placeholder="Cidade">
        </div>
        <div class="field">
          <div class="field-label">UF *</div>
          <input type="text" id="f-estado" placeholder="SC" maxlength="2" style="text-transform:uppercase">
        </div>
      </div>

      <!-- Upload doc (só 1ª vez) -->
      <div id="bloco-upload">
        <div class="field">
          <div class="field-label">Documento de identidade *</div>
          <label class="upload-area" id="upload-area">
            <input type="file" id="f-doc" accept="image/jpeg,image/png,image/webp,application/pdf" onchange="onFileSelected(this)">
            <svg class="upload-icon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/>
            </svg>
            <div class="upload-title">Envie foto do RG ou CNH (frente)</div>
            <div class="upload-hint">JPG, PNG ou PDF até 5MB</div>
            <div class="upload-filename" id="upload-filename"></div>
          </label>
          <div class="upload-progress" id="upload-progress">
            <div class="upload-progress-bar" id="upload-progress-bar"></div>
          </div>
          <div class="field-err" id="upload-err"></div>
        </div>
      </div>

      <!-- Checkbox LGPD -->
      <label class="lgpd-row" id="lgpd-row">
        <input type="checkbox" id="cb-lgpd" checked>
        <div class="lgpd-txt">
          Autorizo a <strong>1Negócio</strong> a salvar meus dados pessoais (CPF, RG, endereço, profissão) para que os próximos termos que eu assinar sejam preenchidos automaticamente. <em>Posso revogar esta autorização a qualquer momento na minha área de usuário.</em>
        </div>
      </label>

      <button class="btn-p" onclick="irPasso2()">Continuar →</button>
    </div>

    <!-- PASSO 2 — Termo -->
    <div id="passo2" style="display:none">
      <div class="sec-title">Termo de Confidencialidade</div>
      <div class="sec-sub">Leia com atenção antes de prosseguir para a assinatura.</div>

      <div class="termo-box" id="termo-box"><!-- preenchido dinamicamente por JS --></div>

      <button class="btn-p" onclick="irPasso3()">Continuar para assinatura →</button>
      <button class="btn-s" onclick="voltarPasso1()">← Voltar</button>
    </div>

    <!-- PASSO 3 — Assinar -->
    <div id="passo3" style="display:none">
      <div class="sec-title">Assinatura</div>
      <div class="sec-sub">Ao assinar, você concorda integralmente com os termos apresentados.</div>

      <!-- Bloco de registro (IP explícito) -->
      <div class="registro-box">
        <div class="registro-title">
          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m0 0v3m0-3h3m-3 0H9m12-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Registros da assinatura
        </div>
        <div class="registro-item"><span class="registro-item-lbl">Seu IP</span><span class="registro-item-val" id="reg-ip">detectando...</span></div>
        <div class="registro-item"><span class="registro-item-lbl">Data e hora</span><span class="registro-item-val" id="reg-datetime">—</span></div>
        <div class="registro-item"><span class="registro-item-lbl">Dispositivo</span><span class="registro-item-val" id="reg-device">—</span></div>
      </div>

      <!-- Aceite final -->
      <label class="aceite-row" onclick="toggleAceite()">
        <input type="checkbox" id="cb-aceite">
        <div class="aceite-txt">
          Li e concordo com o <strong>Termo de Confidencialidade</strong> da 1Negócio sobre o negócio <strong id="aceite-codigo">—</strong>. Minha assinatura digital tem validade jurídica equivalente à assinatura manuscrita, nos termos da Lei nº 14.063/2020 e da MP nº 2.200-2/2001.
        </div>
      </label>

      <div class="inline-error" id="passo3-erro"></div>

      <button class="btn-p" id="btn-assinar" onclick="assinar()" disabled>Assinar digitalmente →</button>
      <button class="btn-s" onclick="voltarPasso2()">← Voltar ao termo</button>

      <div class="loading-row" id="loading-assinar">Registrando assinatura...</div>
    </div>

  </div>

  <!-- Estado: sucesso -->
  <div class="state-sucesso" id="state-sucesso">
    <div class="state-icon">✓</div>
    <div class="state-title">Termo assinado!</div>
    <div class="state-text" id="sucesso-text">Seu termo foi registrado com sucesso. O material completo do negócio já está liberado na sua área privada.<br><br>Você também recebeu o link por WhatsApp.</div>
    <a id="sucesso-cta-anuncio" href="/portal-usuario.html" class="btn-p" style="text-decoration:none;display:inline-block;width:auto;padding:14px 32px">Ver anúncio (área privada) →</a>
    <a href="/portal-usuario.html" class="btn-s" style="text-decoration:none;display:inline-block;width:auto;padding:12px 28px;margin-top:10px">Acessar minha área</a>
  </div>

</div>

<script>
// ═══════════════════════════════════════════════
// CONFIG + ESTADO
