// VALIDAÇÃO DOS DADOS (Passo 1)
// ═══════════════════════════════════════════════
function validarPasso1(){
  hideErr('passo1-erro');
  const campos = [
    ['f-nome','Nome completo'],
    ['f-cpf','CPF'],
    ['f-rg','RG'],
    ['f-profissao','Profissão'],
    ['f-estado-civil','Estado civil'],
    ['f-cep','CEP'],
    ['f-logradouro','Endereço'],
    ['f-bairro','Bairro'],
    ['f-cidade','Cidade'],
    ['f-estado','UF']
  ];
  const faltando = [];
  campos.forEach(([id,label])=>{
    const v = $(id).value.trim();
    if(!v) faltando.push(label);
  });
  if(faltando.length){
    showErr('passo1-erro','Preencha os campos: ' + faltando.join(', ') + '.');
    return false;
  }
  // CPF mínimo
  const cpfDigits = $('f-cpf').value.replace(/\D/g,'');
  if(cpfDigits.length !== 11){
    showErr('passo1-erro','CPF inválido. Preencha com 11 dígitos.');
    return false;
  }
  // UF
  const uf = $('f-estado').value.trim().toUpperCase();
  if(uf.length !== 2){
    showErr('passo1-erro','UF deve ter 2 letras (ex: SC, SP, RJ).');
    return false;
  }
  // Doc (só obrigatório se bloco-upload visível — ou seja, 1ª vez)
  const blocoUpload = $('bloco-upload');
  if(blocoUpload.style.display !== 'none'){
    if(!ctx.docFile && !ctx.docUrl){
      showErr('passo1-erro','Envie uma foto do seu documento de identidade.');
      return false;
    }
  }
  return true;
}

