<!DOCTYPE html>
<html lang="pt-BR">
<head>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-7DGLH0W7KE"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-7DGLH0W7KE');
</script>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>1Negócio · Fale conosco</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=Instrument+Serif:ital@0;1&family=Syne:wght@700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0c0c0a;--bg2:#111110;--bg3:#161614;
  --ink:rgba(255,255,255,.88);--ink2:rgba(255,255,255,.46);
  --ink3:rgba(255,255,255,.22);--ink4:rgba(255,255,255,.08);
  --sep:rgba(255,255,255,.07);
  --green:#10b981;--amber:#f59e0b;--blue:#60a5fa;--red:#f87171;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--ink);font-family:'DM Mono',monospace;overflow-x:hidden}
a{color:inherit;text-decoration:none}

/* ── TICKER ── */
#ticker{
  position:fixed;top:0;left:0;right:0;z-index:600;
  height:26px;background:#060606;
  border-bottom:1px solid rgba(16,185,129,.15);
  overflow:hidden;display:flex;align-items:center;
}
#ticker::before,#ticker::after{content:'';position:absolute;top:0;bottom:0;width:50px;z-index:10;pointer-events:none}
#ticker::before{left:0;background:linear-gradient(90deg,#060606,transparent)}
#ticker::after{right:0;background:linear-gradient(270deg,#060606,transparent)}
.tk-label{
  position:absolute;left:0;top:0;bottom:0;z-index:20;
  display:flex;align-items:center;padding:0 12px;
  background:#060606;border-right:1px solid rgba(16,185,129,.15);
  font-family:'Syne',sans-serif;font-size:7px;font-weight:700;
  letter-spacing:.2em;text-transform:uppercase;color:var(--green);white-space:nowrap;
}
.tk-track{display:flex;width:max-content;animation:tkr 80s linear infinite;padding-left:100px}
#ticker:hover .tk-track{animation-play-state:paused}
@keyframes tkr{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.tk-item{display:flex;align-items:center;gap:8px;padding:0 20px;height:26px;border-right:1px solid rgba(255,255,255,.04);flex-shrink:0;font-size:9px}

/* ── NAV ── */
nav{
  position:fixed;top:26px;left:0;right:0;z-index:500;height:46px;
  display:flex;align-items:center;
  background:rgba(12,12,10,.98);backdrop-filter:blur(20px);
  border-bottom:1px solid var(--sep);
}
.logo{
  font-family:'Syne',sans-serif;font-weight:800;font-size:14px;
  letter-spacing:-.02em;color:#fff;
  display:flex;align-items:center;gap:8px;padding:0 20px;
  border-right:1px solid var(--sep);height:100%;flex-shrink:0;
}
.logo em{font-style:normal;color:var(--green)}
.pulse{width:5px;height:5px;border-radius:50%;background:var(--green);animation:pulse 2.4s ease infinite;flex-shrink:0}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.3;transform:scale(.6)}}
.nav-links{display:flex;align-items:center;flex:1;overflow:hidden}
.nl{
  font-size:10px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;
  color:var(--ink2);background:none;border:none;cursor:pointer;
  padding:0 18px;height:46px;border-right:1px solid var(--sep);
  transition:color .15s;white-space:nowrap;flex-shrink:0;
  text-decoration:none;display:flex;align-items:center;
}
.nl:hover{color:var(--ink)}
.nl.on{color:var(--green)}
.nl.amber{color:var(--amber)}
.nav-entrar{
  background:transparent;border-right:1px solid var(--sep);color:var(--ink3);
  font-family:'DM Mono',monospace;font-size:10px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;
  padding:0 16px;height:46px;cursor:pointer;transition:all .13s;
  display:flex;align-items:center;white-space:nowrap;
  border-left:none;border-top:none;border-bottom:none;
}
.nav-entrar:hover{color:var(--ink)}
.nav-cta{
  font-family:'Syne',sans-serif;font-weight:800;
  background:var(--green);color:#fff;border:none;
  padding:0 22px;height:46px;cursor:pointer;
  transition:all .2s;flex-shrink:0;white-space:nowrap;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;
  min-width:200px;
}
.nav-cta:hover{background:#0ea572;box-shadow:0 0 18px rgba(16,185,129,.3)}
.nav-cta-main{font-size:11px;letter-spacing:.05em;text-transform:uppercase;line-height:1;font-weight:800}
.nav-cta-sub{font-size:6.5px;letter-spacing:.12em;text-transform:uppercase;opacity:.75;line-height:1;font-weight:400}

/* ── LAYOUT ── */
.page{padding-top:144px}
.container{max-width:1060px;margin:0 auto;padding:0 40px}
.container-sm{max-width:720px;margin:0 auto;padding:0 40px}
.section{padding:64px 0;border-bottom:1px solid var(--sep)}

/* ── ANIMAÇÕES ── */
@keyframes fu{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.fu{animation:fu .5s ease both}
.fu1{animation-delay:.1s}.fu2{animation-delay:.2s}

/* ── SEC LABEL ── */
.sec-label{
  font-size:8px;letter-spacing:.24em;text-transform:uppercase;color:var(--ink3);
  margin-bottom:24px;display:flex;align-items:center;gap:10px;
}
.sec-label::before{content:'';width:14px;height:1px;background:var(--green);flex-shrink:0}
.sec-label::after{content:'';flex:1;height:.5px;background:var(--sep)}

/* ── HERO ── */
.hero{padding:72px 0 56px;border-bottom:1px solid var(--sep)}
.hero-eyebrow{
  font-size:8px;letter-spacing:.24em;text-transform:uppercase;color:var(--green);
  display:flex;align-items:center;gap:8px;margin-bottom:20px;
}
.hero-eyebrow::before{content:'';width:16px;height:1px;background:var(--green)}
.hero h1{
  font-family:'Syne',sans-serif;font-size:clamp(38px,5vw,64px);
  font-weight:800;line-height:1.05;letter-spacing:-.02em;
  color:#fff;margin-bottom:16px;
}
.hero h1 em{color:var(--green);font-style:italic;font-family:'Instrument Serif',serif}
.hero-sub{font-size:13px;color:var(--ink2);line-height:1.8;max-width:440px;font-weight:300}

/* ── CARDS DE CONTATO ── */
.contato-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.contato-card{
  padding:36px;position:relative;overflow:hidden;
}
.contato-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
}
.contato-card.vend{
  border:.5px solid rgba(16,185,129,.3);
  background:rgba(16,185,129,.04);
}
.contato-card.vend::before{background:linear-gradient(90deg,var(--green),transparent)}
.contato-card.comp{
  border:.5px solid rgba(96,165,250,.25);
  background:rgba(96,165,250,.03);
}
.contato-card.comp::before{background:linear-gradient(90deg,var(--blue),transparent)}
.contato-badge{
  font-family:'Syne',sans-serif;font-size:8px;font-weight:700;
  letter-spacing:.2em;text-transform:uppercase;margin-bottom:14px;
}
.contato-title{
  font-family:'Syne',sans-serif;font-size:22px;font-weight:800;
  letter-spacing:-.01em;margin-bottom:10px;color:#fff;line-height:1.15;
}
.contato-desc{font-size:11px;color:var(--ink2);line-height:1.7;margin-bottom:24px;font-weight:300}
.contato-links{display:flex;flex-direction:column;gap:8px}

.c-link{
  display:flex;align-items:center;gap:12px;
  padding:12px 16px;text-decoration:none;transition:all .15s;
}
.c-link-ico{
  font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
  flex-shrink:0;width:18px;text-align:center;
}
.c-link-label{
  font-family:'Syne',sans-serif;font-size:10px;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;margin-bottom:2px;
}
.c-link-sub{font-size:10px;color:var(--ink3);font-weight:300}

.c-link.wpp-g{background:rgba(16,185,129,.08);border:.5px solid rgba(16,185,129,.2)}
.c-link.wpp-g:hover{background:rgba(16,185,129,.14);border-color:rgba(16,185,129,.35)}
.c-link.wpp-b{background:rgba(96,165,250,.08);border:.5px solid rgba(96,165,250,.2)}
.c-link.wpp-b:hover{background:rgba(96,165,250,.14);border-color:rgba(96,165,250,.35)}
.c-link.email{background:rgba(255,255,255,.03);border:.5px solid var(--sep)}
.c-link.email:hover{border-color:rgba(255,255,255,.2)}

.contato-cta{
  display:block;width:100%;text-align:center;padding:12px;
  font-family:'Syne',sans-serif;font-size:10px;font-weight:800;
  letter-spacing:.12em;text-transform:uppercase;
  text-decoration:none;transition:opacity .15s;border:none;cursor:pointer;
  margin-top:12px;
}
.contato-cta:hover{opacity:.88}

/* ── FAQ ── */
.faq-item{border-bottom:.5px solid var(--sep)}
.faq-q{
  font-family:'Syne',sans-serif;font-size:11px;font-weight:700;
  letter-spacing:.08em;text-transform:uppercase;
  padding:20px 0;cursor:pointer;
  display:flex;justify-content:space-between;align-items:center;
  color:rgba(255,255,255,.5);transition:color .15s;gap:16px;
}
.faq-q:hover{color:var(--ink)}
.faq-q.open{color:var(--green)}
.faq-ico{font-size:14px;font-weight:300;flex-shrink:0;transition:transform .2s}
.faq-q.open .faq-ico{transform:rotate(45deg)}
.faq-a{font-size:12px;color:var(--ink2);line-height:1.8;padding-bottom:20px;display:none;font-weight:300}

/* ── FOOTER ── */
footer{
  padding:24px 40px;border-top:.5px solid var(--sep);
  display:flex;align-items:center;justify-content:space-between;
  font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink3);
  flex-wrap:wrap;gap:12px;
}
.f-logo{font-family:'Syne',sans-serif;font-size:13px;font-weight:800;color:#fff;display:flex;align-items:center;gap:5px}
.f-logo em{color:var(--green);font-style:normal}
.f-links{display:flex;gap:20px;flex-wrap:wrap}
.f-link{color:var(--ink3);transition:color .15s}
.f-link:hover{color:var(--ink)}
.f-link.on{color:var(--green)}

/* ── RESPONSIVO ── */
@media(max-width:900px){.nl:nth-child(n+4){display:none}}
@media(max-width:768px){
  .nl{display:none}
  .nav-cta-sub{display:none}
  .nav-cta{min-width:auto;padding:0 16px}
  .contato-grid{grid-template-columns:1fr}
}
@media(max-width:600px){
  .nav-entrar{display:none}
  .container,.container-sm{padding:0 20px}
  footer{padding:20px}
  .hero{padding:48px 0 36px}
  .contato-card{padding:24px 20px}
}
</style>
</head>
<body>

<!-- TICKER -->
<div id="ticker">
  <div class="tk-label">AO VIVO</div>
  <div class="tk-track" id="tk-track"></div>
</div>

<!-- NAV -->
<nav>
  <a class="logo" href="/index.html"><em>1</em>NEGÓCIO <div class="pulse"></div></a>
  <div class="nav-links">
    <a class="nl" href="/avaliar.html">Avalie</a>
    <a class="nl" href="/vender.html">Venda</a>
    <a class="nl" href="/index.html">Compre</a>
    <a class="nl amber" href="/index.html#blog">Inteligência</a>
    <a class="nl on" href="/fale-conosco.html">Fale conosco</a>
  </div>
  <button class="nav-entrar" id="nav-entrar" onclick="window.location.href='/portal-usuario.html'">Entrar</button>
  <button class="nav-cta" onclick="window.location.href='/diagnostico.html'">
    <span class="nav-cta-main">Avalie Gratuitamente</span>
    <span class="nav-cta-sub">Publique grátis + 10% · ou R$49/mês + 5%</span>
  </button>
</nav>

<div class="page">

  <!-- HERO -->
  <div class="hero">
    <div class="container-sm">
      <div class="hero-eyebrow fu">Contato direto</div>
      <h1 class="fu fu1">
        Como podemos<br><em>ajudar?</em>
      </h1>
      <p class="hero-sub fu fu2">Escolha o caminho abaixo conforme o seu perfil. Respondemos em até 24h úteis.</p>
    </div>
  </div>

  <!-- DOIS CAMINHOS -->
  <div class="section">
    <div class="container">
      <div class="contato-grid">

        <!-- VENDEDOR -->
        <div class="contato-card vend">
          <div class="contato-badge" style="color:var(--green)">Sou vendedor</div>
          <div class="contato-title">Tenho um negócio<br>para vender</div>
          <div class="contato-desc">Dúvidas sobre avaliação, publicação, confidencialidade, planos ou o processo de venda.</div>
          <div class="contato-links">
            <a href="https://wa.me/message/4EE2KGUFVLEOJ1?text=Olá%2C%20tenho%20um%20negócio%20para%20vender%20e%20gostaria%20de%20saber%20mais%20sobre%20a%201Negócio%20%5BVendedor%5D" target="_blank" class="c-link wpp-g">
              <span class="c-link-ico" style="color:var(--green)">WA</span>
              <div>
                <div class="c-link-label" style="color:var(--green)">WhatsApp · Falar com consultor</div>
                <div class="c-link-sub">Resposta em até 2h em dias úteis</div>
              </div>
            </a>
            <!-- Chat interno — só aparece se logado -->
            <a href="/portal-usuario.html#suporte" id="chat-vendedor" class="c-link email" style="display:none">
              <span class="c-link-ico" style="color:var(--green)">→</span>
              <div>
                <div class="c-link-label" style="color:var(--green)">Chat pelo portal</div>
                <div class="c-link-sub">Mensagem direta ao time 1Negócio</div>
              </div>
            </a>
            <a href="/diagnostico.html" class="contato-cta" style="background:var(--green);color:#000">
              Ou avalie agora — gratuito →
            </a>
          </div>
        </div>

        <!-- COMPRADOR -->
        <div class="contato-card comp">
          <div class="contato-badge" style="color:var(--blue)">Sou comprador</div>
          <div class="contato-title">Procuro um negócio<br>para comprar</div>
          <div class="contato-desc">Dúvidas sobre o catálogo, acesso ao laudo, NDA, qualificação de comprador ou uma oportunidade específica.</div>
          <div class="contato-links">
            <a href="https://wa.me/message/4EE2KGUFVLEOJ1?text=Olá%2C%20estou%20procurando%20um%20negócio%20para%20comprar%20na%201Negócio%20%5BComprador%5D" target="_blank" class="c-link wpp-b">
              <span class="c-link-ico" style="color:var(--blue)">WA</span>
              <div>
                <div class="c-link-label" style="color:var(--blue)">WhatsApp · Falar com consultor</div>
                <div class="c-link-sub">Resposta em até 2h em dias úteis</div>
              </div>
            </a>
            <!-- Chat interno — só aparece se logado -->
            <a href="/portal-usuario.html#suporte" id="chat-comprador" class="c-link email" style="display:none">
              <span class="c-link-ico" style="color:var(--blue)">→</span>
              <div>
                <div class="c-link-label" style="color:var(--blue)">Chat pelo portal</div>
                <div class="c-link-sub">Mensagem direta ao time 1Negócio</div>
              </div>
            </a>
            <a href="/comprar.html#tese" class="contato-cta" style="background:var(--blue);color:#000">
              Ou cadastre sua tese →
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- FAQ -->
  <div class="section" style="border-bottom:none">
    <div class="container-sm">
      <div class="sec-label">Perguntas frequentes</div>
      <div id="faq"></div>
    </div>
  </div>

</div>

<footer>
  <a href="/index.html" class="f-logo"><em>1</em>NEGÓCIO</a>
  <div class="f-links">
    <a href="/avaliar.html" class="f-link">Avalie</a>
    <a href="/vender.html" class="f-link">Venda</a>
    <a href="/index.html" class="f-link">Compre</a>
    <a href="/fale-conosco.html" class="f-link on">Fale conosco</a>
  </div>
  <span>© 2026 1Negócio · contato@1negocio.com.br</span>
</footer>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
var SUPA_URL='https://dbijmgqlcrgjlcfrastg.supabase.co';
var SUPA_KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRiaWptZ3FsY3JnamxjZnJhc3RnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMwNzYxNjMsImV4cCI6MjA4ODY1MjE2M30.mV2rANZ8Nb_AbifTmkEvdfX_nsm8zeT6Al_bPrCzNAA';
var sb=supabase.createClient(SUPA_URL,SUPA_KEY);

// Auth — revela chat interno se logado
(async function(){
  try{
    var res=await sb.auth.getSession();
    if(res.data&&res.data.session){
      var u=res.data.session.user;
      // atualiza nav
      var btn=document.getElementById('nav-entrar');
      if(btn){btn.textContent=u.email.split('@')[0];btn.onclick=function(){window.location.href='/portal-usuario.html';};}
      // mostra botões de chat interno nos dois cards
      var cv=document.getElementById('chat-vendedor');
      var cc=document.getElementById('chat-comprador');
      if(cv)cv.style.display='flex';
      if(cc)cc.style.display='flex';
    }
  }catch(e){}
})();

// Ticker
(function(){
  var items=[
    {cat:'Tecnologia',nome:'ERP Varejo · 380 Clientes',ask:'3,8M',aval:'4,3M',up:true},
    {cat:'Serviços B2B',nome:'Contabilidade Digital · 620 PJ',ask:'3,0M',aval:'3,1M',up:true},
    {cat:'Alimentação',nome:'Barbearia Premium · 3 Un.',ask:'280K',aval:'450K',up:true},
    {cat:'Indústria',nome:'Gráfica Digital · ISO 9001',ask:'1,15M',aval:'1,1M',up:false},
    {cat:'Saúde',nome:'Clínica Integrativa · Curitiba',ask:'2,1M',aval:'2,2M',up:true},
  ];
  var h='';
  [0,1].forEach(function(){
    items.forEach(function(it){
      var pct=Math.abs(Math.round((parseFloat(it.aval)-parseFloat(it.ask))/parseFloat(it.ask)*100))||4;
      h+='<div class="tk-item">'
        +'<span style="font-size:6px;letter-spacing:.14em;text-transform:uppercase;color:var(--green)">'+it.cat+'</span>'
        +'<span style="font-family:\'Syne\',sans-serif;font-size:10px;font-weight:600;color:rgba(255,255,255,.55)">'+it.nome+'</span>'
        +'<span style="color:rgba(255,255,255,.15)">·</span>'
        +'<span style="font-size:8.5px;color:rgba(255,255,255,.2);text-decoration:line-through">'+it.ask+'</span>'
        +'<span style="font-size:8px;color:rgba(255,255,255,.2)">→</span>'
        +'<span style="font-size:9.5px;color:#fff;font-weight:500">'+it.aval+'</span>'
        +'<span style="font-size:7px;color:'+(it.up?'var(--green)':'var(--red)')+'">'+( it.up?'▲':'▼')+pct+'%</span>'
        +'</div>';
    });
  });
  document.getElementById('tk-track').innerHTML=h;
})();

// FAQ
var faqs=[
  ["Como funciona a confidencialidade?","Seu nome, CNPJ, sócios e dados financeiros nunca aparecem no anúncio público. O comprador só acessa o laudo completo após assinar NDA e ser aprovado pela 1Negócio. Todo o contato é mediado por nós até o fechamento."],
  ["A avaliação gratuita é realmente gratuita?","Sim. O diagnóstico online e a publicação no catálogo são 100% gratuitos. Você paga apenas 10% de taxa de sucesso se — e quando — a venda for concluída. Sem mensalidade, sem custo antecipado no plano gratuito."],
  ["Qual a diferença entre plano gratuito e guiado?","No gratuito você preenche o diagnóstico em 5 minutos e gerencia pelo portal. No guiado (R$49/mês em 12x), nossa equipe conduz tudo — avaliação, laudo, destaque no catálogo por 12 meses — e a taxa de sucesso cai de 10% para 5%."],
  ["Quanto tempo leva para vender?","Depende do setor, preço e qualidade do laudo. Negócios bem precificados com dados claros costumam receber propostas em 30–90 dias. O prazo de fechamento varia de 2 a 6 meses."],
  ["O que é o laudo de avaliação?","É o documento completo com score de saúde em 10 dimensões, análise financeira, composição do valor e oportunidades de melhoria. Gerado automaticamente no diagnóstico gratuito ou produzido pela equipe na avaliação profissional (R$397)."],
  ["Como o comprador é qualificado?","Antes de qualquer contato, a 1Negócio verifica capacidade financeira e seriedade do comprador. Apenas compradores aprovados recebem acesso ao laudo completo. Sem curiosos, sem perda de tempo do vendedor."],
  ["Posso cancelar a listagem?","Sim, a qualquer momento pelo portal do vendedor. Não há multa ou fidelidade. A taxa de sucesso só incide no fechamento da venda."],
  ["O que é porteira fechada?","Porteira fechada significa que o comprador paga o valor pedido e entra no negócio assumindo todos os ativos e passivos. O valor que você efetivamente desembolsa pode ser maior ou menor que o preço anunciado — isso fica claro no laudo antes de qualquer negociação."]
];

var faqEl=document.getElementById('faq');
faqs.forEach(function(f){
  var item=document.createElement('div');
  item.className='faq-item';
  item.innerHTML='<div class="faq-q" onclick="toggleFaq(this)"><span>'+f[0]+'</span><span class="faq-ico">+</span></div>'
    +'<div class="faq-a">'+f[1]+'</div>';
  faqEl.appendChild(item);
});
function toggleFaq(el){
  var ans=el.nextElementSibling;
  var open=ans.style.display==='block';
  document.querySelectorAll('.faq-q').forEach(function(q){
    q.classList.remove('open');
    q.nextElementSibling.style.display='none';
    q.querySelector('.faq-ico').textContent='+';
  });
  if(!open){
    el.classList.add('open');
    ans.style.display='block';
    el.querySelector('.faq-ico').textContent='+';
  }
}
</script>
</body>
</html>
