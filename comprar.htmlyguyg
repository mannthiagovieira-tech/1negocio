<!DOCTYPE html>
<html lang="pt-BR">
<head>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-7DGLH0W7KE"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-7DGLH0W7KE');
</script>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>1Negócio · Compre um negócio com laudo técnico</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=Instrument+Serif:ital@0;1&family=Syne:wght@700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0c0c0a;--bg2:#111110;--bg3:#161614;
  --ink:rgba(255,255,255,.88);--ink2:rgba(255,255,255,.46);
  --ink3:rgba(255,255,255,.22);--ink4:rgba(255,255,255,.08);
  --sep:rgba(255,255,255,.07);
  --green:#10b981;--amber:#f59e0b;--blue:#60a5fa;--red:#f87171;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--ink);font-family:'DM Mono',monospace;overflow-x:hidden}
a{color:inherit;text-decoration:none}

/* ── TICKER ── */
#ticker{
  position:fixed;top:0;left:0;right:0;z-index:600;
  height:26px;background:#060606;
  border-bottom:1px solid rgba(16,185,129,.15);
  overflow:hidden;display:flex;align-items:center;
}
#ticker::before,#ticker::after{
  content:'';position:absolute;top:0;bottom:0;width:50px;z-index:10;pointer-events:none;
}
#ticker::before{left:0;background:linear-gradient(90deg,#060606,transparent)}
#ticker::after{right:0;background:linear-gradient(270deg,#060606,transparent)}
.tk-label{
  position:absolute;left:0;top:0;bottom:0;z-index:20;
  display:flex;align-items:center;padding:0 12px;
  background:#060606;border-right:1px solid rgba(16,185,129,.15);
  font-family:'Syne',sans-serif;font-size:7px;font-weight:700;
  letter-spacing:.2em;text-transform:uppercase;color:var(--green);white-space:nowrap;
}
.tk-track{display:flex;width:max-content;animation:tkr 80s linear infinite;padding-left:100px}
#ticker:hover .tk-track{animation-play-state:paused}
@keyframes tkr{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.tk-item{display:flex;align-items:center;gap:8px;padding:0 20px;height:26px;border-right:1px solid rgba(255,255,255,.04);flex-shrink:0;font-size:9px}

/* ── NAV ── */
nav{
  position:fixed;top:26px;left:0;right:0;z-index:500;height:46px;
  display:flex;align-items:center;
  background:rgba(12,12,10,.98);backdrop-filter:blur(20px);
  border-bottom:1px solid var(--sep);
}
.logo{
  font-family:'Syne',sans-serif;font-weight:800;font-size:14px;
  letter-spacing:-.02em;color:#fff;
  display:flex;align-items:center;gap:8px;padding:0 20px;
  border-right:1px solid var(--sep);height:100%;flex-shrink:0;
}
.logo em{font-style:normal;color:var(--green)}
.pulse{width:5px;height:5px;border-radius:50%;background:var(--green);animation:pulse 2.4s ease infinite;flex-shrink:0}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.3;transform:scale(.6)}}
.nav-links{display:flex;align-items:center;flex:1;overflow:hidden}
.nl{
  font-size:10px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;
  color:var(--ink2);background:none;border:none;cursor:pointer;
  padding:0 18px;height:46px;border-right:1px solid var(--sep);
  transition:color .15s;white-space:nowrap;flex-shrink:0;
  text-decoration:none;display:flex;align-items:center;
}
.nl:hover{color:var(--ink)}
.nl.on{color:var(--green)}
.nl.amber{color:var(--amber)}
.nav-entrar{
  background:transparent;border-right:1px solid var(--sep);color:var(--ink3);
  font-family:'DM Mono',monospace;font-size:10px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;
  padding:0 16px;height:46px;cursor:pointer;transition:all .13s;
  display:flex;align-items:center;white-space:nowrap;
  border-left:none;border-top:none;border-bottom:none;
}
.nav-entrar:hover{color:var(--ink)}
.nav-cta{
  font-family:'Syne',sans-serif;font-weight:800;
  background:var(--green);color:#fff;border:none;
  padding:0 22px;height:46px;cursor:pointer;
  transition:all .2s;flex-shrink:0;white-space:nowrap;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;
  min-width:200px;
}
.nav-cta:hover{background:#0ea572;box-shadow:0 0 18px rgba(16,185,129,.3)}
.nav-cta-main{font-size:11px;letter-spacing:.05em;text-transform:uppercase;line-height:1;font-weight:800}
.nav-cta-sub{font-size:6.5px;letter-spacing:.12em;text-transform:uppercase;opacity:.75;line-height:1;font-weight:400}

/* ── LAYOUT ── */
.page{padding-top:144px}
.container{max-width:1060px;margin:0 auto;padding:0 40px}
.container-sm{max-width:720px;margin:0 auto;padding:0 40px}

/* ── ANIMAÇÕES ── */
@keyframes fu{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.fu{animation:fu .5s ease both}
.fu1{animation-delay:.1s}.fu2{animation-delay:.2s}.fu3{animation-delay:.3s}.fu4{animation-delay:.4s}

/* ── SEC LABEL ── */
.sec-label{
  font-size:8px;letter-spacing:.24em;text-transform:uppercase;color:var(--ink3);
  margin-bottom:24px;display:flex;align-items:center;gap:10px;
}
.sec-label::before{content:'';width:14px;height:1px;background:var(--blue);flex-shrink:0}
.sec-label::after{content:'';flex:1;height:.5px;background:var(--sep)}

/* ── HERO ── */
.hero{padding:80px 0 64px;border-bottom:1px solid var(--sep)}
.hero-eyebrow{
  font-size:8px;letter-spacing:.24em;text-transform:uppercase;color:var(--blue);
  display:flex;align-items:center;gap:8px;margin-bottom:20px;
}
.hero-eyebrow::before{content:'';width:16px;height:1px;background:var(--blue)}
.hero h1{
  font-family:'Syne',sans-serif;font-size:clamp(42px,5.5vw,72px);
  font-weight:800;line-height:1.05;letter-spacing:-.02em;
  color:#fff;margin-bottom:20px;
}
.hero h1 em{color:var(--blue);font-style:italic;font-family:'Instrument Serif',serif}
.hero-sub{
  font-size:13px;color:var(--ink2);line-height:1.8;
  max-width:560px;margin-bottom:40px;
  font-weight:300;letter-spacing:0;
}
.hero-ctas{display:flex;gap:10px;flex-wrap:wrap;align-items:center}
.btn-primary{
  background:var(--blue);color:#000;
  font-family:'Syne',sans-serif;font-size:10px;font-weight:800;
  letter-spacing:.12em;text-transform:uppercase;
  padding:14px 28px;border:none;cursor:pointer;
  transition:all .15s;display:inline-flex;align-items:center;gap:8px;
  text-decoration:none;
}
.btn-primary:hover{opacity:.88}
.btn-sec{
  background:transparent;border:.5px solid var(--sep);color:var(--ink2);
  font-family:'Syne',sans-serif;font-size:10px;font-weight:700;
  letter-spacing:.12em;text-transform:uppercase;
  padding:14px 28px;cursor:pointer;transition:all .15s;
  display:inline-flex;align-items:center;gap:8px;text-decoration:none;
}
.btn-sec:hover{border-color:rgba(255,255,255,.2);color:var(--ink)}

/* ── STATS ── */
.stats-grid{
  display:grid;grid-template-columns:repeat(6,1fr);
  gap:1px;background:var(--sep);
}
.stat-card{background:var(--bg2);padding:18px 16px;text-align:center}
.stat-card.dest{
  background:linear-gradient(135deg,rgba(96,165,250,.08),rgba(96,165,250,.03));
  border:.5px solid rgba(96,165,250,.2);
}
.stat-n{
  font-family:'Syne',sans-serif;font-size:22px;font-weight:800;
  letter-spacing:-.02em;margin-bottom:4px;line-height:1;
}
.stat-l{font-size:8px;letter-spacing:.12em;text-transform:uppercase;color:var(--ink3)}

/* ── JORNADA ── */
.jornada-step{
  display:flex;gap:28px;padding:28px 0;
  border-bottom:.5px solid var(--sep);align-items:flex-start;
}
.jornada-step:last-child{border-bottom:none}
.jornada-n{
  font-family:'Syne',sans-serif;font-size:36px;font-weight:800;
  color:rgba(96,165,250,.15);flex-shrink:0;width:48px;line-height:1;
  transition:color .2s;
}
.jornada-step:hover .jornada-n{color:rgba(96,165,250,.4)}
.jornada-title{
  font-family:'Syne',sans-serif;font-size:11px;font-weight:800;
  letter-spacing:.12em;text-transform:uppercase;margin-bottom:6px;color:#fff;
}
.jornada-desc{font-size:11px;color:var(--ink2);line-height:1.7;font-weight:300}

/* ── SETORES ── */
.setores-grid{
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:1px;background:var(--sep);
}
.setor-card{
  background:var(--bg2);padding:22px 24px;
  border-left:3px solid transparent;transition:border-color .2s;
}
.setor-card:hover{border-left-color:var(--blue)}
.setor-pct{
  font-family:'Syne',sans-serif;font-size:24px;font-weight:800;
  letter-spacing:-.02em;margin-bottom:6px;line-height:1;
}
.setor-nome{
  font-family:'Syne',sans-serif;font-size:10px;font-weight:800;
  letter-spacing:.1em;text-transform:uppercase;margin-bottom:5px;color:#fff;
}
.setor-desc{font-size:11px;color:var(--ink2);line-height:1.55;font-weight:300}

/* ── O QUE VOCÊ VÊ ── */
.laudo-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:1px;background:var(--sep);
}
.laudo-card{background:var(--bg2);padding:24px}
.laudo-titulo{
  font-family:'Syne',sans-serif;font-size:10px;font-weight:800;
  letter-spacing:.12em;text-transform:uppercase;margin-bottom:10px;
}
.laudo-desc{font-size:11px;color:var(--ink2);line-height:1.7;font-weight:300}

/* ── FORMULÁRIO ── */
.form-wrap{
  background:var(--bg2);border:.5px solid var(--sep);
  padding:40px;
}
.field{margin-bottom:16px}
.field label{
  display:block;font-size:8px;letter-spacing:.16em;text-transform:uppercase;
  color:var(--ink3);margin-bottom:7px;
}
.field input,.field select,.field textarea{
  width:100%;background:rgba(255,255,255,.04);
  border:.5px solid rgba(255,255,255,.1);
  padding:12px 16px;color:var(--ink);
  font-family:'DM Mono',monospace;font-size:12px;font-weight:300;
  outline:none;transition:border-color .2s;border-radius:0;
  -webkit-appearance:none;
}
.field input:focus,.field select,.field textarea:focus{
  border-color:rgba(96,165,250,.5);background:rgba(96,165,250,.04);
}
.field select{cursor:pointer}
.field select option{background:#111}
.field textarea{resize:vertical;min-height:80px}
.form-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.form-submit{
  display:block;width:100%;padding:14px;text-align:center;
  background:var(--blue);color:#000;border:none;cursor:pointer;
  font-family:'Syne',sans-serif;font-size:10px;font-weight:800;
  letter-spacing:.12em;text-transform:uppercase;transition:opacity .15s;
}
.form-submit:hover{opacity:.88}
.form-submit:disabled{opacity:.4;cursor:not-allowed}
.form-msg{
  display:none;font-size:11px;padding:12px 16px;
  margin-bottom:14px;line-height:1.6;font-weight:300;
}
.form-ok{background:rgba(16,185,129,.06);border:.5px solid rgba(16,185,129,.3);color:var(--green)}
.form-err{background:rgba(248,113,113,.06);border:.5px solid rgba(248,113,113,.3);color:var(--red)}
.form-note{margin-top:10px;font-size:9px;color:var(--ink3);text-align:center;letter-spacing:.05em}

/* ── CTA FINAL ── */
.cta-final{padding:72px 0;text-align:center}
.cta-final h2{
  font-family:'Syne',sans-serif;font-size:clamp(30px,4vw,50px);
  font-weight:800;letter-spacing:-.02em;margin-bottom:14px;color:#fff;
}
.cta-final h2 em{color:var(--blue);font-style:italic;font-family:'Instrument Serif',serif}
.cta-final p{font-size:12px;color:var(--ink2);margin-bottom:28px;line-height:1.7;font-weight:300}
.btn-outline-blue{
  display:inline-block;background:transparent;
  border:.5px solid rgba(96,165,250,.4);color:var(--blue);
  font-family:'Syne',sans-serif;font-size:11px;font-weight:800;
  letter-spacing:.12em;text-transform:uppercase;
  padding:14px 32px;text-decoration:none;transition:all .15s;
}
.btn-outline-blue:hover{background:rgba(96,165,250,.06);border-color:rgba(96,165,250,.7)}

/* ── FOOTER ── */
footer{
  padding:24px 40px;border-top:.5px solid var(--sep);
  display:flex;align-items:center;justify-content:space-between;
  font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink3);
  flex-wrap:wrap;gap:12px;
}
.f-logo{font-family:'Syne',sans-serif;font-size:13px;font-weight:800;color:#fff;display:flex;align-items:center;gap:5px}
.f-logo em{color:var(--green);font-style:normal}
.f-links{display:flex;gap:20px;flex-wrap:wrap}
.f-link{color:var(--ink3);transition:color .15s}
.f-link:hover{color:var(--ink)}
.f-link.on{color:var(--green)}

/* ── SEÇÕES ── */
.section{padding:64px 0;border-bottom:1px solid var(--sep)}

/* ── RESPONSIVO ── */
@media(max-width:900px){
  .nl:nth-child(n+4){display:none}
  .stats-grid{grid-template-columns:repeat(3,1fr)}
}
@media(max-width:768px){
  .nl{display:none}
  .nav-cta-sub{display:none}
  .nav-cta{min-width:auto;padding:0 16px}
  .stats-grid{grid-template-columns:repeat(3,1fr)}
  .setores-grid{grid-template-columns:1fr 1fr}
  .laudo-grid{grid-template-columns:1fr}
  .form-grid-2{grid-template-columns:1fr}
}
@media(max-width:600px){
  .nav-entrar{display:none}
  .container,.container-sm{padding:0 20px}
  footer{padding:20px}
  .hero{padding:48px 0 40px}
  .stats-grid{grid-template-columns:1fr 1fr}
  .setores-grid{grid-template-columns:1fr}
  .form-wrap{padding:24px 20px}
}
@media(max-width:440px){
  .stats-grid{grid-template-columns:1fr 1fr}
  .stat-card:nth-child(n+5){display:none}
}
</style>
</head>
<body>

<!-- TICKER -->
<div id="ticker">
  <div class="tk-label">AO VIVO</div>
  <div class="tk-track" id="tk-track"></div>
</div>

<!-- NAV -->
<nav>
  <a class="logo" href="/index.html"><em>1</em>NEGÓCIO <div class="pulse"></div></a>
  <div class="nav-links">
    <a class="nl" href="/avaliar.html">Avalie</a>
    <a class="nl" href="/vender.html">Venda</a>
    <a class="nl on" href="/comprar.html">Compre</a>
    <a class="nl amber" href="/index.html#blog">Inteligência</a>
    <a class="nl" href="/fale-conosco.html">Fale conosco</a>
  </div>
  <button class="nav-entrar" id="nav-entrar" onclick="window.location.href='/portal-usuario.html'">Entrar</button>
  <button class="nav-cta" onclick="window.location.href='/diagnostico.html'">
    <span class="nav-cta-main">Avalie Gratuitamente</span>
    <span class="nav-cta-sub">Publique grátis + 10% · ou R$49/mês + 5%</span>
  </button>
</nav>

<div class="page">

  <!-- HERO -->
  <div class="hero">
    <div class="container">
      <div class="hero-eyebrow fu">Para investidores e compradores sérios</div>
      <h1 class="fu fu1">
        Não são anúncios.<br>São <em>laudos técnicos.</em>
      </h1>
      <p class="hero-sub fu fu2">
        Cada negócio na 1Negócio tem avaliação financeira calculada, score de saúde em 10 dimensões e composição de valor detalhada. Você analisa antes de entrar em contato. Cadastro gratuito, sempre.
      </p>
      <div class="hero-ctas fu fu3">
        <a href="/index.html" class="btn-primary">Ver catálogo de negócios →</a>
        <a href="#tese" class="btn-sec">Cadastrar tese de investimento</a>
      </div>
    </div>
  </div>

  <!-- STATS -->
  <div class="section" style="padding:40px 0">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-card"><div class="stat-n" style="color:var(--green)">2.714</div><div class="stat-l">À venda agora</div></div>
        <div class="stat-card"><div class="stat-n" style="color:var(--blue)">R$4,8B</div><div class="stat-l">Volume total</div></div>
        <div class="stat-card"><div class="stat-n" style="color:var(--amber)">R$580K</div><div class="stat-l">Ticket médio</div></div>
        <div class="stat-card"><div class="stat-n">34</div><div class="stat-l">Em negociação</div></div>
        <div class="stat-card"><div class="stat-n" style="color:var(--green)">12</div><div class="stat-l">Vendidos 2026</div></div>
        <div class="stat-card dest"><div class="stat-n" style="color:var(--blue);font-size:16px;margin-top:4px">Sempre</div><div class="stat-l" style="color:var(--blue);margin-top:4px">Gratuito para compradores</div></div>
      </div>
    </div>
  </div>

  <!-- JORNADA -->
  <div class="section">
    <div class="container-sm">
      <div class="sec-label">Como funciona para o comprador</div>
      <div>
        <div class="jornada-step">
          <div class="jornada-n">1</div>
          <div>
            <div class="jornada-title">Cadastre sua tese</div>
            <div class="jornada-desc">Informe setor de interesse, faixa de faturamento, ticket disponível e localização. Gratuito e sem compromisso. Você recebe alertas de negócios compatíveis.</div>
          </div>
        </div>
        <div class="jornada-step">
          <div class="jornada-n">2</div>
          <div>
            <div class="jornada-title">Navegue laudos, não apenas anúncios</div>
            <div class="jornada-desc">Cada listagem inclui laudo financeiro completo — faturamento, EBITDA, DRE simplificada, regime tributário, score de saúde e composição do valor. Muito além de um anúncio comum.</div>
          </div>
        </div>
        <div class="jornada-step">
          <div class="jornada-n">3</div>
          <div>
            <div class="jornada-title">Assine o NDA e acesse o laudo completo</div>
            <div class="jornada-desc">Se tiver interesse, a 1Negócio confirma sua capacidade financeira, encaminha o NDA digital e libera o laudo de avaliação completo com dados financeiros reais e nome do negócio.</div>
          </div>
        </div>
        <div class="jornada-step">
          <div class="jornada-n">4</div>
          <div>
            <div class="jornada-title">Negociação e fechamento mediado</div>
            <div class="jornada-desc">A 1Negócio media as rodadas de apresentação via mesa digital. Quando ambos chegam a um acordo, o fechamento é formalizado. Custo zero para o comprador.</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- O QUE VOCÊ VÊ NO LAUDO -->
  <div class="section" style="background:rgba(96,165,250,.02)">
    <div class="container">
      <div class="sec-label">O que você vê em cada laudo</div>
      <div class="laudo-grid">
        <div class="laudo-card">
          <div class="laudo-titulo" style="color:var(--green)">→ Financeiro</div>
          <div class="laudo-desc">Faturamento bruto e líquido, EBITDA ajustado, regime tributário, DRE simplificada mensal e anual, margens operacionais e pró-labore.</div>
        </div>
        <div class="laudo-card">
          <div class="laudo-titulo" style="color:var(--blue)">→ Saúde operacional</div>
          <div class="laudo-desc">Score em 10 dimensões: sócio-dependência, concentração de clientes, risco legal, gestão de processos, alvarás, equipe e escalabilidade.</div>
        </div>
        <div class="laudo-card">
          <div class="laudo-titulo" style="color:var(--amber)">→ Cashout real</div>
          <div class="laudo-desc">O valor que você efetivamente desembolsa pode ser diferente do preço pedido. Balanço patrimonial, ativos e passivos são considerados — o que o dono pede pode não ser o que você paga de verdade. Você sabe exatamente o que está comprando.</div>
        </div>
      </div>
    </div>
  </div>

  <!-- SETORES -->
  <div class="section">
    <div class="container">
      <div class="sec-label">Setores com mais negócios à venda</div>
      <div class="setores-grid">
        <div class="setor-card">
          <div class="setor-pct" style="color:var(--green)">24%</div>
          <div class="setor-nome">Alimentação</div>
          <div class="setor-desc">Restaurante, lanchonete, padaria, delivery, bar. Maior setor da base.</div>
        </div>
        <div class="setor-card">
          <div class="setor-pct" style="color:var(--blue)">37%</div>
          <div class="setor-nome">Varejo</div>
          <div class="setor-desc">Mercado, moda, pet shop, farmácia, construção. Mercado/mercearia lidera com 13%.</div>
        </div>
        <div class="setor-card">
          <div class="setor-pct" style="color:var(--amber)">5,5%</div>
          <div class="setor-nome">Tecnologia</div>
          <div class="setor-desc">SaaS, software B2B, plataformas. Segmento com maiores múltiplos de avaliação.</div>
        </div>
        <div class="setor-card">
          <div class="setor-pct" style="color:var(--ink2)">Outros</div>
          <div class="setor-nome">Serviços, saúde, educação</div>
          <div class="setor-desc">Franquias, clínicas, escolas, consultorias e indústria completam a base.</div>
        </div>
      </div>
    </div>
  </div>

  <!-- FORMULÁRIO TESE -->
  <div id="tese" class="section">
    <div class="container-sm">
      <div class="sec-label">Cadastre sua tese — gratuito</div>
      <p style="font-size:12px;color:var(--ink2);margin-bottom:32px;line-height:1.8;font-weight:300">
        Preencha abaixo e receba alertas de negócios compatíveis com seu perfil. Sem spam. Custo zero.
      </p>
      <div class="form-wrap">
        <div id="form-msg" class="form-msg"></div>
        <div class="form-grid-2" style="margin-bottom:16px">
          <div class="field"><label>Nome</label><input type="text" id="f-nome" placeholder="Seu nome" required></div>
          <div class="field"><label>E-mail</label><input type="email" id="f-email" placeholder="email@empresa.com" required></div>
        </div>
        <div class="form-grid-2" style="margin-bottom:16px">
          <div class="field">
            <label>Setor de interesse</label>
            <select id="f-setor">
              <option value="">Todos os setores</option>
              <option>Alimentação</option>
              <option>Varejo</option>
              <option>Saúde</option>
              <option>Tecnologia / SaaS</option>
              <option>Educação</option>
              <option>Serviços B2B</option>
              <option>Indústria</option>
              <option>Franquia</option>
              <option>Pet</option>
              <option>Hospedagem / Turismo</option>
              <option>Outro</option>
            </select>
          </div>
          <div class="field">
            <label>Ticket disponível</label>
            <select id="f-ticket">
              <option value="">Selecione</option>
              <option>Até R$200K</option>
              <option>R$200K – R$500K</option>
              <option>R$500K – R$1M</option>
              <option>R$1M – R$3M</option>
              <option>Acima de R$3M</option>
            </select>
          </div>
        </div>
        <div class="field" style="margin-bottom:16px">
          <label>Localização de interesse</label>
          <input type="text" id="f-local" placeholder="Ex: São Paulo, Florianópolis, qualquer estado...">
        </div>
        <div class="field" style="margin-bottom:20px">
          <label>Observações (opcional)</label>
          <textarea id="f-obs" rows="3" placeholder="Ex: busco negócio com equipe estruturada, faturamento acima de R$500K, sem dependência do sócio..."></textarea>
        </div>
        <button class="form-submit" id="form-btn" onclick="submitTese()">Cadastrar tese de investimento →</button>
        <div class="form-note">Gratuito. Sem compromisso. Você cancela quando quiser.</div>
      </div>
    </div>
  </div>

  <!-- CTA CATÁLOGO -->
  <div class="cta-final">
    <div class="container-sm">
      <h2>Prefere <em>navegar agora?</em></h2>
      <p>Mais de 2.700 negócios com laudo técnico, score de saúde e valor calculado.</p>
      <a href="/index.html" class="btn-outline-blue">Ver catálogo de negócios →</a>
    </div>
  </div>

</div>

<footer>
  <a href="/index.html" class="f-logo"><em>1</em>NEGÓCIO</a>
  <div class="f-links">
    <a href="/avaliar.html" class="f-link">Avalie</a>
    <a href="/vender.html" class="f-link">Venda</a>
    <a href="/comprar.html" class="f-link on">Compre</a>
    <a href="/fale-conosco.html" class="f-link">Fale conosco</a>
  </div>
  <span>© 2026 1Negócio · M&A de PMEs · Brasil</span>
</footer>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
var SUPA_URL='https://dbijmgqlcrgjlcfrastg.supabase.co';
var SUPA_KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRiaWptZ3FsY3JnamxjZnJhc3RnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMwNzYxNjMsImV4cCI6MjA4ODY1MjE2M30.mV2rANZ8Nb_AbifTmkEvdfX_nsm8zeT6Al_bPrCzNAA';
var sb=supabase.createClient(SUPA_URL,SUPA_KEY);

// Auth check — atualiza nav se logado
(async function(){
  try{
    var res=await sb.auth.getSession();
    if(res.data&&res.data.session){
      var u=res.data.session.user;
      var btn=document.getElementById('nav-entrar');
      if(btn){btn.textContent=u.email.split('@')[0];btn.onclick=function(){window.location.href='/portal-usuario.html';};}
    }
  }catch(e){}
})();

// Ticker
(function(){
  var items=[
    {cat:'Tecnologia',nome:'SaaS Clínicas · 340 Assinantes',ask:'1,3M',aval:'1,7M',up:true},
    {cat:'Indústria',nome:'Gráfica Digital · ISO 9001',ask:'1,15M',aval:'1,1M',up:false},
    {cat:'Saúde',nome:'Clínica Integrativa · Curitiba',ask:'2,1M',aval:'2,2M',up:true},
    {cat:'Serviços B2B',nome:'Contabilidade · 620 PJ',ask:'3,0M',aval:'3,1M',up:true},
    {cat:'Alimentação',nome:'Barbearia Premium · 3 Un.',ask:'280K',aval:'450K',up:true},
  ];
  var h='';
  [0,1].forEach(function(){
    items.forEach(function(it){
      var pct=it.up?Math.round((parseFloat(it.aval)-parseFloat(it.ask))/parseFloat(it.ask)*100):Math.round((parseFloat(it.ask)-parseFloat(it.aval))/parseFloat(it.aval)*100);
      h+='<div class="tk-item">'
        +'<span style="font-size:6px;letter-spacing:.14em;text-transform:uppercase;color:var(--blue)">'+it.cat+'</span>'
        +'<span style="font-family:\'Syne\',sans-serif;font-size:10px;font-weight:600;color:rgba(255,255,255,.55)">'+it.nome+'</span>'
        +'<span style="color:rgba(255,255,255,.15)">·</span>'
        +'<span style="font-size:8.5px;color:rgba(255,255,255,.2);text-decoration:line-through">'+it.ask+'</span>'
        +'<span style="font-size:8px;color:rgba(255,255,255,.2)">→</span>'
        +'<span style="font-size:9.5px;color:#fff;font-weight:500">'+it.aval+'</span>'
        +'<span style="font-size:7px;color:'+(it.up?'var(--green)':'var(--red)')+'">'+( it.up?'▲':'▼')+Math.abs(pct)+'%</span>'
        +'</div>';
    });
  });
  document.getElementById('tk-track').innerHTML=h;
})();

// Submit tese — salva no Supabase (tabela teses_investimento se existir, senão só exibe confirmação)
async function submitTese(){
  var msg=document.getElementById('form-msg');
  var btn=document.getElementById('form-btn');
  var nome=document.getElementById('f-nome').value.trim();
  var email=document.getElementById('f-email').value.trim();

  if(!nome||!email){
    msg.className='form-msg form-err';msg.style.display='block';
    msg.textContent='Preencha nome e e-mail para continuar.';
    return;
  }

  btn.disabled=true;btn.textContent='Enviando...';

  try{
    // Tenta salvar na tabela teses_investimento
    await sb.from('teses_investimento').insert({
      nome,email,
      setor:document.getElementById('f-setor').value||null,
      ticket:document.getElementById('f-ticket').value||null,
      localizacao:document.getElementById('f-local').value.trim()||null,
      observacoes:document.getElementById('f-obs').value.trim()||null,
      origem:'comprar.html',
      created_at:new Date().toISOString()
    });
  }catch(e){
    // Se tabela não existe ainda, apenas confirma visualmente
    console.log('teses_investimento não configurada ainda — salvando localmente');
  }

  msg.className='form-msg form-ok';msg.style.display='block';
  msg.innerHTML='✓ Cadastro recebido! Entraremos em contato em até 48h com oportunidades compatíveis com seu perfil.';
  btn.textContent='Cadastro enviado ✓';
}
</script>
</body>
</html>
