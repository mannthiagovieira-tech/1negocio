function toggleSection(id){
  const section = document.getElementById(id);
  const content = section.querySelector('.section-content');
  const toggle = section.querySelector('.section-toggle');
  content.classList.toggle('collapsed');
  toggle.classList.toggle('collapsed');
}

function toggleDRE(mode){
  window.dreMode = mode;
  document.querySelectorAll('.dre-toggle-btn').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
  document.querySelectorAll('.dre-val.empresa[data-anual]').forEach(el => {
    const val = parseFloat(el.dataset[mode]);
    el.textContent = fmt(val);
  });
}

function calcularISE(D){
  const p1 = D.p1 || 5;
  const p2 = D.p2 || 5;
  const p3 = D.p3 || 5;
  const p4 = D.p4 || 5;
  const p5 = D.p5 || 5;
  const p6 = D.p6 || 5;
  const p7 = D.p7 || 5;
  const p8 = D.p8 || 5;
  
  let score = (p1*0.18 + p2*0.15 + p3*0.15 + p4*0.10 + p5*0.10 + p6*0.10 + p7*0.08 + p8*0.05) * 10;
  if(p1 < 3 && p2 < 3) score = Math.min(score, 40);
  
  return Math.round(score);
}

// ICD — Indice de Confianca dos Dados
function calcularICD(D){
  const CAMPOS_DESEJAVEIS = [
    { campo: 'impostos_pagos_mes', nome: 'Impostos pagos', benchmark: 'Estimado pela faixa do Simples' },
    { campo: 'cmv', nome: 'CMV / Custo de mercadoria', benchmark: 'Benchmark setorial' },
    { campo: 'folha_total', nome: 'Folha de pessoal', benchmark: 'Benchmark setorial' },
    { campo: 'aluguel', nome: 'Aluguel', benchmark: '6% do faturamento' },
    { campo: 'prolabore', nome: 'Pro-labore', benchmark: '1 salario minimo por socio' },
    { campo: 'reputacao', nome: 'Reputacao/marca', benchmark: 'Neutro (boa)' },
    { campo: 'processos', nome: 'Processos documentados', benchmark: 'Parcial' },
    { campo: 'usa_erp', nome: 'Sistema de gestao', benchmark: 'Nao utiliza' },
    { campo: 'ativo_caixa', nome: 'Caixa disponivel', benchmark: 'R$ 0' },
    { campo: 'passivo_emprestimos', nome: 'Dividas', benchmark: 'R$ 0' },
    { campo: 'processos_juridicos', nome: 'Processos juridicos', benchmark: 'Nao possui' },
    { campo: 'crescimento', nome: 'Crescimento YoY', benchmark: 'Estavel' },
    { campo: 'concentracao_clientes', nome: 'Concentracao de clientes', benchmark: '30%' },
    { campo: 'recorrencia', nome: 'Receita recorrente', benchmark: '0%' },
    { campo: 'dependencia', nome: 'Socio-dependencia', benchmark: 'Parcial' },
  ];
  
  let preenchidos = 0;
  let camposBenchmark = [];
  let camposPreenchidos = [];
  
  CAMPOS_DESEJAVEIS.forEach(item => {
    const val = D[item.campo];
    const camposZeroValido = ['ativo_caixa', 'passivo_emprestimos'];
    let foiPreenchido = false;
    
    if(val !== undefined && val !== null && val !== '') {
      if(camposZeroValido.includes(item.campo)) {
        foiPreenchido = true;
      } else {
        foiPreenchido = !!val;
      }
    }
    
    if(foiPreenchido) {
      preenchidos++;
      camposPreenchidos.push(item.nome);
    } else {
      camposBenchmark.push({ nome: item.nome, benchmark: item.benchmark });
    }
  });
  
  const total = CAMPOS_DESEJAVEIS.length;
  const pct = Math.round((preenchidos / total) * 100);
  
  let classificacao = 'Opaco';
  if(pct >= 90) classificacao = 'Transparente';
  else if(pct >= 70) classificacao = 'Adequado';
  else if(pct >= 50) classificacao = 'Parcial';
  
  return { pct, preenchidos, total, classificacao, camposBenchmark, camposPreenchidos };
}

function mapSetorToTipo(setor){
  const map = {
    'alimentacao':'alimentacao','varejo':'varejo','industria':'industria',
    'servicos_empresas':'servico_projeto','servicos_locais':'servico_mao_obra',
    'hospedagem':'hospedagem','tech_saas':'plataformas','outro':'outro'
  };
  return map[setor] || 'outro';
}

function formatarSetor(setor){
  const map = {
    'alimentacao':'Alimentacao','varejo':'Varejo','saude':'Saude',
    'beleza_estetica':'Beleza e Estetica','educacao':'Educacao',
    'servicos_locais':'Servicos Locais','servicos_empresas':'Servicos B2B',
    'bem_estar':'Bem-estar','hospedagem':'Hospedagem','industria':'Industria',
    'construcao':'Construcao','tech_saas':'Tecnologia/SaaS','outro':'Outros'
  };
  return map[setor] || setor || 'Negocio';
}

function calcularAcoes(D, fat, cmvPct, folhaPct, aluguelPct, mo, bench, ebitda, passivos, parcelas, fator1N, ise){
  const acoes = [];
  
  if(cmvPct > bench.cmv * 1.05){
    const economia = fat * (cmvPct - bench.cmv) * 0.5;
    acoes.push({
      titulo: 'Reducao de custo de mercadoria',
      descricao: 'Renegociar fornecedores, revisar mix de produtos, auditar perdas e desperdicios.',
      ganhoAnual: economia,
      impactoValuation: economia * fator1N,
      grupo: 'DRE'
    });
  }
  
  if(folhaPct > bench.folha * 1.1){
    const economia = fat * (folhaPct - bench.folha) * 0.4;
    acoes.push({
      titulo: 'Otimizacao de equipe',
      descricao: 'Revisar estrutura de cargos, eliminar redundancias, automacao de processos.',
      ganhoAnual: economia,
      impactoValuation: economia * fator1N,
      grupo: 'DRE'
    });
  }
  
  if(aluguelPct > 0.06){
    const economia = fat * (aluguelPct - 0.05) * 0.5;
    acoes.push({
      titulo: 'Renegociacao de aluguel',
      descricao: 'Renegociar contrato ou avaliar mudanca para local mais eficiente.',
      ganhoAnual: economia,
      impactoValuation: economia * fator1N,
      grupo: 'DRE'
    });
  }
  
  if(D.regime_tributario === 'simples' && fat > 900000){
    const economia = fat * 0.012;
    acoes.push({
      titulo: 'Migracao de regime tributario',
      descricao: 'Avaliar migracao para Lucro Presumido - faturamento acima do limite ideal do Simples.',
      ganhoAnual: economia,
      impactoValuation: economia * fator1N,
      grupo: 'Tributario'
    });
  }
  
  if(D.dependencia === 'dependente' || D.p5 <= 3){
    const ganho = ebitda * 0.1;
    acoes.push({
      titulo: 'Reducao de socio-dependencia',
      descricao: 'Desenvolver gestor de segundo nivel, documentar processos criticos, delegar operacao.',
      ganhoAnual: ganho,
      impactoValuation: ebitda * 0.15 * fator1N,
      grupo: 'ISE'
    });
  }
  
  if(D.processos === 'nao' || D.p4 <= 3){
    acoes.push({
      titulo: 'Documentacao de processos',
      descricao: 'Mapear e documentar os 5 processos mais criticos: vendas, operacao, financeiro, RH, atendimento.',
      ganhoAnual: fat * 0.02,
      impactoValuation: ebitda * 0.1 * fator1N,
      grupo: 'ISE'
    });
  }
  
  const dividaRO = passivos / ebitda;
  if(dividaRO > 2){
    const economia = parcelas * 12 * 0.15;
    acoes.push({
      titulo: 'Reestruturacao de dividas',
      descricao: 'Portabilidade para taxas menores, renegociacao de parcelas, amortizacao antecipada.',
      ganhoAnual: economia,
      impactoValuation: economia * fator1N,
      grupo: 'BP'
    });
  }
  
  if(!D.canais || D.canais.length <= 1){
    const ganho = fat * 0.05;
    acoes.push({
      titulo: 'Expansao de canais de venda',
      descricao: 'Desenvolver presenca digital, e-commerce, delivery, novos pontos de contato.',
      ganhoAnual: ganho,
      impactoValuation: ganho * fator1N,
      grupo: 'Comercial'
    });
  }
  
  if(D.concentracao_clientes === 'alta'){
    const ganho = fat * 0.08;
    acoes.push({
      titulo: 'Diversificacao de carteira',
      descricao: 'Reduzir dependencia dos maiores clientes, prospectar novos segmentos.',
      ganhoAnual: ganho,
      impactoValuation: ganho * fator1N,
      grupo: 'Comercial'
    });
  }
  
  if(D.recorrencia === 'nenhuma' || D.recorrencia === 'baixa'){
    const ganho = fat * 0.12;
    acoes.push({
      titulo: 'Modelo de recorrencia',
      descricao: 'Criar planos de assinatura, contratos mensais, programas de fidelidade.',
      ganhoAnual: ganho,
      impactoValuation: ganho * fator1N * 1.2,
      grupo: 'Comercial'
    });
  }
  
  if(mo < 0.10){
    const ganho = fat * 0.03;
    acoes.push({
      titulo: 'Repricing de produtos/servicos',
      descricao: 'Analise de elasticidade de preco, reposicionamento de ofertas deficitarias.',
      ganhoAnual: ganho,
      impactoValuation: ganho * fator1N,
      grupo: 'DRE'
    });
  }
  
  if(D.crescimento === 'queda' || D.crescimento === 'caiu_mais'){
    const ganho = fat * 0.05;
    acoes.push({
      titulo: 'Plano de retomada de crescimento',
      descricao: 'Diagnostico de causa-raiz, revisao de oferta, expansao de canais de aquisicao.',
      ganhoAnual: ganho,
      impactoValuation: ganho * fator1N,
      grupo: 'Comercial'
    });
  }
  
  if(D.marca_registrada === 'nao'){
    acoes.push({
      titulo: 'Registro de marca no INPI',
      descricao: 'Proteger a marca aumenta valor percebido e seguranca juridica.',
      ganhoAnual: 0,
      impactoValuation: ebitda * 0.05 * fator1N,
      grupo: 'ISE'
    });
  }
  
  if(D.usa_erp === 'nao'){
    const ganho = fat * 0.02;
    acoes.push({
      titulo: 'Implantacao de ERP/gestao',
      descricao: 'Sistema de gestao integrado para controle financeiro, estoque e vendas.',
      ganhoAnual: ganho,
      impactoValuation: ganho * fator1N,
      grupo: 'ISE'
    });
  }
  
  acoes.push({
    titulo: 'Investimento em marketing digital',
    descricao: 'Estrategia de conteudo, midia paga, presenca em redes sociais.',
    ganhoAnual: fat * 0.03,
    impactoValuation: fat * 0.03 * fator1N,
    grupo: 'Comercial'
  });
  
  acoes.push({
    titulo: 'Automacao de processos repetitivos',
    descricao: 'Identificar tarefas manuais que podem ser automatizadas.',
    ganhoAnual: fat * 0.015,
    impactoValuation: fat * 0.015 * fator1N,
    grupo: 'Operacional'
  });
  
  acoes.push({
    titulo: 'Programa de capacitacao',
    descricao: 'Treinamento continuo da equipe para aumentar produtividade.',
    ganhoAnual: fat * 0.01,
    impactoValuation: fat * 0.01 * fator1N,
    grupo: 'RH'
  });
  
  acoes.push({
    titulo: 'Otimizacao de estoque',
    descricao: 'Liquidacao de itens parados, politica de compras minimas.',
    ganhoAnual: fat * 0.008,
    impactoValuation: fat * 0.008 * fator1N,
    grupo: 'BP'
  });
  
  acoes.push({
    titulo: 'Precificacao dinamica',
    descricao: 'Ajuste de precos por demanda, horario ou canal de venda.',
    ganhoAnual: fat * 0.025,
    impactoValuation: fat * 0.025 * fator1N,
    grupo: 'Comercial'
  });
  
  acoes.push({
    titulo: 'Programa de NPS e retencao',
    descricao: 'Medir satisfacao, reduzir churn, aumentar lifetime value.',
    ganhoAnual: fat * 0.02,
    impactoValuation: fat * 0.02 * fator1N,
    grupo: 'Comercial'
  });
  
  acoes.sort((a,b) => b.impactoValuation - a.impactoValuation);
  
  return acoes;
}

function renderDRECompleta(fat, cmv, folha, aluguel, desp, imp, ebitda, lucro, bench){
  const rows = [
    {label:'Faturamento bruto', val:fat, bench:fat, dest:true},
    {label:'(-) Impostos s/ faturamento', val:imp, bench:fat*bench.impostos},
    {label:'(=) Receita liquida', val:fat-imp, bench:fat*(1-bench.impostos), dest:true},
    {label:'(-) CMV', val:cmv, bench:fat*bench.cmv},
    {label:'(=) Lucro bruto', val:fat-imp-cmv, bench:fat*(1-bench.impostos-bench.cmv), dest:true},
    {label:'(-) Folha de pessoal', val:folha, bench:fat*bench.folha},
    {label:'(-) Aluguel', val:aluguel, bench:fat*bench.aluguel},
    {label:'(-) Outras despesas', val:desp, bench:desp},
    {label:'(=) Resultado Operacional', val:ebitda, bench:fat*bench.ro, dest:true}
  ];
  
  return rows.map(r => {
    const diff = (r.val - r.bench) / r.bench;
    const diffClass = Math.abs(diff) < 0.05 ? 'neutral' : diff > 0 ? (r.dest ? 'up' : 'down') : (r.dest ? 'down' : 'up');
    const diffLabel = Math.abs(diff) < 0.02 ? '' : (diff > 0 ? '+' : '') + (diff*100).toFixed(0) + '%';
    return `
      <div class="dre-row ${r.dest?'destaque':''}">
        <span class="dre-label">${r.label}</span>
        <span class="dre-val empresa" data-anual="${r.val}" data-mensal="${r.val/12}">${fmt(r.val/12)}</span>
        <span class="dre-val mercado">${fmt(r.bench/12)}</span>
        <span class="dre-diff ${diffClass}">${diffLabel}</span>
      </div>`;
  }).join('');
}

function renderAcoesISE(pilares, fat, fator1N){
  const acoes = [];
  pilares.forEach(p => {
    if(p.val <= 5){
      let acao = '';
      switch(p.nome){
        case 'Result.': acao = 'Aumentar margem operacional via repricing ou reducao de custos'; break;
        case 'Cresc.': acao = 'Implementar estrategia de crescimento com novos canais'; break;
        case 'Canais': acao = 'Diversificar canais de venda e aquisicao'; break;
        case 'Gestao': acao = 'Documentar processos e criar organograma formal'; break;
        case 'Indep.': acao = 'Desenvolver gestor autonomo e delegar operacao'; break;
        case 'Risco': acao = 'Regularizar pendencias juridicas e trabalhistas'; break;
        case 'Marca': acao = 'Fortalecer presenca digital e registrar marca'; break;
        case 'Tech': acao = 'Implantar ERP e ferramentas de gestao'; break;
      }
      if(acao) acoes.push({pilar: p.nome, acao, impacto: '+2 pts'});
    }
  });
  
  if(acoes.length === 0) return '<div style="font-size:12px;color:var(--ink3)">Todos os pilares estao saudaveis.</div>';
  
  return acoes.map(a => `
    <div class="ise-acao-item">
      <span class="ise-acao-pilar">${a.pilar}</span>
      <span class="ise-acao-texto">${a.acao}</span>
      <span class="ise-acao-impacto">${a.impacto}</span>
    </div>
  `).join('');
}

function renderAcoesDRE(cmvPct, folhaPct, aluguelPct, bench, fat, fator1N){
  const acoes = [];
  
  if(cmvPct > bench.cmv * 1.05){
    acoes.push({linha:'CMV', acao:'Renegociar fornecedores, auditar perdas', ganho:fat*(cmvPct-bench.cmv)*0.5});
  }
  if(folhaPct > bench.folha * 1.1){
    acoes.push({linha:'Folha', acao:'Revisar estrutura, automacao de processos', ganho:fat*(folhaPct-bench.folha)*0.4});
  }
  if(aluguelPct > 0.06){
    acoes.push({linha:'Aluguel', acao:'Renegociar contrato ou avaliar mudanca', ganho:fat*(aluguelPct-0.05)*0.5});
  }
  
  if(acoes.length === 0) return '<div style="font-size:12px;color:var(--ink3)">DRE alinhada com benchmarks do mercado.</div>';
  
  return `
    <div style="font-size:11px;color:var(--pu);margin-bottom:12px;display:flex;align-items:center;gap:6px">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
      </svg>
      ACOES 1SOCIO
    </div>
    ${acoes.map(a => `
      <div class="ise-acao-item">
        <span class="ise-acao-pilar">${a.linha}</span>
        <span class="ise-acao-texto">${a.acao}</span>
        <span class="ise-acao-impacto">+${fmt(a.ganho)}/ano</span>
      </div>
    `).join('')}
  `;
}

function renderAcoesBP(D, ebitda, passivos, fator1N){
  const dividaRO = passivos / ebitda;
  const comprometimento = (D.parcelas_mensais||0) / (ebitda/12);
  
  if(dividaRO <= 2 && comprometimento <= 0.3) return '';
  
  let html = '<div style="margin-top:20px;padding-top:20px;border-top:1px solid var(--line)">';
  html += '<div style="font-size:11px;color:var(--pu);margin-bottom:12px;display:flex;align-items:center;gap:6px"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>REESTRUTURACAO 1SOCIO</div>';
  
  if(dividaRO > 2){
    html += `<div class="ise-acao-item"><span class="ise-acao-pilar">Divida/RO</span><span class="ise-acao-texto">Indice de ${dividaRO.toFixed(1)}x - considerar portabilidade ou renegociacao</span><span class="ise-acao-impacto" style="color:var(--am)">${dividaRO.toFixed(1)}x</span></div>`;
  }
  if(comprometimento > 0.3){
    html += `<div class="ise-acao-item"><span class="ise-acao-pilar">Caixa</span><span class="ise-acao-texto">${(comprometimento*100).toFixed(0)}% do resultado comprometido com parcelas</span><span class="ise-acao-impacto" style="color:var(--am)">${(comprometimento*100).toFixed(0)}%</span></div>`;
  }
  
  return html + '</div>';
}

function simularTributario(fat, regimeAtual){
  const regimes = [
    {nome:'MEI', aliq:0.016, limite:80000},
    {nome:'Simples', aliq: fat<=180000?0.06:fat<=360000?0.112:fat<=720000?0.135:fat<=1800000?0.16:0.21, limite:4800000},
    {nome:'Presumido', aliq:0.068, limite:78000000},
    {nome:'Real', aliq:0.088, limite:999999999}
  ];
  
  const resultado = regimes.map(r => {
    const aplicavel = fat <= r.limite;
    const imposto = aplicavel ? fat * r.aliq : null;
    const atual = (regimeAtual==='mei'&&r.nome==='MEI')||(regimeAtual==='simples'&&r.nome==='Simples')||(regimeAtual==='presumido'&&r.nome==='Presumido')||(regimeAtual==='real'&&r.nome==='Real');
    return {...r, imposto, atual, aplicavel};
  }).filter(r => r.aplicavel);
  
  const melhor = resultado.reduce((min, r) => r.imposto < min.imposto ? r : min, resultado[0]);
  resultado.forEach(r => r.melhor = r === melhor);
  
  const atual = resultado.find(r => r.atual) || resultado[0];
  const economia = atual.imposto - melhor.imposto;
  
  return {
    regimes: resultado,
    economia: Math.max(0, economia),
    recomendacao: economia > fat*0.01 ? `Migrar para ${melhor.nome} pode gerar economia significativa` : 'Regime atual esta otimizado'
  };
}

function calcularIndicadores(D, fat, ebitda, valorVenda, ativos, passivos, cmv, folha, bench){
  const indicadores = [];
  
  const pmr = D.contas_receber ? (D.contas_receber/(fat/365)).toFixed(0) : '?';
  indicadores.push({nome:'PMR', valor:pmr+' dias', bench:'Ideal: ate 30 dias', status:pmr<=30?'verde':pmr<=60?'amarelo':'vermelho', acao:pmr>45?'Regua de cobranca':null});
  
  const cobertura = D.ativo_caixa ? (D.ativo_caixa/(ebitda/12)).toFixed(1) : '?';
  indicadores.push({nome:'Cobertura caixa', valor:cobertura+' meses', bench:'Ideal: 3+ meses', status:cobertura>=3?'verde':cobertura>=1?'amarelo':'vermelho', acao:cobertura<2?'Construir reserva':null});
  
  const dividaRO = passivos > 0 ? (passivos/ebitda).toFixed(1) : '0';
  indicadores.push({nome:'Divida / RO', valor:dividaRO+'x', bench:'Ideal: ate 2x', status:dividaRO<=1?'verde':dividaRO<=2?'amarelo':'vermelho', acao:dividaRO>2?'Reestruturar':null});
  
  const roi = ((ebitda/valorVenda)*100).toFixed(0);
  indicadores.push({nome:'ROI anual', valor:roi+'%', bench:'sobre valor de venda', status:roi>=25?'verde':roi>=15?'amarelo':'vermelho', acao:null});
  
  const payback = (valorVenda/ebitda).toFixed(1);
  indicadores.push({nome:'Payback', valor:payback+' anos', bench:'Ideal: ate 4 anos', status:payback<=3?'verde':payback<=6?'amarelo':'vermelho', acao:null});
  
  const liquidez = passivos > 0 ? (ativos/passivos).toFixed(1) : '999';
  indicadores.push({nome:'Liquidez', valor:liquidez+'x', bench:'Ideal: 1.5x+', status:liquidez>=1.5?'verde':liquidez>=1?'amarelo':'vermelho', acao:liquidez<1?'Risco de insolvencia':null});
  
  const margemOp = ((ebitda/fat)*100).toFixed(1);
  indicadores.push({nome:'Margem operacional', valor:margemOp+'%', bench:`Mercado: ${(bench.ro*100).toFixed(0)}%`, status:ebitda/fat>=bench.ro?'verde':ebitda/fat>=bench.ro*0.7?'amarelo':'vermelho', acao:null});
  
  const cmvPct = ((cmv/fat)*100).toFixed(1);
  indicadores.push({nome:'CMV', valor:cmvPct+'%', bench:`Mercado: ${(bench.cmv*100).toFixed(0)}%`, status:cmv/fat<=bench.cmv?'verde':cmv/fat<=bench.cmv*1.2?'amarelo':'vermelho', acao:null});
  
  const folhaPct = ((folha/fat)*100).toFixed(1);
  indicadores.push({nome:'Pessoal', valor:folhaPct+'%', bench:`Mercado: ${(bench.folha*100).toFixed(0)}%`, status:folha/fat<=bench.folha?'verde':folha/fat<=bench.folha*1.2?'amarelo':'vermelho', acao:null});
  
  return indicadores;
}

function gerarTeseInvestimento(D, setor, fat, ebitda, valorVenda, ise, top10, valoracao){
  const roi = (ebitda/valorVenda*100).toFixed(0);
  const payback = (valorVenda/ebitda).toFixed(1);
  const upside = (valoracao/valorVenda*100).toFixed(0);
  
  return `
    Negocio estabelecido no segmento de ${setor.toLowerCase()}, com ${D.tempo_operacao||'alguns'} anos de 
    operacao e faturamento anual de ${fmt(fat)}. O ISE de ${ise}/100 indica estrutura 
    ${ise>=70?'consolidada':ise>=50?'operacional':'em desenvolvimento'}, 
    com oportunidades claras de melhoria.
    <br><br>
    <strong>Retorno:</strong> ROI de ${roi}% ao ano, com payback em ${payback} anos - 
    ${roi>=25?'acima':roi>=15?'dentro':'abaixo'} da media de mercado para o setor.
    <br><br>
    <strong>Upside:</strong> Uma acao prioritaria de crescimento comercial + 10 acoes de melhoria identificadas podem gerar valorizacao 
    de +${upside}% em 12 meses, elevando o valor de ${fmt(valorVenda)} para ${fmt(valorVenda+valoracao)}.
    <br><br>
    <strong>Perfil ideal do comprador:</strong> 
    ${ise>=70?'Investidor buscando negocio estavel com retorno previsivel':
      ise>=50?'Operador experiente que pode capturar upside operacional':
      'Empreendedor disposto a estruturar o negocio e capturar valorizacao'}.
  `;
}

function gerarDescricaoTeaser(D, setor, fat, ise){
  return `
    Empresa do segmento de ${setor.toLowerCase()} localizada em ${D.cidade||'Brasil'}${D.estado?'/'+D.estado:''}, 
    com ${D.tempo_operacao||'alguns'} anos de operacao consolidada. 
    ${D.funcionarios_clt?`Equipe de ${(D.funcionarios_clt||0)+(D.funcionarios_pj||0)} colaboradores.`:''}
    ${D.num_clientes?`Base de ${D.num_clientes.toLocaleString('pt-BR')} clientes ativos.`:''}
    Estrutura ${ise>=70?'consolidada e profissionalizada':ise>=50?'operacional com oportunidades de melhoria':'em fase de desenvolvimento'}.
    Negocio pronto para transicao de gestao.
  `;
}

function gerarAcaoZero(D){
  const crescimento = D.crescimento || 'estavel';
  const capacidade = D.capacidade_ociosa || D.capacidade_crescimento || 30;
  const temBase = D.num_clientes && D.num_clientes > 50;
  const recorrencia = D.recorrencia || 'baixa';
  
  let contexto = '';
  if(crescimento === 'queda' || crescimento === 'caiu_mais'){
    contexto = 'O negocio esta em queda - prioridade absoluta e reverter a tendencia antes de qualquer outra acao.';
  } else if(crescimento === 'estavel'){
    contexto = 'O negocio esta estavel - ha espaco para acelerar sem adicionar estrutura.';
  } else {
    contexto = 'O negocio ja esta crescendo - o desafio e manter o ritmo e capturar mais margem.';
  }
  
  let acoes = [];
  
  if(temBase){
    acoes.push('Ativar a base de clientes existente com campanhas de recompra e upsell');
  } else {
    acoes.push('Iniciar captura sistematica de dados de clientes (WhatsApp, email) para criar base acionavel');
  }
  
  if(recorrencia === 'nenhuma' || recorrencia === 'baixa'){
    acoes.push('Criar modelo de recorrencia ou fidelidade para aumentar frequencia de compra');
  }
  
  acoes.push('Otimizar verbas de marketing ja investidas - medir ROI por canal e realocar para os mais eficientes');
  acoes.push('Explorar capacidade ociosa da estrutura atual (' + capacidade + '% de margem para crescer sem custo fixo adicional)');
  
  return `<strong>${contexto}</strong><br><br>
    Oportunidades imediatas:<br>
    - ${acoes.join('<br>- ')}`;
}

init();
</script>
</body>
</html>
