<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Laudo Completo · 1Negócio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&family=Cabinet+Grotesk:wght@400;500;700;800;900&display=swap" rel="stylesheet">
<style>
@media print {
  body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  .page-break { page-break-before: always; }
  .no-print { display: none !important; }
}
:root{
  --bg:#080d0a;--bg1:#0e1510;--bg2:#131a14;--bg3:#1a2218;
  --em:#3dff7a;--em-d:rgba(61,255,122,.08);--em-l:rgba(61,255,122,.25);
  --am:#ffb03a;--am-d:rgba(255,176,58,.10);--am-l:rgba(255,176,58,.25);
  --rd:#ff5c5c;--rd-d:rgba(255,92,92,.08);--rd-l:rgba(255,92,92,.25);
  --pu:#a78bfa;--pu-d:rgba(167,139,250,.08);--pu-l:rgba(167,139,250,.25);
  --ink:#f0f5f1;--ink2:#a8b8ac;--ink3:#5a7060;--ink4:#3a4e3e;
  --line:rgba(255,255,255,.05);--line2:rgba(255,255,255,.10);
  --r:8px;--r2:14px;--r3:20px;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{min-height:100vh;background:var(--bg);color:var(--ink);
  font-family:'Cabinet Grotesk',sans-serif}

/* ── PAGE ── */
.page{position:relative;min-height:100vh;padding:40px 24px}
.container{max-width:800px;margin:0 auto}

/* ── CAPA ── */
.capa{min-height:100vh;display:flex;flex-direction:column;justify-content:center;
  align-items:center;text-align:center;padding:40px 20px}
.capa-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:28px;
  letter-spacing:-.02em;margin-bottom:60px}
.capa-logo em{color:var(--em);font-style:normal}
.capa-tipo{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.2em;
  text-transform:uppercase;color:var(--em);margin-bottom:16px;
  padding:8px 20px;border:1px solid var(--em-l);border-radius:30px}
.capa-titulo{font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(32px,8vw,48px);
  line-height:1.1;letter-spacing:-.03em;margin-bottom:16px}
.capa-setor{font-family:'DM Mono',monospace;font-size:12px;letter-spacing:.12em;
  text-transform:uppercase;color:var(--ink3);margin-bottom:8px}
.capa-local{font-size:16px;color:var(--ink3);margin-bottom:60px}
.capa-data{font-family:'DM Mono',monospace;font-size:11px;color:var(--ink4)}
.capa-validade{font-size:12px;color:var(--ink4);margin-top:8px}

/* ── SECTION ── */
.section{margin-bottom:40px}
.section-head{display:flex;align-items:center;gap:12px;margin-bottom:20px;cursor:pointer}
.section-title{font-family:'Syne',sans-serif;font-weight:700;font-size:18px;color:var(--ink)}
.section-line{flex:1;height:1px;background:var(--line2)}
.section-toggle{width:24px;height:24px;border-radius:50%;background:var(--bg2);
  border:1px solid var(--line2);display:flex;align-items:center;justify-content:center;
  color:var(--ink3);font-size:12px;transition:transform .2s}
.section-toggle.collapsed{transform:rotate(-90deg)}
.section-content{overflow:hidden;transition:max-height .3s ease}
.section-content.collapsed{max-height:0 !important}

/* ── SUMARIO ── */
.sumario{background:var(--bg1);border:1px solid var(--line2);border-radius:var(--r2);padding:24px}
.sumario-title{font-family:'Syne',sans-serif;font-weight:700;font-size:16px;margin-bottom:16px}
.sumario-list{list-style:none}
.sumario-item{display:flex;justify-content:space-between;padding:10px 0;
  border-bottom:1px solid var(--line);font-size:14px}
.sumario-item:last-child{border-bottom:none}
.sumario-item span:first-child{color:var(--ink2)}
.sumario-item span:last-child{font-family:'DM Mono',monospace;color:var(--ink4)}
.sumario-item.highlight{background:var(--pu-d);margin:0 -24px;padding:10px 24px;border-color:var(--pu-l)}
.sumario-item.highlight span:first-child{color:var(--pu)}

/* ── VALOR DESTAQUE ── */
.valor-destaque{text-align:center;padding:40px 24px;margin-bottom:32px;
  background:linear-gradient(180deg,var(--em-d) 0%,var(--bg1) 100%);
  border:1px solid var(--em-l);border-radius:var(--r3)}
.valor-destaque-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.16em;
  text-transform:uppercase;color:var(--em);margin-bottom:12px}
.valor-destaque-num{font-family:'Syne',sans-serif;font-weight:800;
  font-size:clamp(48px,12vw,64px);line-height:1;letter-spacing:-.03em;color:var(--ink)}
.valor-destaque-sub{font-size:14px;color:var(--ink3);margin-top:12px}

/* ── TERMÔMETRO ── */
.termo-card{background:var(--bg1);border:1px solid var(--line2);border-radius:var(--r2);padding:32px}
.termo-bar{position:relative;height:10px;background:var(--bg3);border-radius:5px;margin:60px 0 80px}
.termo-fill{position:absolute;left:0;top:0;height:100%;border-radius:5px;
  background:linear-gradient(90deg,var(--ink4) 0%,var(--em) 50%,var(--pu) 100%)}
.termo-marker{position:absolute;top:-50px;transform:translateX(-50%)}
.termo-marker-line{width:2px;height:60px;margin:0 auto;border-radius:1px}
.termo-marker.expectativa .termo-marker-line{background:var(--ink3)}
.termo-marker.avaliacao .termo-marker-line{background:var(--em)}
.termo-marker.potencial .termo-marker-line{background:var(--pu)}
.termo-marker-label{text-align:center;font-size:11px;color:var(--ink3);margin-top:8px;white-space:nowrap}
.termo-marker-label strong{display:block;font-family:'DM Mono',monospace;font-size:12px;margin-top:4px}
.termo-marker.expectativa .termo-marker-label strong{color:var(--ink3)}
.termo-marker.avaliacao .termo-marker-label strong{color:var(--em)}
.termo-marker.potencial .termo-marker-label strong{color:var(--pu)}
.termo-legend{display:flex;justify-content:center;gap:24px;flex-wrap:wrap}
.termo-leg-item{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--ink3)}
.termo-leg-item .dot{width:10px;height:10px;border-radius:50%}
.termo-leg-item .dot.gray{background:var(--ink4)}
.termo-leg-item .dot.green{background:var(--em)}
.termo-leg-item .dot.purple{background:var(--pu)}

/* ── ICD — INDICE DE CONFIANCA DOS DADOS ── */
.icd-badge{display:inline-flex;align-items:center;gap:8px;padding:6px 12px;border-radius:20px;
  font-size:11px;font-weight:600;background:var(--bg2);border:1px solid var(--line2)}
.icd-badge .icd-pct{font-family:'DM Mono',monospace;font-size:13px;font-weight:700}
.icd-badge.icd-transparente{background:rgba(61,255,122,0.1);border-color:var(--em);color:var(--em)}
.icd-badge.icd-adequado{background:rgba(167,139,250,0.1);border-color:var(--pu);color:var(--pu)}
.icd-badge.icd-parcial{background:rgba(255,176,58,0.1);border-color:var(--am);color:var(--am)}
.icd-badge.icd-opaco{background:rgba(255,92,92,0.1);border-color:var(--rd);color:var(--rd)}
.icd-card{background:var(--bg1);border:1px solid var(--line2);border-radius:var(--r2);padding:20px;margin-bottom:20px}
.icd-card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.icd-card-title{font-size:12px;font-weight:700;color:var(--ink2);letter-spacing:0.5px}
.icd-bar-wrap{height:8px;background:var(--bg2);border-radius:4px;overflow:hidden;margin-bottom:12px}
.icd-bar-fill{height:100%;border-radius:4px;transition:width 0.5s ease}
.icd-bar-fill.icd-transparente{background:var(--em)}
.icd-bar-fill.icd-adequado{background:var(--pu)}
.icd-bar-fill.icd-parcial{background:var(--am)}
.icd-bar-fill.icd-opaco{background:var(--rd)}
.icd-detail-row{display:flex;align-items:center;gap:8px;padding:6px 0;font-size:11px;border-bottom:1px solid var(--line)}
.icd-detail-row:last-child{border-bottom:none}
.icd-check{color:var(--em);font-weight:700}
.icd-bench{color:var(--am);font-weight:700}
.icd-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.icd-col{background:var(--bg2);border-radius:var(--r);padding:12px}
.icd-col-title{font-size:10px;font-weight:700;margin-bottom:8px;letter-spacing:.08em}

/* ── ISE COCKPIT ── */
.ise-cockpit{background:var(--bg1);border:1px solid var(--line2);border-radius:var(--r2);padding:32px}
.ise-cockpit-center{position:relative;width:220px;height:130px;margin:0 auto 24px}
.ise-gauge{width:100%;height:100%}
.ise-cockpit-num{position:absolute;bottom:15px;left:50%;transform:translateX(-50%);
  font-family:'Syne',sans-serif;font-weight:800;font-size:44px;color:var(--ink)}
.ise-cockpit-label{position:absolute;bottom:-5px;left:50%;transform:translateX(-50%);
  font-family:'DM Mono',monospace;font-size:11px;color:var(--ink4)}
.ise-cockpit-class{text-align:center;margin-bottom:24px}
.ise-class{display:inline-block;padding:8px 18px;border-radius:24px;font-family:'DM Mono',monospace;
  font-size:11px;letter-spacing:.12em;text-transform:uppercase;font-weight:600}
.ise-class.estruturado{background:var(--em-d);color:var(--em);border:1px solid var(--em-l)}
.ise-class.consolidado{background:var(--em-d);color:var(--em);border:1px solid var(--em-l)}
.ise-class.operacional{background:var(--am-d);color:var(--am);border:1px solid var(--am-l)}
.ise-class.dependente{background:var(--am-d);color:var(--am);border:1px solid var(--am-l)}
.ise-class.embrionario{background:var(--rd-d);color:var(--rd);border:1px solid var(--rd-l)}
.ise-cockpit-fator{font-family:'DM Mono',monospace;font-size:12px;color:var(--ink3);margin-top:10px}
.ise-cockpit-fator strong{color:var(--em)}
.ise-pilares-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.ise-pilar-card{background:var(--bg2);border-radius:var(--r);padding:14px;text-align:center}
.ise-pilar-val{font-family:'Syne',sans-serif;font-weight:700;font-size:22px;margin-bottom:4px}
.ise-pilar-val.verde{color:var(--em)}
.ise-pilar-val.amarelo{color:var(--am)}
.ise-pilar-val.vermelho{color:var(--rd)}
.ise-pilar-name{font-size:9px;color:var(--ink4);text-transform:uppercase;letter-spacing:.08em}
.ise-pilar-peso{font-family:'DM Mono',monospace;font-size:8px;color:var(--ink4);margin-top:4px}

/* ── ISE AÇÕES ── */
.ise-acoes{margin-top:20px;padding-top:20px;border-top:1px solid var(--line)}
.ise-acao-item{display:flex;gap:12px;padding:12px 0;border-bottom:1px solid var(--line)}
.ise-acao-item:last-child{border-bottom:none}
.ise-acao-pilar{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.1em;
  text-transform:uppercase;color:var(--pu);min-width:80px}
.ise-acao-texto{font-size:13px;color:var(--ink2);flex:1}
.ise-acao-impacto{font-family:'DM Mono',monospace;font-size:11px;color:var(--pu);text-align:right}

/* ── DRE ── */
.dre-card{background:var(--bg1);border:1px solid var(--line2);border-radius:var(--r2);padding:24px}
.dre-toggle{display:flex;gap:6px;margin-bottom:20px}
.dre-toggle-btn{padding:6px 16px;border:1px solid var(--line2);background:transparent;
  color:var(--ink3);font-size:11px;border-radius:var(--r);cursor:pointer;transition:all .15s}
.dre-toggle-btn.active{background:var(--em-d);border-color:var(--em);color:var(--em)}
.dre-header{display:grid;grid-template-columns:1fr 100px 100px 80px;gap:8px;
  padding-bottom:12px;border-bottom:1px solid var(--line);margin-bottom:8px}
.dre-header span{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.12em;
  text-transform:uppercase;color:var(--ink4)}
.dre-header span:not(:first-child){text-align:right}
.dre-row{display:grid;grid-template-columns:1fr 100px 100px 80px;gap:8px;padding:10px 0;
  border-bottom:1px solid var(--line)}
.dre-row:last-child{border-bottom:none}
.dre-row.destaque{background:var(--em-d);margin:0 -24px;padding:12px 24px;border-radius:0}
.dre-label{font-size:13px;color:var(--ink2)}
.dre-row.destaque .dre-label{color:var(--ink);font-weight:600}
.dre-val{font-family:'DM Mono',monospace;font-size:12px;text-align:right}
.dre-val.empresa{color:var(--ink)}
.dre-val.mercado{color:var(--ink3)}
.dre-row.destaque .dre-val{font-weight:600}
.dre-row.destaque .dre-val.empresa{color:var(--em)}
.dre-diff{display:inline-block;font-size:9px;padding:2px 8px;border-radius:10px;margin-left:6px}
.dre-diff.up{background:var(--em-d);color:var(--em)}
.dre-diff.down{background:var(--rd-d);color:var(--rd)}
.dre-diff.neutral{background:var(--line);color:var(--ink3)}

/* ── DRE AÇÕES ── */
.dre-acoes{margin-top:20px;padding-top:20px;border-top:1px solid var(--line)}

/* ── INDICADORES ── */
.ind-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.ind-card{background:var(--bg1);border:1px solid var(--line2);border-radius:var(--r2);padding:16px}
.ind-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.ind-name{font-size:11px;color:var(--ink3)}
.ind-status{width:10px;height:10px;border-radius:50%}
.ind-status.verde{background:var(--em)}
.ind-status.amarelo{background:var(--am)}
.ind-status.vermelho{background:var(--rd)}
.ind-val{font-family:'Syne',sans-serif;font-weight:700;font-size:20px;color:var(--ink)}
.ind-bench{font-family:'DM Mono',monospace;font-size:10px;color:var(--ink4);margin-top:4px}
.ind-acao{font-size:11px;color:var(--pu);margin-top:8px;padding-top:8px;border-top:1px solid var(--line)}

/* ── BP ── */
.bp-card{background:var(--bg1);border:1px solid var(--line2);border-radius:var(--r2);padding:24px}
.bp-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px}
.bp-col{text-align:center}
.bp-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.12em;
  text-transform:uppercase;color:var(--ink4);margin-bottom:10px}
.bp-val{font-family:'Syne',sans-serif;font-weight:700;font-size:22px}
.bp-val.ativo{color:var(--em)}
.bp-val.passivo{color:var(--rd)}
.bp-val.pl{color:var(--ink)}
.bp-detail{margin-top:12px;font-size:12px;color:var(--ink3)}

/* ── TRIBUTÁRIO ── */
.trib-card{background:var(--bg1);border:1px solid var(--line2);border-radius:var(--r2);padding:24px}
.trib-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px}
.trib-regime{background:var(--bg2);border-radius:var(--r);padding:16px;text-align:center;
  border:2px solid transparent;transition:all .15s}
.trib-regime.atual{border-color:var(--ink3)}
.trib-regime.melhor{border-color:var(--em);background:var(--em-d)}
.trib-regime-nome{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.1em;
  text-transform:uppercase;color:var(--ink4);margin-bottom:8px}
.trib-regime.melhor .trib-regime-nome{color:var(--em)}
.trib-regime-valor{font-family:'Syne',sans-serif;font-weight:700;font-size:18px;color:var(--ink)}
.trib-regime-aliq{font-family:'DM Mono',monospace;font-size:10px;color:var(--ink4);margin-top:4px}
.trib-regime-tag{font-size:9px;margin-top:8px;padding:4px 8px;border-radius:10px}
.trib-regime.atual .trib-regime-tag{background:var(--line);color:var(--ink3)}
.trib-regime.melhor .trib-regime-tag{background:var(--em-d);color:var(--em)}
.trib-resultado{background:var(--bg2);border-radius:var(--r);padding:20px;text-align:center}
.trib-economia-label{font-size:12px;color:var(--ink3);margin-bottom:8px}
.trib-economia-val{font-family:'Syne',sans-serif;font-weight:800;font-size:28px;color:var(--em)}
.trib-economia-sub{font-size:11px;color:var(--ink4);margin-top:4px}

/* ══════════════════════════════════════════════════════════════
   1SÓCIO DESTAQUE - AÇÕES E POTENCIAL
   ══════════════════════════════════════════════════════════════ */

/* ── PLANO DE AÇÃO 1SÓCIO ── */
.plano-card{background:linear-gradient(135deg,var(--pu-d) 0%,var(--bg1) 100%);
  border:1px solid var(--pu-l);border-radius:var(--r3);padding:28px;position:relative;overflow:hidden}
.plano-card::before{content:'';position:absolute;top:-50%;right:-20%;width:300px;height:300px;
  background:radial-gradient(circle,var(--pu-d) 0%,transparent 70%);pointer-events:none}
.plano-header{display:flex;justify-content:space-between;align-items:start;margin-bottom:24px;
  padding-bottom:20px;border-bottom:1px solid var(--pu-l);position:relative}
.plano-badge{display:inline-flex;align-items:center;gap:6px;
  font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.14em;
  text-transform:uppercase;color:var(--pu);background:var(--pu-d);
  padding:6px 12px;border-radius:20px;border:1px solid var(--pu-l);margin-bottom:12px}
.plano-badge svg{width:12px;height:12px}
.plano-titulo{font-family:'Syne',sans-serif;font-weight:700;font-size:18px;color:var(--ink)}
.plano-subtitulo{font-size:12px;color:var(--ink3);margin-top:4px}
.plano-total{text-align:right}
.plano-total-label{font-size:10px;color:var(--ink4);margin-bottom:4px}
.plano-total-val{font-family:'Syne',sans-serif;font-weight:800;font-size:18px;color:var(--pu)}
.plano-total-sub{font-family:'DM Mono',monospace;font-size:10px;color:var(--pu);margin-top:8px;opacity:.8}

/* ── AÇÃO ITEM 1SÓCIO ── */
.acao-item{display:grid;grid-template-columns:36px 1fr 90px 90px;gap:14px;
  padding:16px 0;border-bottom:1px solid var(--line);align-items:start;position:relative}
.acao-item:last-child{border-bottom:none}
.acao-num{width:36px;height:36px;border-radius:50%;
  background:linear-gradient(135deg,var(--pu-d) 0%,var(--bg2) 100%);
  border:1px solid var(--pu-l);
  display:flex;align-items:center;justify-content:center;
  font-family:'Syne',sans-serif;font-weight:700;font-size:14px;color:var(--pu)}
.acao-content{flex:1}
.acao-titulo{font-weight:600;font-size:14px;color:var(--ink);margin-bottom:4px}
.acao-desc{font-size:12px;color:var(--ink3);line-height:1.5}
.acao-grupo{display:inline-block;font-family:'DM Mono',monospace;font-size:8px;
  letter-spacing:.1em;text-transform:uppercase;color:var(--pu);
  background:var(--pu-d);padding:2px 8px;border-radius:10px;margin-top:6px}
.acao-ganho{text-align:right}
.acao-ganho-label{font-size:9px;color:var(--ink4);margin-bottom:2px}
.acao-ganho-val{font-family:'DM Mono',monospace;font-size:13px;color:var(--em)}
.acao-valuation{text-align:right}
.acao-valuation-label{font-size:9px;color:var(--ink4);margin-bottom:2px}
.acao-valuation-val{font-family:'Syne',sans-serif;font-weight:700;font-size:14px;color:var(--pu)}

/* ── CTA 1SÓCIO ── */
.cta-1socio{margin-top:24px;padding:20px;background:var(--pu-d);border:1px solid var(--pu-l);
  border-radius:var(--r2);display:flex;align-items:center;justify-content:space-between;gap:16px}
.cta-1socio-content{}
.cta-1socio-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:16px;color:var(--pu);margin-bottom:4px}
.cta-1socio-logo em{color:var(--ink);font-style:normal}
.cta-1socio-text{font-size:12px;color:var(--ink3)}
.cta-1socio-btn{padding:12px 24px;background:var(--pu);color:var(--bg);
  font-family:'Syne',sans-serif;font-weight:700;font-size:13px;
  border:none;border-radius:var(--r2);cursor:pointer;white-space:nowrap;
  transition:all .15s}
.cta-1socio-btn:hover{background:var(--ink);transform:translateY(-1px)}

/* ── REPOSITÓRIO ── */
.repo-card{background:var(--bg2);border:1px solid var(--line);border-radius:var(--r2);padding:24px}
.repo-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
.repo-titulo{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.14em;
  text-transform:uppercase;color:var(--ink4)}
.repo-potencial{font-family:'DM Mono',monospace;font-size:11px;color:var(--pu)}
.repo-list{display:grid;gap:8px}
.repo-item{display:flex;justify-content:space-between;align-items:center;padding:12px 14px;
  background:var(--bg1);border:1px solid var(--line);border-radius:var(--r);font-size:12px;
  transition:all .15s}
.repo-item:hover{border-color:var(--pu-l);background:var(--pu-d)}
.repo-item-nome{color:var(--ink2)}
.repo-item-ganho{font-family:'DM Mono',monospace;color:var(--pu)}
.repo-note{font-size:11px;color:var(--ink4);margin-top:16px;padding-top:16px;border-top:1px solid var(--line);
  display:flex;align-items:center;gap:8px}
.repo-note svg{width:14px;height:14px;color:var(--pu)}

/* ── TESE DE INVESTIMENTO ── */
.tese-card{background:linear-gradient(135deg,var(--em-d) 0%,var(--bg1) 100%);
  border:1px solid var(--em-l);border-radius:var(--r3);padding:32px}
.tese-titulo{font-family:'Syne',sans-serif;font-weight:700;font-size:18px;margin-bottom:20px}
.tese-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:24px}
.tese-metric{text-align:center}
.tese-metric-val{font-family:'Syne',sans-serif;font-weight:800;font-size:24px;color:var(--em)}
.tese-metric-label{font-size:11px;color:var(--ink3);margin-top:4px}
.tese-upside{background:var(--pu-d);border:1px solid var(--pu-l);border-radius:var(--r);
  padding:16px;text-align:center;margin-bottom:20px}
.tese-upside-val{font-family:'Syne',sans-serif;font-weight:800;font-size:28px;color:var(--pu)}
.tese-upside-label{font-size:11px;color:var(--pu);margin-top:4px}
.tese-texto{font-size:14px;line-height:1.8;color:var(--ink2)}

/* ── TEASER EXECUTIVO ── */
.teaser-card{background:var(--bg1);border:1px solid var(--line2);border-radius:var(--r2);padding:32px}
.teaser-header{display:flex;justify-content:space-between;align-items:start;margin-bottom:24px;
  padding-bottom:20px;border-bottom:1px solid var(--line)}
.teaser-info{}
.teaser-setor{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.14em;
  text-transform:uppercase;color:var(--ink4);margin-bottom:8px}
.teaser-titulo{font-family:'Syne',sans-serif;font-weight:700;font-size:22px}
.teaser-valor{text-align:right}
.teaser-valor-label{font-size:10px;color:var(--ink4);margin-bottom:4px}
.teaser-valor-num{font-family:'Syne',sans-serif;font-weight:800;font-size:24px;color:var(--em)}
.teaser-section{margin-bottom:20px}
.teaser-section-title{font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.14em;
  text-transform:uppercase;color:var(--ink4);margin-bottom:10px}
.teaser-text{font-size:13px;line-height:1.7;color:var(--ink2)}
.teaser-highlights{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}
.teaser-highlight{background:var(--bg2);border-radius:var(--r);padding:14px}
.teaser-highlight-val{font-family:'Syne',sans-serif;font-weight:700;font-size:18px;color:var(--ink)}
.teaser-highlight-label{font-size:11px;color:var(--ink3);margin-top:4px}
.teaser-upside{background:var(--pu-d);border:1px solid var(--pu-l);border-radius:var(--r);padding:14px}
.teaser-upside .teaser-highlight-val{color:var(--pu)}
.teaser-upside .teaser-highlight-label{color:var(--pu)}

/* ── CÁLCULO ── */
.calc-card{background:var(--bg2);border:1px solid var(--line);border-radius:var(--r2);
  padding:24px;font-family:'DM Mono',monospace}
.calc-row{display:flex;justify-content:space-between;padding:8px 0;font-size:13px;color:var(--ink2)}
.calc-row.total{border-top:1px solid var(--line);padding-top:14px;margin-top:8px;
  font-weight:600;font-size:15px;color:var(--em)}

/* ── FOOTER ── */
.laudo-footer{margin-top:60px;padding-top:32px;border-top:1px solid var(--line);text-align:center}
.footer-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:18px;margin-bottom:12px}
.footer-logo em{color:var(--em);font-style:normal}
.footer-text{font-size:12px;color:var(--ink4);line-height:1.6}
.footer-disclaimer{font-size:10px;color:var(--ink4);margin-top:20px;padding:16px;
  background:var(--bg1);border-radius:var(--r)}

/* ── LOADING ── */
.loading{display:flex;flex-direction:column;align-items:center;justify-content:center;
  min-height:60vh;gap:16px}
.loading-spinner{width:40px;height:40px;border:2px solid var(--line2);
  border-top-color:var(--em);border-radius:50%;animation:spin 1s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-text{font-family:'DM Mono',monospace;font-size:11px;color:var(--ink3)}

/* ── RESPONSIVE ── */
@media(max-width:640px){
  .trib-grid{grid-template-columns:repeat(2,1fr)}
  .ind-grid{grid-template-columns:repeat(2,1fr)}
  .tese-grid{grid-template-columns:repeat(3,1fr)}
  .acao-item{grid-template-columns:32px 1fr;gap:12px}
  .acao-ganho,.acao-valuation{display:none}
  .acao-content::after{content:attr(data-ganho);display:block;font-family:'DM Mono',monospace;
    font-size:12px;color:var(--pu);margin-top:8px}
  .cta-1socio{flex-direction:column;text-align:center}
}
</style>
</head>
<body>
<div class="page">
  <div class="container" id="main-content">
    <div class="loading">
      <div class="loading-spinner"></div>
      <div class="loading-text">Carregando laudo...</div>
    </div>
  </div>
</div>

<script>
const SUPA_URL = 'https://dbijmgqlcrgjlcfrastg.supabase.co';
const SUPA_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRiaWptZ3FsY3JnamxjZnJhc3RnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMwNzYxNjMsImV4cCI6MjA4ODY1MjE2M30.mV2rANZ8Nb_AbifTmkEvdfX_nsm8zeT6Al_bPrCzNAA';

const fmt = n => n==null?'--':n.toLocaleString('pt-BR',{style:'currency',currency:'BRL',maximumFractionDigits:0});
const fmtPct = n => n==null?'--':(n*100).toFixed(1)+'%';
const fmtNum = n => n==null?'--':n.toLocaleString('pt-BR');

const MULT = {
  'tech_saas':{m:3.0},'saude':{m:2.0},'educacao':{m:2.5},
  'servicos_empresas':{m:2.0},'financeiro':{m:2.5},'bem_estar':{m:2.0},
  'marketing':{m:2.0},'industria':{m:1.75},'beleza_estetica':{m:1.75},
  'hospedagem':{m:1.75},'varejo':{m:1.5},'alimentacao':{m:1.5},
  'construcao':{m:1.5},'servicos_locais':{m:1.75},'outro':{m:1.5}
};

const BENCH_DRE = {
  'varejo':    {cmv:0.40,folha:0.18,aluguel:0.05,impostos:0.09,ro:0.14},
  'distribuicao':{cmv:0.60,folha:0.13,aluguel:0.02,impostos:0.09,ro:0.05},
  'industria': {cmv:0.52,folha:0.22,aluguel:0.03,impostos:0.10,ro:0.06},
  'servico_projeto':{cmv:0.03,folha:0.37,aluguel:0.02,impostos:0.08,ro:0.34},
  'servico_mao_obra':{cmv:0.08,folha:0.53,aluguel:0.01,impostos:0.07,ro:0.21},
  'hospedagem':{cmv:0.28,folha:0.25,aluguel:0.08,impostos:0.08,ro:0.15},
  'locacoes':  {cmv:0.05,folha:0.08,aluguel:0.01,impostos:0.08,ro:0.69},
  'plataformas':{cmv:0.03,folha:0.24,aluguel:0.01,impostos:0.08,ro:0.39},
  'alimentacao':{cmv:0.35,folha:0.22,aluguel:0.06,impostos:0.09,ro:0.12},
  'outro':     {cmv:0.35,folha:0.25,aluguel:0.05,impostos:0.09,ro:0.12}
};

const MOCK_DATA = {
  nome: 'Acai do Ze',
  setor: 'alimentacao',
  tipo_negocio: 'varejo',
  cidade: 'Florianopolis',
  estado: 'SC',
  tempo_operacao: 4,
  faturamento_mensal: 45000,
  cmv: 16000,
  folha_total: 9000,
  despesas_fixas: 6000,
  aluguel: 3500,
  depreciacao: 500,
  impostos: 4000,
  prolabore: 5000,
  ativo_imobilizado: 45000,
  ativo_estoque: 12000,
  ativo_caixa: 18000,
  contas_receber: 8000,
  passivo_emprestimos: 25000,
  parcelas_mensais: 2500,
  passivo_fornecedores: 10000,
  passivo_impostos: 3000,
  passivo_trabalhista: 0,
  expectativa_venda: 450000,
  regime_tributario: 'simples',
  num_clientes: 1200,
  funcionarios_clt: 4,
  funcionarios_pj: 1,
  recorrencia: 'baixa',
  concentracao_clientes: 'baixa',
  processos: 'parcial',
  dependencia: 'parcial',
  processos_juridicos: 'nao',
  canais: ['loja_fisica','delivery'],
  crescimento: 'ate_10',
  reputacao: 'boa',
  usa_erp: 'sim',
  p1: 7, p2: 6, p3: 7, p4: 5, p5: 5, p6: 8, p7: 7, p8: 6
};

async function init(){
  const params = new URLSearchParams(location.search);
  const slug = params.get('lead') || params.get('id');
  
  if(!slug){
    console.log('Modo de teste: usando dados mockados');
    renderLaudo(MOCK_DATA, 'teste-acai-ze');
    return;
  }
  
  try{
    const r = await fetch(`${SUPA_URL}/functions/v1/diagnostico-sessao?action=load&slug=${slug}`);
    const json = await r.json();
    
    if(!json.found || !json.dados){
      document.getElementById('main-content').innerHTML = `
        <div class="loading"><p>Laudo nao encontrado</p></div>`;
      return;
    }
    
    renderLaudo(json.dados, slug);
  }catch(e){
    console.error(e);
    document.getElementById('main-content').innerHTML = `
      <div class="loading"><p>Erro ao carregar</p></div>`;
  }
}

function renderLaudo(D, slug){
  const setor = D.setor || 'outro';
  const tipoNeg = D.tipo_negocio || mapSetorToTipo(setor);
  const mult = MULT[setor] || MULT['outro'];
  const bench = BENCH_DRE[tipoNeg] || BENCH_DRE['outro'];
  
  const fatMensal = D.faturamento_mensal || 30000;
  const faturamento = fatMensal * 12;
  const cmv = (D.cmv || fatMensal * bench.cmv) * 12;
  const folha = (D.folha_total || fatMensal * bench.folha) * 12;
  const aluguel = (D.aluguel || fatMensal * 0.05) * 12;
  const despesas = (D.despesas_fixas || fatMensal * 0.15) * 12;
  const depreciacao = (D.depreciacao || 0) * 12;
  const impostos = (D.impostos || fatMensal * 0.09) * 12;
  
  const receitaLiq = faturamento - impostos;
  const lucroBruto = receitaLiq - cmv;
  const ebitda = lucroBruto - folha - despesas - aluguel;
  const lucroLiq = ebitda - depreciacao;
  
  const cmvPct = cmv / faturamento;
  const folhaPct = folha / faturamento;
  const aluguelPct = aluguel / faturamento;
  const margemOp = ebitda / faturamento;
  
  const ativos = (D.ativo_imobilizado||0) + (D.ativo_estoque||0) + (D.ativo_caixa||0) + (D.contas_receber||0);
  const passivos = (D.passivo_emprestimos||0) + (D.passivo_fornecedores||0) + (D.passivo_impostos||0) + (D.passivo_trabalhista||0);
  const pl = ativos - passivos;
  
  const ise = calcularISE(D);
  const iseClass = ise >= 85 ? 'estruturado' : ise >= 70 ? 'consolidado' : ise >= 50 ? 'operacional' : ise >= 35 ? 'dependente' : 'embrionario';
  const iseFator = ise >= 85 ? 1.5 : ise >= 70 ? 1.25 : ise >= 50 ? 1.0 : ise >= 35 ? 0.75 : 0.5;
  
  // Calcular ICD
  const icd = calcularICD(D);
  const icdClass = icd.pct >= 90 ? 'transparente' : icd.pct >= 70 ? 'adequado' : icd.pct >= 50 ? 'parcial' : 'opaco';
  
  const multiplo = mult.m;
  const fator1N = multiplo * iseFator;
  const valorOp = ebitda * fator1N;
  const valorVenda = valorOp + pl;
  const expectativaDono = D.expectativa_venda || valorVenda * 1.2;
  
  const acoes = calcularAcoes(D, faturamento, cmvPct, folhaPct, aluguelPct, margemOp, 
    bench, ebitda, passivos, D.parcelas_mensais||0, fator1N, ise);
  
  const top10 = acoes.slice(0, 10);
  const somaTop10 = top10.reduce((s,a) => s + a.ganhoAnual, 0);
  const valoracaoTop10 = top10.reduce((s,a) => s + a.impactoValuation, 0);
  
  const repositorio = acoes.slice(10);
  const somaRepo = repositorio.reduce((s,a) => s + a.ganhoAnual, 0);
  
  const potencial1Socio = valorVenda + valoracaoTop10;
  
  const pilares = [
    {nome:'Result.', val:D.p1||5, peso:'18%'},
    {nome:'Cresc.', val:D.p2||5, peso:'15%'},
    {nome:'Canais', val:D.p3||5, peso:'15%'},
    {nome:'Gestao', val:D.p4||5, peso:'10%'},
    {nome:'Indep.', val:D.p5||5, peso:'10%'},
    {nome:'Risco', val:D.p6||5, peso:'10%'},
    {nome:'Marca', val:D.p7||5, peso:'8%'},
    {nome:'Tech', val:D.p8||5, peso:'5%'}
  ];
  
  const simTrib = simularTributario(faturamento, D.regime_tributario);
  const indicadores = calcularIndicadores(D, faturamento, ebitda, valorVenda, ativos, passivos, cmv, folha, bench, tipoNeg);
  
  const setorFmt = formatarSetor(setor);
  const dataHoje = new Date().toLocaleDateString('pt-BR');
  const upsidePct = ((valoracaoTop10 / valorVenda) * 100).toFixed(0);
  
  document.getElementById('main-content').innerHTML = `
    <div class="capa">
      <div class="capa-logo"><em>1</em>NEGOCIO</div>
      <div class="capa-tipo">Laudo Completo</div>
      <div class="capa-titulo">${D.nome || 'Negocio'}</div>
      <div class="capa-setor">${setorFmt}</div>
      <div class="capa-local">${D.cidade || 'Brasil'}${D.estado ? ', '+D.estado : ''}</div>
      <div class="capa-data">Emitido em ${dataHoje}</div>
      <div class="capa-validade">Validade: 90 dias</div>
    </div>
    
    <div class="page-break"></div>
    
    <div class="section">
      <div class="sumario">
        <div class="sumario-title">Sumario</div>
        <ul class="sumario-list">
          <li class="sumario-item"><span>1. Valor de Venda</span><span>${fmt(valorVenda)}</span></li>
          <li class="sumario-item"><span>2. ISE - Indice de Solidez</span><span>${ise}/100</span></li>
          <li class="sumario-item"><span>3. DRE Comparativa</span><span>vs Mercado</span></li>
          <li class="sumario-item"><span>4. Indicadores Implicitos</span><span>${indicadores.length} metricas</span></li>
          <li class="sumario-item"><span>5. Balanco Patrimonial</span><span>PL ${fmt(pl)}</span></li>
          <li class="sumario-item"><span>6. Simulacao Tributaria</span><span>4 regimes</span></li>
          <li class="sumario-item highlight"><span>7. Plano de Acao 1Socio</span><span>0+10 acoes - +${upsidePct}%</span></li>
          <li class="sumario-item highlight"><span>8. Repositorio de Acoes</span><span>+${repositorio.length} acoes</span></li>
          <li class="sumario-item"><span>9. Tese de Investimento</span><span></span></li>
          <li class="sumario-item"><span>10. Teaser Executivo</span><span></span></li>
        </ul>
      </div>
      
      <!-- ICD — Indice de Confianca dos Dados -->
      <div class="icd-card" style="margin-top:20px">
        <div class="icd-card-header">
          <div class="icd-card-title">TRANSPARENCIA DOS DADOS</div>
          <div class="icd-badge icd-${icdClass}">
            <span class="icd-pct">${icd.pct}%</span>
            <span>${icd.classificacao}</span>
          </div>
        </div>
        
        <div class="icd-bar-wrap">
          <div class="icd-bar-fill icd-${icdClass}" style="width:${icd.pct}%"></div>
        </div>
        
        <div style="font-size:11px;color:var(--ink3);margin-bottom:12px">
          ${icd.preenchidos} de ${icd.total} campos desejaveis preenchidos
        </div>
        
        <div class="icd-grid">
          <div class="icd-col">
            <div class="icd-col-title" style="color:var(--em)">DADOS REAIS (${icd.camposPreenchidos.length})</div>
            ${icd.camposPreenchidos.slice(0,5).map(c => `<div class="icd-detail-row"><span class="icd-check">+</span><span style="color:var(--ink2)">${c}</span></div>`).join('')}
            ${icd.camposPreenchidos.length > 5 ? `<div style="font-size:10px;color:var(--ink4);padding-top:4px">+${icd.camposPreenchidos.length - 5} mais</div>` : ''}
          </div>
          
          <div class="icd-col">
            <div class="icd-col-title" style="color:var(--am)">BENCHMARK (${icd.camposBenchmark.length})</div>
            ${icd.camposBenchmark.slice(0,5).map(c => `<div class="icd-detail-row"><span class="icd-bench">~</span><span style="color:var(--ink3)">${c.nome}</span></div>`).join('')}
            ${icd.camposBenchmark.length > 5 ? `<div style="font-size:10px;color:var(--ink4);padding-top:4px">+${icd.camposBenchmark.length - 5} mais</div>` : ''}
          </div>
        </div>
        
        <div style="margin-top:12px;padding:10px;background:var(--bg2);border-radius:var(--r)">
          <div style="font-size:11px;color:var(--ink3);line-height:1.4">
            <strong style="color:var(--ink2)">O que isso significa:</strong> 
            ${icd.pct >= 90 ? 'A avaliacao e baseada quase inteiramente em dados fornecidos por voce. Alta confiabilidade.' :
              icd.pct >= 70 ? 'A maioria dos dados sao reais. Alguns campos usam estimativas de mercado.' :
              icd.pct >= 50 ? 'Parte dos dados usa benchmarks do mercado. Preencher mais campos aumenta a precisao.' :
              'Muitos campos usam estimativas de mercado. Considere completar o diagnostico para uma avaliacao mais precisa.'}
          </div>
        </div>
      </div>
    </div>
    
    <div class="section" id="sec-valor">
      <div class="section-head" onclick="toggleSection('sec-valor')">
        <span class="section-title">1. Valor de Venda</span>
        <span class="section-line"></span>
        <span class="section-toggle">v</span>
      </div>
      <div class="section-content">
        <div class="valor-destaque">
          <div class="valor-destaque-label">Valor de venda estimado</div>
          <div class="valor-destaque-num">${fmt(valorVenda)}</div>
          <div class="valor-destaque-sub">Avaliacao 1Negocio - porteira fechada</div>
        </div>
        
        <div class="termo-card">
          <div class="termo-bar">
            <div class="termo-fill" style="width:100%"></div>
            <div class="termo-marker expectativa" style="left:${Math.min(85,Math.max(15,(expectativaDono/potencial1Socio)*100))}%">
              <div class="termo-marker-line"></div>
              <div class="termo-marker-label">Expectativa<br><strong>${fmt(expectativaDono)}</strong></div>
            </div>
            <div class="termo-marker avaliacao" style="left:${Math.min(85,Math.max(15,(valorVenda/potencial1Socio)*100))}%">
              <div class="termo-marker-line"></div>
              <div class="termo-marker-label">1Negocio<br><strong>${fmt(valorVenda)}</strong></div>
            </div>
            <div class="termo-marker potencial" style="left:88%">
              <div class="termo-marker-line"></div>
              <div class="termo-marker-label">1Socio 12m<br><strong>${fmt(potencial1Socio)}</strong></div>
            </div>
          </div>
          <div class="termo-legend">
            <span class="termo-leg-item"><span class="dot gray"></span>O que o dono pede</span>
            <span class="termo-leg-item"><span class="dot green"></span>Valor justo de mercado</span>
            <span class="termo-leg-item"><span class="dot purple"></span>Potencial com 1Socio</span>
          </div>
        </div>
        
        <div class="calc-card" style="margin-top:20px">
          <div class="calc-row"><span>Resultado Operacional anual</span><span>${fmt(ebitda)}</span></div>
          <div class="calc-row"><span>Fator 1Negocio</span><span>${fator1N.toFixed(2)}x</span></div>
          <div class="calc-row"><span>= Valor operacional</span><span>${fmt(valorOp)}</span></div>
          <div class="calc-row"><span>+ Patrimonio liquido</span><span>${fmt(pl)}</span></div>
          <div class="calc-row total"><span>= Valor de venda</span><span>${fmt(valorVenda)}</span></div>
        </div>
      </div>
    </div>
    
    <div class="section" id="sec-ise">
      <div class="section-head" onclick="toggleSection('sec-ise')">
        <span class="section-title">2. ISE - Indice de Solidez Empresarial</span>
        <span class="section-line"></span>
        <span class="section-toggle">v</span>
      </div>
      <div class="section-content">
        <div class="ise-cockpit">
          <div class="ise-cockpit-center">
            <svg viewBox="0 0 200 120" class="ise-gauge">
              <defs>
                <linearGradient id="gaugeGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                  <stop offset="0%" style="stop-color:var(--rd)"/>
