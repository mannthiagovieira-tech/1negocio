var SUPABASE_ANON = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRiaWptZ3FsY3JnamxjZnJhc3RnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMwNzYxNjMsImV4cCI6MjA4ODY1MjE2M30.mV2rANZ8Nb_AbifTmkEvdfX_nsm8zeT6Al_bPrCzNAA';

// Lista UFs
var UFS = ['AC','AL','AM','AP','BA','CE','DF','ES','GO','MA','MG','MS','MT','PA','PB','PE','PI','PR','RJ','RN','RO','RR','RS','SC','SE','SP','TO'];

// ============================================================
// THEME
// ============================================================
var themeBtn  = document.querySelector('[data-toggle-theme]');
var themeIcon = document.getElementById('theme-icon');
applyTheme(localStorage.getItem('1n-theme') || 'light');
themeBtn.addEventListener('click', function(){
  var next = document.body.dataset.theme === 'light' ? 'dark' : 'light';
  applyTheme(next);
  localStorage.setItem('1n-theme', next);
});
function applyTheme(t){
  document.body.dataset.theme = t;
  themeIcon.textContent = t === 'light' ? '☼' : '☾';
  themeBtn.setAttribute('aria-pressed', t === 'dark' ? 'true' : 'false');
}

// ============================================================
// FORM
// ============================================================
var form        = document.getElementById('form-cadastro');
var btnSubmit   = document.getElementById('btn-submit');
var inputWpp    = document.getElementById('f-whatsapp');
var formUF      = document.getElementById('f-uf');
var qtyBtns     = document.querySelectorAll('.qty-btn');
var papelCards  = document.querySelectorAll('.papel-card');
var checkAceite = document.getElementById('check-aceite');
var aceiteInp   = document.getElementById('f-aceite');
var toastEl     = document.getElementById('toast');
var viewForm    = document.getElementById('view-form');
var viewSuccess = document.getElementById('view-success');

// popula UFs no select
UFS.forEach(function(uf){
  var o = document.createElement('option');
  o.value = uf;
  o.textContent = uf;
  formUF.appendChild(o);
});

// máscara WhatsApp
inputWpp.addEventListener('input', function(e){
  var v = e.target.value.replace(/\D/g,'').slice(0,11);
  if(v.length > 6)      v = '(' + v.slice(0,2) + ') ' + v.slice(2,7) + '-' + v.slice(7);
  else if(v.length > 2) v = '(' + v.slice(0,2) + ') ' + v.slice(2);
  e.target.value = v;
});

// botões de quantidade
qtyBtns.forEach(function(b){
  b.addEventListener('click', function(){
    qtyBtns.forEach(function(x){ x.classList.remove('active'); });
    b.classList.add('active');
  });
});

// papel cards
papelCards.forEach(function(c){
  c.addEventListener('click', function(){
    papelCards.forEach(function(x){ x.classList.remove('selected'); });
    c.classList.add('selected');
    c.querySelector('input').checked = true;
  });
});

// checkbox aceite (visual)
checkAceite.addEventListener('click', function(e){
  if(e.target.tagName === 'A') return;
  if(e.target !== aceiteInp){
    aceiteInp.checked = !aceiteInp.checked;
  }
  checkAceite.classList.toggle('checked', aceiteInp.checked);
});

// toast
function toast(msg, kind){
  toastEl.textContent = msg;
  toastEl.className = 'toast show' + (kind === 'error' ? ' error' : '');
  setTimeout(function(){ toastEl.className = toastEl.className.replace(' show',''); }, 4000);
}

// submit
form.addEventListener('submit', async function(e){
  e.preventDefault();
  var fd = new FormData(form);
  var nome  = (fd.get('nome')    ||'').toString().trim();
  var wpp   = (fd.get('whatsapp')||'').toString().replace(/\D/g,'');
  var email = (fd.get('email')   ||'').toString().trim();
  var papel = (fd.get('papel_escolhido')||'').toString();
  var aceito = !!aceiteInp.checked;

  if(nome.length < 3)        return toast('Informe seu nome completo', 'error');
  if(wpp.length < 10)        return toast('WhatsApp inválido', 'error');
  if(email.indexOf('@') < 1) return toast('E-mail inválido', 'error');
  if(papel !== 'parceiro' && papel !== 'socio') return toast('Escolha um caminho (Parceiro ou Sócio)', 'error');
  if(!aceito)                return toast('Você precisa aceitar o contato', 'error');

  var volEl = document.querySelector('.qty-btn.active');
  var network_volume = volEl ? volEl.dataset.vol : '5_20';

  var payload = {
    nome:              nome,
    whatsapp:          wpp,
    email:             email,
    profissao:         (fd.get('profissao')||'').toString() || null,
    cidade:            (fd.get('cidade')||'').toString().trim() || null,
    estado:            (fd.get('estado')||'').toString() || null,
    network_descricao: (fd.get('network_descricao')||'').toString().trim() || null,
    network_volume:    network_volume,
    papel_escolhido:   papel
  };

  btnSubmit.disabled = true;
  var origLabel = btnSubmit.innerHTML;
  btnSubmit.textContent = 'Enviando…';

  try{
    var r = await fetch(SUPABASE_URL + '/rest/v1/socio_parceiro_leads', {
      method:'POST',
      headers:{
        'apikey':SUPABASE_ANON,
        'Authorization':'Bearer ' + SUPABASE_ANON,
        'Content-Type':'application/json',
        'Prefer':'return=minimal'
      },
      body:JSON.stringify(payload)
    });
    if(r.ok){
      // troca pra view de sucesso
      viewForm.style.display    = 'none';
      viewSuccess.style.display = 'block';
      window.scrollTo({top:0, behavior:'smooth'});
    } else {
      var txt = await r.text();
      console.error('insert falhou', r.status, txt);
      toast('Erro ao enviar. Tente novamente.', 'error');
      btnSubmit.innerHTML = origLabel;
      btnSubmit.disabled = false;
    }
  } catch(err){
    console.error(err);
    toast('Erro de conexão.', 'error');
    btnSubmit.innerHTML = origLabel;
    btnSubmit.disabled = false;
  }
});

})();
</script>
</body>
</html>
