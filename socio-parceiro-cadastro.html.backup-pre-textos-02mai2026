}
.success-card h1{
  font-family:'Syne',serif;font-weight:800;
  font-size:clamp(28px,4.5vw,44px);line-height:1.1;
  letter-spacing:-.025em;color:var(--ink);margin-bottom:14px;
}
.success-card p{
  font-size:15.5px;color:var(--ink-2);line-height:1.6;
