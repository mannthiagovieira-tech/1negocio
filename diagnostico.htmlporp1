<script>
// ═══════════════════════════════════════════════════════════
// ⚙️ CONFIGURAÇÕES DO MOTOR DE AVALIAÇÃO
// (visíveis também no painel admin — não alterar sem atualizar ambos)
// ═══════════════════════════════════════════════════════════
const CONFIG = {
  versao: '1.0 · Março 2026',

  // Múltiplos base por categoria (resultado ajustado anual)
  // Ajustar trimestralmente com base em WACC real do mercado
  multiplos: {
    alimentacao:   { min: 1.5, max: 3.0, label: 'Alimentação' },
    comercio:      { min: 1.5, max: 3.0, label: 'Comércio & Varejo' },
    beleza_saude:  { min: 2.0, max: 3.5, label: 'Beleza & Saúde' },
    pet:           { min: 2.0, max: 3.5, label: 'Pet' },
    industria:     { min: 2.5, max: 4.5, label: 'Indústria & Fabricação' },
    educacao:      { min: 2.5, max: 4.0, label: 'Educação' },
    distribuicao:  { min: 2.0, max: 3.5, label: 'Distribuição & Atacado' },
    tecnologia:    { min: 3.0, max: 6.0, label: 'Tecnologia & Digital' },
    hospedagem:    { min: 2.0, max: 3.5, label: 'Hospedagem & Turismo' },
    outro:         { min: 1.5, max: 3.0, label: 'Outro' },
  },

  // Pesos dos 10 pilares de saúde (deve somar 100%)
  pesos: {
    p1: 40,  // Dependência dos sócios — KEY MAN RISK
    p2: 8,   // Comercial / Geração de receita
    p3: 6,   // Produto / Oferta
    p4: 7,   // Gestão e processos
    p5: 10,  // Financeiro / Resultado
    p6: 7,   // Balanço patrimonial
    p7: 7,   // Estrutura de endividamento
    p8: 5,   // Risco jurídico / tributário
    p9: 5,   // Concentração de receita
    p10: 5,  // Potencial de crescimento
  },

  // Tabela de prêmio de maturidade (score → multiplicador)
  premios: [
    { min: 0,  max: 29, mult: 0.80, label: 'Crítico' },
    { min: 30, max: 44, mult: 0.88, label: 'Baixo' },
    { min: 45, max: 59, mult: 0.95, label: 'Básico' },
    { min: 60, max: 69, mult: 1.00, label: 'Regular' },
    { min: 70, max: 79, mult: 1.08, label: 'Bom' },
    { min: 80, max: 89, mult: 1.18, label: 'Ótimo' },
    { min: 90, max: 100,mult: 1.30, label: 'Excelente' },
  ],

  // Alíquotas estimadas por regime (sobre faturamento)
  aliquotas: {
    simples:  0.10,
    presumido: 0.18,
    real:     0.22,
    mei:      0.05,
    pf:       0.15,
    '':       0.15,  // não informado → conservador
  }
};

// ═══════════════════════════════════════════════════════════
// SUPABASE
// ═══════════════════════════════════════════════════════════
const SUPA_URL = 'https://dbijmgqlcrgjlcfrastg.supabase.co';
const SUPA_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRiaWptZ3FsY3JnamxjZnJhc3RnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMwNzYxNjMsImV4cCI6MjA4ODY1MjE2M30.mV2rANZ8Nb_AbifTmkEvdfX_nsm8zeT6Al_bPrCzNAA';
const sb = supabase.createClient(SUPA_URL, SUPA_KEY);

let usuarioAtual = null;
let etapaAtual = 1;
let totalEtapas = 7;

// Dados coletados
const D = {
  categoria: null, detalhe: null, franquia: null,
  cidade: null, estado: null, anos: null, colaboradores: null,
  contrato: null, local_fisico: null,
  fat_mensal: 0, regime: '', cmv: 0, folha: 0, aluguel: 0,
  contas_fixas: 0, terceiros: 0, marketing: 0, outras_desp: 0,
  parcelas: 0, prolabore: 0, investimentos: 0,
  at_maquinas: 0, at_moveis: 0, at_veiculos: 0, at_ti: 0,
  at_reformas: 0, at_estoque: 0, at_receber: 0, at_caixa: 0, at_imovel: 0,
  pa_fornecedores: 0, pa_tributario: 0, pa_bancario: 0, pa_outros: 0,
  p1: null, p2: null, p3: null, p4: null, p5: null,
  p6: null, p7: null, p8: null, p9: null, p10: null,
  motivo: null, urgencia: null,
};

// ═══════════════════════════════════════════════════════════
// AUTH
// ═══════════════════════════════════════════════════════════
async function init() {
  const { data: { session } } = await sb.auth.getSession();
  if (session) {
    usuarioAtual = session.user;
    mostrarApp();
  }
}

function mudarAba(aba) {
  document.getElementById('tab-criar').classList.toggle('ativo', aba === 'criar');
  document.getElementById('tab-entrar').classList.toggle('ativo', aba === 'entrar');
  document.getElementById('form-criar').style.display = aba === 'criar' ? 'block' : 'none';
  document.getElementById('form-entrar').style.display = aba === 'entrar' ? 'block' : 'none';
  document.getElementById('auth-erro').style.display = 'none';
}

async function criarConta() {
  const nome = document.getElementById('auth-nome').value.trim();
  const email = document.getElementById('auth-email-c').value.trim();
  const senha = document.getElementById('auth-senha-c').value;
  const erro = document.getElementById('auth-erro');
  const btn = document.getElementById('btn-criar');

  if (!nome) { mostrarErroAuth('Informe seu nome.'); return; }
  if (!email || !email.includes('@')) { mostrarErroAuth('Informe um e-mail válido.'); return; }
  if (senha.length < 8) { mostrarErroAuth('A senha precisa ter pelo menos 8 caracteres.'); return; }

  btn.textContent = 'Criando conta...'; btn.disabled = true;
  erro.style.display = 'none';

  const { data, error } = await sb.auth.signUp({
    email, password: senha,
    options: { data: { full_name: nome } }
  });

  if (error) {
    if (error.message.includes('already')) {
      mostrarErroAuth('Este e-mail já tem cadastro. Tente entrar na aba "Já tenho conta".');
    } else {
      mostrarErroAuth(error.message);
    }
    btn.textContent = 'Criar conta e começar →'; btn.disabled = false;
    return;
  }

  usuarioAtual = data.user;
  await sb.from('usuarios').upsert({
    id: usuarioAtual.id, email, nome, tipo: 'sell',
    updated_at: new Date().toISOString()
  });

  mostrarApp();
}

async function fazerLogin() {
  const email = document.getElementById('auth-email-e').value.trim();
  const senha = document.getElementById('auth-senha-e').value;
  const btn = document.getElementById('btn-entrar');

  if (!email || !senha) { mostrarErroAuth('Preencha e-mail e senha.'); return; }

  btn.textContent = 'Entrando...'; btn.disabled = true;

  const { data, error } = await sb.auth.signInWithPassword({ email, password: senha });

  if (error) {
    mostrarErroAuth('E-mail ou senha incorretos.');
    btn.textContent = 'Entrar e continuar →'; btn.disabled = false;
    return;
  }

  usuarioAtual = data.user;
  mostrarApp();
}

function mostrarErroAuth(msg) {
  const el = document.getElementById('auth-erro');
  el.textContent = msg;
  el.style.display = 'block';
}

function mostrarApp() {
  document.getElementById('tela-auth').classList.remove('ativa');
  document.getElementById('tela-form').classList.add('ativa');
  document.getElementById('hdr-user').style.display = 'flex';
  document.getElementById('hdr-email').textContent = usuarioAtual.email;
}

async function sair() {
  await sb.auth.signOut();
  usuarioAtual = null;
  document.getElementById('tela-form').classList.remove('ativa');
  document.getElementById('tela-resultado').classList.remove('ativa');
  document.getElementById('tela-auth').classList.add('ativa');
  document.getElementById('hdr-user').style.display = 'none';
}

// ═══════════════════════════════════════════════════════════
// NAVEGAÇÃO DE ETAPAS
// ═══════════════════════════════════════════════════════════
function irPara(n) {
  // Salvar dados da etapa atual antes de avançar
  coletarDadosEtapa(etapaAtual);

  document.getElementById('e' + etapaAtual).classList.remove('ativa');
  etapaAtual = n;
  document.getElementById('e' + n).classList.add('ativa');
  document.getElementById('hdr-step').textContent = 'Etapa ' + n + ' de ' + totalEtapas;
  document.getElementById('prog').style.width = ((n / (totalEtapas + 1)) * 100) + '%';

  window.scrollTo({ top: 0, behavior: 'smooth' });
  salvarRascunho();
}

function coletarDadosEtapa(n) {
  const g = (id) => { const el = document.getElementById(id); return el ? el.value : ''; };
  const gn = (id) => { const v = parseFloat(g(id)); return isNaN(v) ? 0 : v; };

  if (n === 2) {
    D.cidade = g('cidade');
    D.estado = g('estado');
    D.anos = gn('anos-operacao');
    D.colaboradores = gn('total-colaboradores');
  }
  if (n === 3) {
    D.fat_mensal = gn('fat-mensal');
    D.regime = g('regime');
    D.cmv = gn('cmv');
    D.folha = gn('folha');
    D.aluguel = gn('aluguel');
    D.contas_fixas = gn('contas-fixas');
    D.terceiros = gn('terceiros');
    D.marketing = gn('marketing');
    D.outras_desp = gn('outras-desp');
    D.parcelas = gn('parcelas');
    D.prolabore = gn('prolabore');
    D.investimentos = gn('investimentos');
  }
  if (n === 4) {
    D.at_maquinas = gn('at-maquinas');
    D.at_moveis = gn('at-moveis');
    D.at_veiculos = gn('at-veiculos');
    D.at_ti = gn('at-ti');
    D.at_reformas = gn('at-reformas');
    D.at_estoque = gn('at-estoque');
    D.at_receber = gn('at-receber');
    D.at_caixa = gn('at-caixa');
    D.at_imovel = gn('at-imovel');
    D.pa_fornecedores = gn('pa-fornecedores');
    D.pa_tributario = gn('pa-tributario');
    D.pa_bancario = gn('pa-bancario');
    D.pa_outros = gn('pa-outros');
  }
}

// ═══════════════════════════════════════════════════════════
// SELEÇÕES DE OPÇÕES
// ═══════════════════════════════════════════════════════════
function selecionarCategoria(cat, btn) {
  document.querySelectorAll('#opcoes-categoria .opcao').forEach(b => b.classList.remove('sel'));
  btn.classList.add('sel');
  D.categoria = cat;
  document.getElementById('detalhe-wrap').style.display = 'block';

  // Ajusta label do CMV por tipo
  const cmvTitulo = document.getElementById('cmv-titulo');
  const cmvLabel = document.getElementById('cmv-label');
  const cmvWrap = document.getElementById('cmv-wrap');
  if (['alimentacao','comercio','industria','distribuicao','pet'].includes(cat)) {
    cmvWrap.style.display = 'block';
    cmvTitulo.textContent = cat === 'alimentacao' ? 'Custo dos ingredientes e insumos' :
                            cat === 'industria' ? 'Custo de matéria-prima e produção' :
                            'Custo da mercadoria (CMV)';
  } else {
    cmvWrap.style.display = 'none';
    D.cmv = 0;
  }
}

function sel2(campo, val, btn) {
  const grupo = btn.parentElement;
  grupo.querySelectorAll('.opcao').forEach(b => b.classList.remove('sel'));
  btn.classList.add('sel');
  D[campo] = val;
  if (campo === 'detalhe') D.detalhe = val;
}

document.getElementById('detalhe-negocio').addEventListener('input', function() {
  D.detalhe = this.value;
});

function selEscala(campo, val, btn) {
  const grupo = document.getElementById('esc-' + campo);
  group = btn.parentElement;
  group.querySelectorAll('.escala-op').forEach(b => b.classList.remove('sel'));
  btn.classList.add('sel');
  D[campo] = val;
}

// ═══════════════════════════════════════════════════════════
// MOTOR DE CÁLCULO
// ═══════════════════════════════════════════════════════════
function calcular() {
  // Coletar dados finais
  coletarDadosEtapa(7);

  const cat = D.categoria || 'outro';
  const fat = D.fat_mensal;
  const regime = D.regime || '';

  // 1. Impostos estimados
  const aliquota = CONFIG.aliquotas[regime] || CONFIG.aliquotas[''];
  const impostos_mes = fat * aliquota;

  // 2. Resultado Operacional Ajustado (mensal)
  const result_mes = fat
    - impostos_mes
    - D.cmv
    - D.folha
    - D.aluguel
    - D.contas_fixas
    - D.terceiros
    - D.marketing
    - D.outras_desp;

  const result_anual = result_mes * 12;

  // 3. Geração de caixa real (mensal, informacional)
  const caixa_mes = result_mes - D.parcelas - D.investimentos - D.prolabore;

  // 4. Múltiplo do setor
  const mult_cfg = CONFIG.multiplos[cat] || CONFIG.multiplos['outro'];
  const mult_base = (mult_cfg.min + mult_cfg.max) / 2;

  // 5. Score de saude (0 a 100)
  const pilares = ['p1','p2','p3','p4','p5','p6','p7','p8','p9','p10'];
  let score_ponderado = 0;
  let pilares_preenchidos = 0;

  pilares.forEach(p => {
    const val = D[p];
    if (val !== null && val !== undefined) {
      score_ponderado += (val / 10) * CONFIG.pesos[p];
      pilares_preenchidos++;
    }
  });

  // Se não preencheu todos, assume 5 nos faltantes (neutro)
  if (pilares_preenchidos < 10) {
    pilares.forEach(p => {
      if (D[p] === null || D[p] === undefined) {
        score_ponderado += (5 / 10) * CONFIG.pesos[p];
      }
    });
  }

  const score = Math.round(score_ponderado);

  // 6. Prêmio de maturidade
  const premio_cfg = CONFIG.premios.find(p => score >= p.min && score <= p.max) || CONFIG.premios[0];
  const premio = premio_cfg.mult;

  // 7. Valor do negócio
  const valor_negocio = Math.max(0, result_anual * mult_base * premio);

  // 8. Balanço patrimonial
  const total_ativos = D.at_maquinas + D.at_moveis + D.at_veiculos + D.at_ti +
                       D.at_reformas + D.at_estoque + D.at_receber + D.at_caixa + D.at_imovel;
  const total_passivos = D.pa_fornecedores + D.pa_tributario + D.pa_bancario + D.pa_outros;
  const balanco = total_ativos - total_passivos;

  // 9. Valor de venda (porteira fechada)
  const valor_venda = valor_negocio + balanco;

  return {
    cat, fat_mensal: fat, regime,
    impostos_mes, result_mes, result_anual,
    caixa_mes,
    mult_base, mult_cfg,
    score, premio, premio_cfg,
    valor_negocio,
    total_ativos, total_passivos, balanco,
    valor_venda,
    pilares_scores: pilares.map(p => ({ id: p, val: D[p] !== null ? D[p] : 5 }))
  };
}

// ═══════════════════════════════════════════════════════════
// TELA DE RESULTADO
// ═══════════════════════════════════════════════════════════
function calcularEMostrar() {
  coletarDadosEtapa(7);

  const R = calcular();
  const conteudo = document.getElementById('resultado-conteudo');

  const nomePilares = {
    p1:'Dependência dos Sócios', p2:'Comercial / Vendas',
    p3:'Produto / Oferta', p4:'Gestão e Processos',
    p5:'Financeiro / Resultado', p6:'Balanço Patrimonial',
    p7:'Estrutura de Dívida', p8:'Risco Jurídico / Fiscal',
    p9:'Concentração de Receita', p10:'Potencial de Crescimento'
  };

  const scoreCor = R.score >= 70 ? 'var(--green)' : R.score >= 50 ? 'var(--amber)' : 'var(--red)';
  const balancoCor = R.balanco >= 0 ? 'verde' : 'vermelho';
  const balacoSinal = R.balanco >= 0 ? '+' : '';

  conteudo.innerHTML = `
    <div class="res-eyebrow">Avaliação concluída · Porteira fechada</div>

    <!-- VALOR DE VENDA PRINCIPAL -->
    <div class="res-card-principal">
      <div class="res-label">Valor de Venda estimado</div>
      <div class="res-valor">${fmtBRL(R.valor_venda)}</div>
      <div class="res-valor-sub">Porteira fechada — comprador assume ativos e passivos</div>

      <div class="res-breakdown">
        <div class="res-breakdown-titulo">Como chegamos neste número</div>
        <div class="res-linha">
          <span class="res-linha-label">Resultado operacional ajustado (anual)</span>
          <span class="res-linha-val">${fmtBRL(R.result_anual)}</span>
        </div>
        <div class="res-linha">
          <span class="res-linha-label">× Múltiplo do setor (${R.mult_cfg.label})</span>
          <span class="res-linha-val">${R.mult_base.toFixed(1)}×</span>
        </div>
        <div class="res-linha">
          <span class="res-linha-label">× Prêmio de saúde (score ${R.score})</span>
          <span class="res-linha-val">${R.premio.toFixed(2)}×</span>
        </div>
        <div class="res-linha">
          <span class="res-linha-label">= Valor do negócio</span>
          <span class="res-linha-val verde">${fmtBRL(R.valor_negocio)}</span>
        </div>
        <div class="res-linha">
          <span class="res-linha-label">+ Ativos do negócio</span>
          <span class="res-linha-val verde">+${fmtBRL(R.total_ativos)}</span>
        </div>
        <div class="res-linha">
          <span class="res-linha-label">− Passivos (dívidas e obrigações)</span>
          <span class="res-linha-val ${R.total_passivos > 0 ? 'vermelho' : ''}">−${fmtBRL(R.total_passivos)}</span>
        </div>
        <div class="res-linha total">
          <span class="res-linha-label">= Valor de Venda</span>
          <span class="res-linha-val">${fmtBRL(R.valor_venda)}</span>
        </div>
      </div>
    </div>

    <!-- CARDS SECUNDÁRIOS -->
    <div class="res-grid">
      <div class="res-mini">
        <div class="res-mini-label">Resultado operacional / mês</div>
        <div class="res-mini-val ${R.result_mes >= 0 ? 'verde' : ''}">${fmtBRL(R.result_mes)}</div>
      </div>
      <div class="res-mini">
        <div class="res-mini-label">Geração de caixa real / mês</div>
        <div class="res-mini-val ${R.caixa_mes >= 0 ? '' : ''}" style="color:${R.caixa_mes >= 0 ? 'var(--green)' : 'var(--amber)'}">${fmtBRL(R.caixa_mes)}</div>
      </div>
      <div class="res-mini">
        <div class="res-mini-label">Múltiplo aplicado</div>
        <div class="res-mini-val">${R.mult_base.toFixed(1)}× · ${R.mult_cfg.label}</div>
      </div>
      <div class="res-mini">
        <div class="res-mini-label">Balanço patrimonial</div>
        <div class="res-mini-val ${balancoCor}">${balacoSinal}${fmtBRL(R.balanco)}</div>
      </div>
    </div>

    ${R.caixa_mes < 0 ? `
    <div class="res-alerta">
      ⚠️ A geração de caixa real está negativa — isso significa que após pagar dívidas, pró-labore e reinvestimentos, o negócio consome mais do que gera. Isso é comum e pode ser resolvido. Um novo gestor pode enxergar isso como uma oportunidade de melhoria.
    </div>` : ''}

    <!-- SAÚDE DO NEGÓCIO -->
    <div class="res-saude">
      <div class="res-saude-topo">
        <div>
          <div class="res-saude-titulo">Nota de Saúde / Maturidade</div>
          <div style="font-size:11px;color:var(--ink2);margin-top:3px">${R.premio_cfg.label} · Prêmio ${R.premio.toFixed(2)}×</div>
