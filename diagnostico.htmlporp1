          <div class="cta-sub">Publique na plataforma e receba propostas de compradores qualificados. Taxa de sucesso de 10% apenas se vender.</div>
        </div>
        <button class="cta-btn verde">Publicar grátis →</button>
      </div>

      <div class="cta-card destaque" style="border-color:rgba(245,158,11,.4);background:rgba(245,158,11,.04)" onclick="contratarGuiado()">
        <div class="cta-info">
          <div class="cta-titulo">Plano Guiado <span class="cta-badge" style="background:var(--amber)">Recomendado</span></div>
          <div class="cta-sub">Consultor dedicado, destaque por 12 meses na plataforma e taxa de sucesso reduzida para 5%.</div>
        </div>
        <div class="cta-preco" style="color:var(--amber)">R$ 588 <span style="font-size:11px;color:var(--ink3)">ou 12×49</span></div>
      </div>

      <div class="cta-card" onclick="comprarRelatorio()">
        <div class="cta-info">
          <div class="cta-titulo">Relatório em PDF</div>
          <div class="cta-sub">Receba este resultado em um laudo completo em PDF para usar como você quiser.</div>
        </div>
        <div class="cta-preco">R$ 99</div>
      </div>

      <div class="cta-card" onclick="contratarAvaliacao()">
        <div class="cta-info">
          <div class="cta-titulo">Avaliação Profissional Completa</div>
          <div class="cta-sub">Avaliação aprofundada com consultor especializado. Laudo robusto sem publicação do anúncio.</div>
        </div>
        <div class="cta-preco">R$ 397</div>
      </div>

      <div class="cta-card" onclick="irParaHome()">
        <div class="cta-info">
          <div class="cta-titulo" style="color:var(--ink2)">Só quero ver o resultado por enquanto</div>
          <div class="cta-sub">Você pode voltar quando quiser pelo portal.</div>
        </div>
        <button class="cta-btn outline">Ir para o início →</button>
      </div>

    </div>
  `;

  // Mostrar tela resultado
  document.getElementById('tela-form').classList.remove('ativa');
  document.getElementById('tela-resultado').classList.add('ativa');
  document.getElementById('prog').style.width = '100%';
  document.getElementById('hdr-step').textContent = 'Resultado da avaliação';
  window.scrollTo({ top: 0, behavior: 'smooth' });

  // Salvar avaliação no banco
  salvarAvaliacao(R);
}

// ═══════════════════════════════════════════════════════════
// BANCO DE DADOS
// ═══════════════════════════════════════════════════════════
async function salvarRascunho() {
  if (!usuarioAtual) return;
  try {
    const payload = {
      vendedor_id: usuarioAtual.id,
      nome: D.detalhe || D.categoria || 'Rascunho',
      categoria: D.categoria,
      cidade: D.cidade,
      estado: D.estado,
      faturamento_anual: D.fat_mensal * 12,
      status: 'rascunho',
      plano: 'gratuito',
      comissao_pct: 10,
      score_saude: 0,
      notas_admin: JSON.stringify({ rascunho: true, dados: D }),
      updated_at: new Date().toISOString(),
    };

    // Upsert por vendedor_id (só um rascunho ativo por vez)
    const { data: existente } = await sb.from('negocios')
      .select('id').eq('vendedor_id', usuarioAtual.id).eq('status', 'rascunho').single();

    if (existente) {
      await sb.from('negocios').update(payload).eq('id', existente.id);
    } else {
      payload.created_at = new Date().toISOString();
      await sb.from('negocios').insert(payload);
    }
  } catch(e) { /* silencioso */ }
}

async function salvarAvaliacao(R) {
  if (!usuarioAtual) return;
  try {
    const payload = {
      vendedor_id: usuarioAtual.id,
      nome: D.detalhe || CONFIG.multiplos[D.categoria]?.label || 'Negócio',
      categoria: D.categoria,
      cidade: D.cidade,
      estado: D.estado,
      faturamento_anual: D.fat_mensal * 12,
      resultado_liquido_mensal: R.result_mes,
      folha_pagamento: D.folha,
      aluguel_mensal: D.aluguel,
      funcionarios: D.colaboradores,
      motivo_venda: D.motivo,
      urgencia: String(D.urgencia || 5),
      status: 'em_avaliacao',
      plano: 'gratuito',
      comissao_pct: 10,
      score_saude: R.score,
      avaliacao_min: Math.round(R.valor_venda * 0.85),
      avaliacao_max: Math.round(R.valor_venda * 1.15),
      ativo_maquinas: D.at_maquinas,
      ativo_equipamentos: D.at_moveis,
      ativo_veiculos: D.at_veiculos,
      ativo_ti: D.at_ti,
      ativo_reformas: D.at_reformas,
      ativo_estoque: D.at_estoque,
      ativo_receber: D.at_receber,
      ativo_caixa: D.at_caixa,
      ativo_imovel: D.at_imovel,
      dividas: D.pa_bancario + D.pa_tributario + D.pa_fornecedores + D.pa_outros,
      notas_admin: JSON.stringify({
        resultado_operacional_mensal: R.result_mes,
        resultado_operacional_anual: R.result_anual,
        caixa_real_mensal: R.caixa_mes,
        multiplo_aplicado: R.mult_base,
        premio_saude: R.premio,
        valor_negocio: R.valor_negocio,
        total_ativos: R.total_ativos,
        total_passivos: R.total_passivos,
        balanco: R.balanco,
        valor_venda: R.valor_venda,
        score: R.score,
        pilares: R.pilares_scores,
        dados_brutos: D,
        config_versao: CONFIG.versao,
      }),
      updated_at: new Date().toISOString(),
    };

    // Remove rascunho anterior e insere completo
    await sb.from('negocios').delete()
      .eq('vendedor_id', usuarioAtual.id).eq('status', 'rascunho');

    payload.created_at = new Date().toISOString();
    const { data } = await sb.from('negocios').insert(payload).select('id').single();
    if (data?.id) {
      window._negocioId = data.id;
    }
  } catch(e) { console.error('salvarAvaliacao', e); }
}

// ═══════════════════════════════════════════════════════════
// AÇÕES DO RESULTADO
// ═══════════════════════════════════════════════════════════
function abrirModalPublicacao() {
  const R = calcular();
  document.getElementById('modal-valor-avaliado').textContent = fmtBRL(R.valor_venda);
  document.getElementById('modal-pedido').classList.add('aberto');
}

function fecharModal() {
  document.getElementById('modal-pedido').classList.remove('aberto');
}

async function confirmarPublicacao() {
  const preco = parseFloat(document.getElementById('preco-pedido').value) || 0;
  if (preco <= 0) { toast('Informe o valor que você espera receber.'); return; }

  if (window._negocioId) {
    await sb.from('negocios').update({ preco_pedido: preco, status: 'em_avaliacao' }).eq('id', window._negocioId);

    // Alerta no admin
    await sb.from('admin_agenda').insert({
      tipo: 'gratuito', status: 'pendente',
      nome_cliente: D.detalhe || CONFIG.multiplos[D.categoria]?.label || 'Negócio',
      email_cliente: usuarioAtual.email,
      notas_admin: `Publicação gratuita · ${D.cidade || ''} · Fat: ${fmtBRL(D.fat_mensal)}/mês · Preço pedido: ${fmtBRL(preco)}`,
      created_at: new Date().toISOString(),
      updated_at: new Date().toISOString(),
    });
  }

  fecharModal();
  toast('Publicação solicitada! Nossa equipe entrará em contato em até 48h.');

  setTimeout(() => {
    document.getElementById('tela-resultado').classList.remove('ativa');
    window.location.href = '/portal-usuario.html';
  }, 2500);
}

function contratarGuiado() {
  window.open('https://buy.stripe.com/7sYdR8elo21aeSRegH5os02', '_blank');
}

function comprarRelatorio() {
  window.open('https://buy.stripe.com/9B6fZgfpsdJScKJegH5os04', '_blank');
}

function contratarAvaliacao() {
  window.open('https://buy.stripe.com/9B6cN47X05dm3a9a0r5os03', '_blank');
}

function irParaHome() {
  window.location.href = '/portal-usuario.html';
}

// ═══════════════════════════════════════════════════════════
// UTILITÁRIOS
// ═══════════════════════════════════════════════════════════
function fmtBRL(v) {
  if (!v && v !== 0) return '—';
  const abs = Math.abs(v);
  const sinal = v < 0 ? '-' : '';
  if (abs >= 1e6) return sinal + 'R$ ' + (abs/1e6).toFixed(2).replace('.',',') + ' Mi';
  if (abs >= 1e3) return sinal + 'R$ ' + (abs/1e3).toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g,'.') + ' mil';
  return sinal + 'R$ ' + abs.toLocaleString('pt-BR', { minimumFractionDigits: 0 });
}

function toast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  setTimeout(() => el.classList.remove('show'), 3500);
}

// ═══════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════
init();
</script>
</body>
</html>
