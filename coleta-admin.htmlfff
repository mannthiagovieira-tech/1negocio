  subcategorias:[
    {id:'rest_bar',label:'Restaurante / Bar',cats:['alimentacao'],mult_min:1.0,mult_max:2.0},
    {id:'tecnologia',label:'Tecnologia / SaaS',cats:['tecnologia'],mult_min:2.5,mult_max:5.0},
    {id:'comercio',label:'Comércio / Varejo',cats:['comercio'],mult_min:1.0,mult_max:2.0},
    {id:'beleza',label:'Beleza e Saúde',cats:['beleza_saude'],mult_min:1.5,mult_max:3.0},
    {id:'pet',label:'Pet',cats:['pet'],mult_min:1.2,mult_max:3.5},
    {id:'educacao',label:'Educação',cats:['educacao'],mult_min:2.0,mult_max:3.5},
    {id:'industria',label:'Indústria',cats:['industria'],mult_min:2.0,mult_max:4.0},
    {id:'distribuicao',label:'Distribuição',cats:['distribuicao'],mult_min:2.0,mult_max:3.5},
    {id:'hospedagem',label:'Hospedagem',cats:['hospedagem'],mult_min:1.5,mult_max:3.0},
    {id:'servicos_b2b',label:'Serviços B2B',cats:['servicos_b2b'],mult_min:2.0,mult_max:4.0},
    {id:'saude',label:'Saúde / Clínica',cats:['saude_clinica'],mult_min:2.0,mult_max:4.0},
    {id:'construcao',label:'Construção',cats:['construcao'],mult_min:1.5,mult_max:3.0},
    {id:'outro',label:'Outro',cats:['outro'],mult_min:1.5,mult_max:3.0}
  ],
  premios:[
    {min:0,max:40,label:'Vulnerável',fator:0.80},
    {min:41,max:60,label:'Em desenvolvimento',fator:0.92},
    {min:61,max:80,label:'Madura',fator:1.12},
    {min:81,max:100,label:'Sólida',fator:1.25}
  ]
};

// ── INIT ───────────────────────────────────────────────────────
(async function(){
  var params=new URLSearchParams(window.location.search);
  NEG_ID=params.get('negocio_id')||null;
  VENDOR_ID=params.get('vendedor_id')||null;

  if(NEG_ID){
    await carregarNegocio(NEG_ID);
  }
  if(VENDOR_ID){
    await carregarVendedor(VENDOR_ID);
  }

  buildPilares();
  recalcular();
})();

async function carregarNegocio(id){
  var res=await sb.from('negocios').select('*').eq('id',id).single();
  if(!res.data)return;
  var n=res.data;
  VENDOR_ID=n.vendedor_id;

  // Preencher D com os dados salvos
  D.nome=n.nome||'';D.categoria=n.categoria||'';D.detalhe=n.detalhe||n.nome||'';
  D.estado=n.estado||'';D.cidade=n.cidade||'';
  D.fat=(n.faturamento_anual||0)/12;D.regime=n.regime_tributario||'';
  D.prolabore=n.prolabore_mensal||n.prolabore||0;
  D.folha=n.folha_pagamento||0;
  D.aluguel=n.aluguel_mensal||0;D.contas=n.contas_mensais||0;
  D.terceiros=n.terceiros_mensais||0;D.mkt=n.mkt_mensal||0;D.outras=n.outras_desp_mensais||0;
  D.divida_total=n.divida_total||0;D.parcelas=n.parcelas_mensais||0;
  D.tem_divida=D.divida_total>0?'sim':'nao';
  D.urgencia=parseInt(n.urgencia)||5;
  D.preco_esperado=n.preco_pedido||0;

  // Pilares
  if(n.score_pilares){try{var sp=JSON.parse(n.score_pilares);sp.forEach(function(p){D[p.id]=p.val;});}catch(e){}}

  // Notas
  D.notas_admin=n.notas_admin||'';

  // Ativos/passivos dos JSON
  if(n.ativos_json){try{var a=JSON.parse(n.ativos_json);D.at_maq=a.maquinas||0;D.at_mov=a.moveis||0;D.at_veic=a.veiculos||0;D.at_ti=a.ti||0;D.at_ref=a.reformas||0;D.at_est=a.estoque||0;D.at_rec=a.receber||0;D.at_cx=a.caixa||0;}catch(e){}}
  if(n.passivos_json){try{var p=JSON.parse(n.passivos_json);D.pa_forn=p.fornecedores||0;D.pa_trib=p.tributario||0;D.pa_banc=p.bancario||0;D.pa_out=p.outros||0;}catch(e){}}

  preencherFormulario();
  atualizarStatus(n.status);

  // Inicializar DRE multicanal no bloco 09
  document.getElementById('dre-mc-toolbar').style.display='flex';
  DRE_MC.init(id,'dre-mc-container');

  // Carregar docs do repositório
  var docs=await sb.from('anuncio_documentos').select('*').eq('negocio_id',id).order('created_at');
  DOCS_REPO=docs.data||[];
  renderRepo();

  // Status do header
  document.getElementById('badge-status').textContent=statusLabel(n.status);
}

async function carregarVendedor(id){
  var res=await sb.from('usuarios').select('nome,email').eq('id',id).single();
  if(res.data){
    VENDOR_NOME=res.data.nome||res.data.email||'—';
    document.getElementById('hdr-vendor').textContent='→ '+VENDOR_NOME;
    document.getElementById('vendor-sel').textContent=VENDOR_NOME+' ('+res.data.email+')';
    document.getElementById('vendor-sel').style.color='var(--green)';
    document.getElementById('bs-0').textContent='OK';
    document.getElementById('bs-0').style.background='rgba(16,185,129,.1)';
    document.getElementById('bs-0').style.color='var(--green)';
  }
}

function preencherFormulario(){
  setV('f-nome',D.nome);setV('f-detalhe',D.detalhe);setV('f-ano',D.ano);
  setV('f-estado',D.estado);setV('f-cidade',D.cidade);
  setV('f-fat',D.fat||'');setV('f-folha',D.folha||'');setV('f-prolabore',D.prolabore||'');
  setV('f-aluguel',D.aluguel||'');setV('f-contas',D.contas||'');
  setV('f-terceiros',D.terceiros||'');setV('f-mkt',D.mkt||'');setV('f-outras',D.outras||'');
  setV('f-divida-total',D.divida_total||'');setV('f-parcelas',D.parcelas||'');
  setV('f-at-maq',D.at_maq||'');setV('f-at-mov',D.at_mov||'');setV('f-at-veic',D.at_veic||'');
  setV('f-at-ti',D.at_ti||'');setV('f-at-ref',D.at_ref||'');setV('f-at-est',D.at_est||'');
  setV('f-at-rec',D.at_rec||'');setV('f-at-cx',D.at_cx||'');
  setV('f-pa-forn',D.pa_forn||'');setV('f-pa-trib',D.pa_trib||'');
  setV('f-pa-banc',D.pa_banc||'');setV('f-pa-out',D.pa_out||'');
  setV('f-preco-esperado',D.preco_esperado||'');
  setV('f-categoria',D.categoria);setV('f-estado',D.estado);
  document.getElementById('sl-urgencia').value=D.urgencia||5;
  document.getElementById('sv-urg').textContent=D.urgencia||5;
  setV('notas-internas',D.notas_admin);
  if(D.regime)highlightOpt('reg-'+D.regime);
  if(D.motivo)highlightOpt('mot-'+D.motivo);
  if(D.imovel){highlightOpt('im-'+D.imovel);toggleImovelDet();}
  if(D.tem_cmv){highlightOpt('cmv-'+D.tem_cmv);toggleCMV();}
  if(D.tem_divida){highlightOpt('div-'+D.tem_divida);toggleDivida();}
  if(D.franquia){highlightOpt('fran-'+D.franquia);if(D.franquia==='sim'){document.getElementById('fran-nome-wrap').style.display='block';setV('f-franquia-nome',D.franquia_nome);}}
  if(D.modelo)highlightOpt('mod-'+D.modelo);
  // Contadores
  updCounter('clt');updCounter('pj');updCounter('socios');
  atualizarApetite();
}

function setV(id,val){var el=document.getElementById(id);if(el)el.value=val||'';}
function updCounter(campo){var el=document.getElementById('cv-'+campo);if(el)el.textContent=D[campo]||0;}

// ── NAVEGAÇÃO DOS BLOCOS ───────────────────────────────────────
function toggleBloco(hdr){
  var bloco=hdr.closest('.bloco');
  bloco.classList.toggle('open');
}

function switchSTab(id,tab){
  document.querySelectorAll('.stab').forEach(function(t){t.classList.remove('on');});
  document.querySelectorAll('.sidebar-panel').forEach(function(p){p.classList.remove('on');});
  tab.classList.add('on');
  document.getElementById('stab-'+id).classList.add('on');
}

// ── OPÇÕES E SELETORES ─────────────────────────────────────────
function setOpt(campo,val,prefix){
  D[campo]=val;
  document.querySelectorAll('[id^="'+prefix+'"]').forEach(function(b){b.classList.remove('sel');});
  var el=document.getElementById(prefix+val);
  if(el)el.classList.add('sel');
  autoSalvar();
}

function highlightOpt(id){var el=document.getElementById(id);if(el)el.classList.add('sel');}

function adj(campo,delta){
  D[campo]=Math.max(0,(D[campo]||0)+delta);
  updCounter(campo);
  autoSalvar();
}

function toggleTag(tag,btn){
  if(!Array.isArray(D.divida_tags))D.divida_tags=[];
  var i=D.divida_tags.indexOf(tag);
  if(i>=0){D.divida_tags.splice(i,1);btn.classList.remove('sel');}
  else{D.divida_tags.push(tag);btn.classList.add('sel');}
}

function toggleImovelDet(){
  var show=['proprio','alugado'].includes(D.imovel);
  document.getElementById('imovel-det').style.display=show?'block':'none';
  if(D.imovel==='proprio'){
    document.getElementById('aluguel-wrap').style.display='none';
    document.getElementById('imovel-valor-wrap').style.display='block';
  }else{
    document.getElementById('aluguel-wrap').style.display='block';
    document.getElementById('imovel-valor-wrap').style.display='none';
  }
}

function toggleCMV(){
  document.getElementById('cmv-det').style.display=D.tem_cmv==='sim'?'block':'none';
}

function toggleCMVModo(){
  document.getElementById('cmv-pct-wrap').style.display=D.cmv_modo==='pct'?'block':'none';
  document.getElementById('cmv-val-wrap').style.display=D.cmv_modo==='val'?'block':'none';
  document.getElementById('cmv-markup-wrap').style.display=D.cmv_modo==='markup'?'block':'none';
}

function toggleDivida(){
  document.getElementById('divida-det').style.display=D.tem_divida==='sim'?'block':'none';
}

// ── BUILD PILARES ──────────────────────────────────────────────
function buildPilares(){
  // P1 cards
  var p1opts=[[0,'Tudo pararia. Sou o centro de tudo.'],[2,'Grande parte pararia.'],[4,'Continua com dificuldades.'],[6,'Funciona, mas decisões passam por mim.'],[8,'Funciona bem sem mim.'],[10,'Operação totalmente autônoma.']];
  document.getElementById('p1-opts').innerHTML=p1opts.map(function(o){
    return '<button class="pilar-opt'+(D.p1===o[0]?' sel':'')+'" onclick="selPilar(\'p1\','+o[0]+',this)">'+o[1]+'</button>';
  }).join('');

  // P2 slider
  buildSlider('p2-slider','p2',D.p2,10,'Vendas aleatórias, sem processo','Processo comercial estruturado e previsível');

  // P3 cards
  var p3opts=[[0,'A oferta é confusa ou muda muito.'],[2,'Clara internamente, pouco estruturada.'],[4,'Boa entrega, sem padronização definida.'],[6,'Oferta clara e consistente.'],[8,'Oferta estruturada, com recorrência possível.'],[10,'Bem posicionada, com marca forte.']];
  document.getElementById('p3-opts').innerHTML=p3opts.map(function(o){
    return '<button class="pilar-opt'+(D.p3===o[0]?' sel':'')+'" onclick="selPilar(\'p3\','+o[0]+',this)">'+o[1]+'</button>';
  }).join('');

  // P4 slider
  buildSlider('p4-slider','p4',D.p4,10,'Sem processos — tudo na cabeça das pessoas','Processos claros, documentados, com indicadores');

  // P5 cards
  var p5opts=[[0,'Prejuízo recorrente ou sem controle.'],[2,'Às vezes positivo, muito variável.'],[4,'Positivo, mas pequeno ou inconsistente.'],[6,'Positivo e relativamente previsível.'],[8,'Margem saudável e consistente.'],[10,'Resultado sólido, crescente e monitorado.']];
  document.getElementById('p5-opts').innerHTML=p5opts.map(function(o){
    return '<button class="pilar-opt'+(D.p5===o[0]?' sel':'')+'" onclick="selPilar(\'p5\','+o[0]+',this)">'+o[1]+'</button>';
  }).join('');

  // P8 slider
  buildSlider('p8-slider','p8',D.p8,10,'Várias pendências — fiscal, trabalhista, jurídico','Tudo regularizado, sem passivos relevantes');

  // P9 cards
  var p9opts=[[0,'1-2 clientes = mais de 70% do faturamento.'],[2,'3-5 clientes = mais de 60%.'],[4,'Alguma concentração, mas distribuída.'],[6,'Bem distribuída, sem dependência excessiva.'],[8,'Nenhum cliente acima de 15%.'],[10,'Receita pulverizada e recorrente.']];
  document.getElementById('p9-opts').innerHTML=p9opts.map(function(o){
    return '<button class="pilar-opt'+(D.p9===o[0]?' sel':'')+'" onclick="selPilar(\'p9\','+o[0]+',this)">'+o[1]+'</button>';
  }).join('');

  // P10 slider (0-100)
  buildSliderP10();
}

function buildSlider(containerId,campo,val,max,labelMin,labelMax){
  var el=document.getElementById(containerId);
  if(!el)return;
  el.innerHTML='<div class="slider-wrap">'
    +'<input type="range" min="0" max="'+max+'" step="1" value="'+(val||0)+'" '
    +'oninput="D.'+campo+'=parseInt(this.value);document.getElementById(\'sv-'+campo+'\').textContent=this.value;recalcular()">'
    +'<div class="slider-labels"><span>0 — '+labelMin+'</span><span>10 — '+labelMax+'</span></div>'
    +'<div class="slider-val-display" id="sv-'+campo+'">'+(val||0)+'</div>'
    +'</div>';
}

function buildSliderP10(){
  var el=document.getElementById('p10-slider');
  if(!el)return;
  var val=D.p10!==null?D.p10:50;
  el.innerHTML='<div class="slider-wrap">'
    +'<input type="range" min="0" max="100" step="5" value="'+val+'" '
    +'oninput="D.p10=parseInt(this.value);document.getElementById(\'sv-p10\').textContent=this.value+\'%\';recalcular()">'
    +'<div class="slider-labels"><span>0% — Sem espaço para crescer</span><span>100% — Dobraria sem aumentar custos</span></div>'
    +'<div class="slider-val-display" id="sv-p10">'+val+'%</div>'
    +'</div>';
}

function selPilar(campo,val,btn){
  D[campo]=val;
  var container=btn.closest('[id$="-opts"]');
  if(container)container.querySelectorAll('.pilar-opt').forEach(function(b){b.classList.remove('sel');});
  btn.classList.add('sel');
  recalcular();
}

// ── APETITE ────────────────────────────────────────────────────
function setApetite(eixo,val,prefix){
  D['apetite_'+eixo]=val;
  document.querySelectorAll('[id^="'+prefix+'"]').forEach(function(b){b.classList.remove('sel');});
  var el=document.getElementById(prefix+val);
  if(el)el.classList.add('sel');
  atualizarApetite();
}

function atualizarApetite(){
  var urg=Math.round((D.urgencia||5)/10*3); // converte 1-10 para 0-3
  D.apetite_urgencia=urg;
  var score=(D.apetite_urgencia||0)+(D.apetite_abertura||0);
  var label=score<=1?'Firme, mas ouve propostas':score<=3?'Aberto a negociação':score<=5?'Motivado a vender':'Flexível';
  document.getElementById('apetite-label').textContent=label;
  document.getElementById('apetite-score').textContent=score+'/6';
}

// ── CÁLCULO ────────────────────────────────────────────────────
function calcImpostos(){
  var fat=D.fat||0;
  var aliq={mei:0.05,simples:0.10,presumido:0.12,real:0.15,pf:0.10,'':0.10};
  return fat*(aliq[D.regime]||0.10);
}

function calcCMV(){
  var fat=D.fat||0;
  if(D.tem_cmv!=='sim')return 0;
  if(D.cmv_modo==='pct')return fat*(D.cmv_pct||0)/100;
  if(D.cmv_modo==='val')return D.cmv_val||0;
  if(D.cmv_modo==='markup'&&D.markup_venda>0)return fat*(1-D.markup_comp/D.markup_venda);
  return 0;
}

function somaAtivos(){
  return (D.at_maq||0)+(D.at_mov||0)+(D.at_veic||0)+(D.at_ti||0)+(D.at_ref||0)+(D.at_est||0)+(D.at_rec||0)+(D.at_cx||0)+(D.imovel_valor||0);
}

function somaPassivos(){
  return (D.pa_forn||0)+(D.pa_trib||0)+(D.pa_banc||0)+(D.pa_out||0)+(D.divida_total||0);
}

function calcResultado(){
  var fat=D.fat||0;
  var imp=calcImpostos();
  var cmv=calcCMV();
  var desp=(D.folha||0)+(D.aluguel||0)+(D.contas||0)+(D.terceiros||0)+(D.mkt||0)+(D.outras||0);
  var result=fat-imp-cmv-desp;
  var caixa=result-(D.parcelas||0)-(D.prolabore||0);

  // Score
  var pilares=['p1','p2','p3','p4','p5','p8','p9','p10'];
  var p6_auto=Math.min(10,Math.max(0,((somaAtivos()-somaPassivos())/Math.max(fat*12,1))*10));
  var p7_auto=D.divida_total>0?Math.min(10,Math.max(0,10-((D.divida_total/(Math.max(result*12,1))*5)))):10;
  D.p6=Math.round(p6_auto);D.p7=Math.round(p7_auto);

  var score=0;
  ['p1','p2','p3','p4','p5','p6','p7','p8','p9','p10'].forEach(function(p){
    var v=D[p]!==null&&D[p]!==undefined?D[p]:5;
    if(p==='p10')v=v/10;
    score+=(v/10)*CONFIG.pesos[p];
  });
  score=Math.round(score);

  // Múltiplo
  var sub=CONFIG.subcategorias.find(function(s){return s.cats.includes(D.categoria);})||CONFIG.subcategorias[CONFIG.subcategorias.length-1];
  var mult_base=(sub.mult_min+sub.mult_max)/2;

  // Fator maturidade
  var pcfg=CONFIG.premios.find(function(p){return score>=p.min&&score<=p.max;})||CONFIG.premios[0];
  var fator=pcfg.fator;
  if(score>40&&score<=60)fator=0.80+((score-40)/20)*0.25;
  else if(score>60&&score<=80)fator=1.05+((score-60)/20)*0.15;
  else if(score>80)fator=1.20+((score-80)/20)*0.10;
  fator=Math.round(fator*100)/100;

  var mult_ajustado=Math.round(mult_base*fator*100)/100;
  var valor_negocio=Math.max(0,result*12*mult_ajustado);
  var balanco=somaAtivos()-somaPassivos();
  var valor_venda=valor_negocio+balanco;

  return {fat,imp,cmv,desp,result,caixa,score,mult_base,fator,mult_ajustado,pcfg,
          ativos:somaAtivos(),passivos:somaPassivos(),balanco,valor_negocio,valor_venda,sub};
}

function recalcular(){
  try{
    RESULTADO=calcResultado();
    renderDREPreview();
    renderResultadoFinal();
    atualizarApetite();
  }catch(e){console.error('recalcular',e);}
}

function renderDREPreview(){
  var R=RESULTADO;if(!R)return;
  var el=document.getElementById('dre-preview-table');if(!el)return;
  function row(l,v,cls){return '<tr'+(cls?' class="'+cls+'"':'')+' ><td>'+l+'</td><td style="color:'+(cls==='total'?'var(--green)':cls==='subtotal'?'var(--blue)':'var(--ink2)')+'">'+fmtBRL(v)+'</td></tr>';}
  el.innerHTML='<table class="dre-table">'
    +row('(+) Faturamento bruto mensal',R.fat)
    +row('(−) Impostos estimados',-R.imp)
    +row('(−) CMV',-R.cmv)
    +row('(−) Despesas fixas',-R.desp)
    +row('= Resultado operacional',R.result,'subtotal')
    +row('(−) Parcelas de dívida',-((D.parcelas||0)))
    +row('(−) Pró-labore',-((D.prolabore||0)))
    +row('= Geração de caixa real',R.caixa,'total')
    +'<tr><td colspan="2" style="padding:4px 10px;font-size:9px;color:var(--ink3)">Balanço: ativos '+fmtBRL(R.ativos)+' · passivos '+fmtBRL(R.passivos)+'</td></tr>'
    +'</table>';
}

function renderResultadoFinal(){
  var R=RESULTADO;if(!R)return;
  var el=document.getElementById('resultado-final');if(!el)return;
  var scoreCor=R.score>=81?'var(--green)':R.score>=61?'#fbbf24':R.score>=41?'var(--amber)':'var(--red)';

  el.innerHTML='<div class="resultado-card">'
    +'<div class="resultado-title">Resultado calculado — V'+CONFIG.versao+'</div>'
    +'<div class="resultado-row"><span>Resultado operacional/mês</span><span style="color:var(--green)">'+fmtBRL(R.result)+'</span></div>'
    +'<div class="resultado-row"><span>Resultado anual</span><span>'+fmtBRL(R.result*12)+'</span></div>'
    +'<div class="resultado-row"><span>Múltiplo base ('+R.sub.label+')</span><span>'+R.mult_base.toFixed(2)+'×</span></div>'
    +'<div class="resultado-row"><span>Score de saúde</span><span style="color:'+scoreCor+'">'+R.score+'/100 · '+R.pcfg.label+'</span></div>'
    +'<div class="resultado-row"><span>Fator maturidade</span><span>'+R.fator+'× → múltiplo ajustado '+R.mult_ajustado.toFixed(2)+'×</span></div>'
    +'<div class="resultado-row"><span>Valor do Negócio (EV)</span><span style="color:var(--blue)">'+fmtBRL(R.valor_negocio)+'</span></div>'
    +'<div class="resultado-row"><span>Balanço (ativos − passivos)</span><span style="color:'+(R.balanco>=0?'var(--green)':'var(--red)')+'">'+fmtBRL(R.balanco)+'</span></div>'
    +'<div class="resultado-row total"><span>Valor de Venda (porteira fechada)</span><span>'+fmtBRL(R.valor_venda)+'</span></div>'
    +(D.preco_esperado>0?'<div style="margin-top:10px;padding:8px 12px;background:rgba(255,255,255,.03);font-size:11px;color:var(--ink2)">Expectativa do vendedor: <strong>'+fmtBRL(D.preco_esperado)+'</strong> · '
      +calcTagPreco(D.preco_esperado,R.valor_venda)+'</div>':'')
    +'</div>';

  // Score pilares
  var pilEl=document.getElementById('score-pilares-display');
  if(pilEl){
    var nomes={p1:'Sócios',p2:'Comercial',p3:'Produto',p4:'Gestão',p5:'Resultado',p6:'Balanço',p7:'Dívida',p8:'Jurídico',p9:'Concentr.',p10:'Escala'};
    pilEl.innerHTML=['p1','p2','p3','p4','p5','p6','p7','p8','p9','p10'].map(function(p){
      var v=D[p]!==null&&D[p]!==undefined?D[p]:5;
      var pct=p==='p10'?v:v*10;
      return '<div class="score-pilar"><div class="score-pilar-nome">'+nomes[p]+'</div>'
        +'<div class="score-pilar-val" style="color:'+(pct>=70?'var(--green)':pct>=40?'var(--amber)':'var(--red)')+'">'+v+'</div>'
        +'</div>';
    }).join('');
  }

  document.getElementById('bs-19').textContent='Calculado';
  document.getElementById('bs-19').style.background='rgba(16,185,129,.1)';
  document.getElementById('bs-19').style.color='var(--green)';
}

function calcTagPreco(pedido,calculado){
  var diff=(pedido-calculado)/calculado*100;
  if(diff<=-20)return '<span style="color:var(--green)">🟢 Oportunidade</span>';
  if(diff<-10)return '<span style="color:var(--blue)">🔵 Abaixo do preço</span>';
  if(diff<=10)return '<span style="color:var(--ink2)">⚪ Na faixa</span>';
  if(diff<=20)return '<span style="color:var(--amber)">🟡 Levemente acima</span>';
  return '<span style="color:var(--red)">🔴 Acima do preço</span>';
}

// ── BUSCA DE VENDEDOR ──────────────────────────────────────────
var _vtimer=null;
function buscarVendedor(q){
  clearTimeout(_vtimer);
  var res=document.getElementById('busca-resultado');
  if(q.length<2){res.style.display='none';return;}
  _vtimer=setTimeout(async function(){
    var r=await sb.from('usuarios').select('id,nome,email').ilike('email','%'+q+'%').limit(8);
    var users=r.data||[];
    if(!users.length){res.style.display='none';return;}
    res.style.display='block';
    res.innerHTML=users.map(function(u){
      return '<div onclick="selecionarVendedor(\''+u.id+'\',\''+esc(u.nome||u.email)+'\')" '
        +'style="padding:9px 12px;cursor:pointer;border-bottom:.5px solid var(--sep);font-size:11px;color:var(--ink2)" '
        +'onmouseover="this.style.background=\'var(--surface3)\'" onmouseout="this.style.background=\'\'">'
        +(u.nome||'—')+' <span style="color:var(--ink3)">'+u.email+'</span></div>';
    }).join('');
  },300);
}

function selecionarVendedor(id,nome){
  VENDOR_ID=id;VENDOR_NOME=nome;
  document.getElementById('vendor-sel').textContent=nome;
  document.getElementById('vendor-sel').style.color='var(--green)';
  document.getElementById('busca-resultado').style.display='none';
  document.getElementById('busca-vendor').value='';
  document.getElementById('hdr-vendor').textContent='→ '+nome;
  document.getElementById('bs-0').textContent='OK';
  document.getElementById('bs-0').style.background='rgba(16,185,129,.1)';
  document.getElementById('bs-0').style.color='var(--green)';
}

async function criarVendedor(){
  var email=prompt('E-mail do novo vendedor:');if(!email)return;
  var nome=prompt('Nome:');
  var res=await sb.from('usuarios').insert({email,nome:nome||email.split('@')[0],tipo:'sell',created_at:new Date().toISOString()}).select('id').single();
  if(res.error){toast('Erro: '+res.error.message);return;}
  selecionarVendedor(res.data.id,nome||email);
  toast('Usuário criado. Deve criar senha no primeiro acesso pelo portal.');
}

// ── REPOSITÓRIO ────────────────────────────────────────────────
async function uploadRepo(input){
  if(!NEG_ID){toast('Salve o rascunho primeiro para associar documentos.');return;}
  var files=Array.from(input.files);
  for(var i=0;i<files.length;i++){
    var f=files[i];
    var path=NEG_ID+'/'+Date.now()+'_'+f.name.replace(/[^a-zA-Z0-9._-]/g,'_');
    var up=await sb.storage.from('documentos').upload(path,f,{upsert:true});
    if(up.error){toast('Erro upload: '+f.name+' — '+up.error.message);continue;}
    var ins=await sb.from('anuncio_documentos').insert({negocio_id:NEG_ID,nome:f.name,storage_path:path,tamanho_bytes:f.size}).select('id').single();
    if(ins.data)DOCS_REPO.push({id:ins.data.id,nome:f.name,storage_path:path,tamanho_bytes:f.size});
  }
  renderRepo();
  toast(files.length+' arquivo(s) enviado(s)');
}

async function salvarTextoRepo(){
  var txt=document.getElementById('repo-texto-input').value.trim();
  if(!txt){toast('Digite ou cole um texto primeiro.');return;}
  if(!NEG_ID){toast('Salve o rascunho primeiro.');return;}

  // Salvar como arquivo .txt no storage
  var nomeArq='transcricao_'+new Date().toISOString().slice(0,16).replace('T','_').replace(':','')+'.txt';
  var blob=new Blob([txt],{type:'text/plain;charset=utf-8'});
  var path=NEG_ID+'/'+Date.now()+'_'+nomeArq;
  var up=await sb.storage.from('documentos').upload(path,blob,{upsert:true,contentType:'text/plain'});
  if(up.error){toast('Erro ao salvar: '+up.error.message);return;}
  var ins=await sb.from('anuncio_documentos').insert({negocio_id:NEG_ID,nome:nomeArq,storage_path:path,tamanho_bytes:blob.size}).select('id').single();
  if(ins.data)DOCS_REPO.push({id:ins.data.id,nome:nomeArq,storage_path:path,tamanho_bytes:blob.size});
  document.getElementById('repo-texto-input').value='';
  renderRepo();
  toast('Transcrição salva no repositório ✓');
}

function renderRepo(){
  var el=document.getElementById('repo-lista');
  if(!DOCS_REPO.length){el.innerHTML='<div style="padding:20px;text-align:center;color:var(--ink3);font-size:11px">Nenhum documento ainda</div>';return;}
  el.innerHTML='<div>'+DOCS_REPO.map(function(d){
    return '<div class="repo-item">'
      +'<span class="repo-nome" title="'+esc(d.nome)+'">'+esc(d.nome)+'</span>'
      +'<span class="repo-size">'+Math.round((d.tamanho_bytes||0)/1024)+'KB</span>'
      +'<button class="repo-del" onclick="delDoc(\''+d.id+'\')">×</button>'
      +'</div>';
  }).join('')+'</div>';
}

async function delDoc(id){
  await sb.from('anuncio_documentos').delete().eq('id',id);
  DOCS_REPO=DOCS_REPO.filter(function(d){return d.id!==id;});
  renderRepo();
}

// ── COPILOT IA ─────────────────────────────────────────────────
async function acionarCopilot(){
  if(!DOCS_REPO.length){toast('Adicione documentos ao repositório primeiro.');return;}
  var btn=document.getElementById('btn-copilot');
  btn.textContent='✦ Analisando...';btn.disabled=true;
  var log=document.getElementById('copilot-log');
  log.style.display='block';log.textContent='Iniciando análise dos documentos...\n';

  try{
    log.textContent+='Enviando para Copilot IA...\n';
    var response=await fetch('https://dbijmgqlcrgjlcfrastg.supabase.co/functions/v1/copilot-coleta',{
      method:'POST',
      headers:{
        'Content-Type':'application/json',
        'apikey':'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRiaWptZ3FsY3JnamxjZnJhc3RnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMwNzYxNjMsImV4cCI6MjA4ODY1MjE2M30.mV2rANZ8Nb_AbifTmkEvdfX_nsm8zeT6Al_bPrCzNAA'
      },
      body:JSON.stringify({documentos:DOCS_REPO})
    });
    var data=await response.json();
    if(!data.ok)throw new Error(data.erro||'Erro desconhecido');
    var sug=data.sugestoes||{};
    log.textContent+='Análise concluída. Preenchendo campos...\n';

    // Aplicar sugestões
    var campos=['nome','detalhe','estado','cidade','regime'];
    campos.forEach(function(c){if(sug[c]!==null&&sug[c]!==undefined){D[c]=sug[c];}});
    var numericos=['fat','cmv_pct','folha','prolabore','aluguel','contas','divida_total','urgencia'];
    numericos.forEach(function(c){if(sug[c]!==null&&sug[c]!==undefined){D[c]=parseFloat(sug[c])||0;}});
    var pilares=['p1','p2','p3','p4','p5','p8','p9'];
    pilares.forEach(function(p){if(sug[p]!==null&&sug[p]!==undefined){D[p]=parseInt(sug[p])||5;}});
    if(sug.p10!==null&&sug.p10!==undefined)D.p10=parseInt(sug.p10)||50;
    if(sug.categoria)D.categoria=sug.categoria;
    if(sug.tem_cmv)D.tem_cmv=sug.tem_cmv;

    // Observações
    var obs_campos=['obs_identidade','obs_faturamento','obs_p1','obs_p2','obs_dre'];
    obs_campos.forEach(function(c){if(sug[c]){D[c]=sug[c];}});

    preencherFormulario();
    buildPilares();
    recalcular();

    log.textContent+='✓ Campos preenchidos. Revise e confirme antes de salvar.\n';
    toast('Copilot IA preencheu os campos. Revise antes de salvar.');
  }catch(e){
    log.textContent+='Erro: '+e.message+'\n';
    toast('Erro no Copilot: '+e.message);
  }

  btn.textContent='✦ Copilot IA';btn.disabled=false;
  setTimeout(function(){log.style.display='none';},8000);
}

// ── SALVAR ─────────────────────────────────────────────────────
function autoSalvar(){
  clearTimeout(_autoSalvarTimer);
  _autoSalvarTimer=setTimeout(function(){salvar('rascunho',true);},3000);
}

async function salvar(statusDestino,silencioso){
  if(!VENDOR_ID){if(!silencioso)toast('Vincule um vendedor primeiro.');return;}

  var R;
  try{ R=RESULTADO||calcResultado(); }
  catch(e){ R={result:0,caixa:0,score:0,mult_base:1,mult_ajustado:1,valor_negocio:0,valor_venda:0}; }

  var dados={
    vendedor_id:VENDOR_ID,
    nome:D.nome||D.detalhe||'Rascunho',
    categoria:D.categoria||null,detalhe:D.detalhe||null,
    estado:D.estado||null,cidade:D.cidade||null,
    faturamento_anual:(D.fat||0)*12,
    regime_tributario:D.regime||null,
    folha_pagamento:D.folha||null,prolabore_mensal:D.prolabore||null,
    aluguel_mensal:D.aluguel||null,contas_mensais:D.contas||null,
    terceiros_mensais:D.terceiros||null,mkt_mensal:D.mkt||null,outras_desp_mensais:D.outras||null,
    divida_total:D.divida_total||null,parcelas_mensais:D.parcelas||null,
    resultado_liquido_mensal:R.result||0,caixa_mensal:R.caixa||0,
    score_saude:R.score||0,
    score_pilares:['p1','p2','p3','p4','p5','p6','p7','p8','p9','p10'].map(function(p){return {id:p,val:D[p]||null};}),
    mult_base:R.mult_base||1,mult_ajustado:R.mult_ajustado||1,
    valor_negocio:Math.round(R.valor_negocio||0),
    valor_venda:Math.round(R.valor_venda||0),
    valor_negocio_min:Math.round((R.valor_negocio||0)*0.85),
    valor_negocio_max:Math.round((R.valor_negocio||0)*1.15),
    valor_venda_min:Math.round((R.valor_venda||0)*0.85),
    valor_venda_max:Math.round((R.valor_venda||0)*1.15),
    ativos_json:JSON.stringify({maquinas:D.at_maq,moveis:D.at_mov,veiculos:D.at_veic,ti:D.at_ti,reformas:D.at_ref,estoque:D.at_est,receber:D.at_rec,caixa:D.at_cx,imovel:D.imovel_valor}),
    passivos_json:JSON.stringify({fornecedores:D.pa_forn,tributario:D.pa_trib,bancario:D.pa_banc,outros:D.pa_out}),
    motivo_venda:D.motivo||null,urgencia:String(D.urgencia||5),preco_pedido:D.preco_esperado||null,
    apetite_urgencia:D.apetite_urgencia||0,apetite_abertura:D.apetite_abertura||0,
    notas_admin:[
      D.notas_admin,
      D.obs_identidade?'[IDENTIDADE] '+D.obs_identidade:'',
      D.obs_localizacao?'[LOCALIZAÇÃO] '+D.obs_localizacao:'',
      D.obs_equipe?'[EQUIPE] '+D.obs_equipe:'',
      D.obs_faturamento?'[FINANCEIRO] '+D.obs_faturamento:'',
      D.obs_custos?'[CUSTOS] '+D.obs_custos:'',
      D.obs_dividas?'[DÍVIDAS] '+D.obs_dividas:'',
      D.obs_ativos?'[ATIVOS] '+D.obs_ativos:'',
      D.obs_passivos?'[PASSIVOS] '+D.obs_passivos:'',
      D.obs_dre?'[DRE] '+D.obs_dre:'',
      D.obs_p1?'[P1-SÓCIOS] '+D.obs_p1:'',
      D.obs_p2?'[P2-COMERCIAL] '+D.obs_p2:'',
      D.obs_p3?'[P3-PRODUTO] '+D.obs_p3:'',
      D.obs_p4?'[P4-GESTÃO] '+D.obs_p4:'',
      D.obs_p5?'[P5-RESULTADO] '+D.obs_p5:'',
      D.obs_p8?'[P8-JURÍDICO] '+D.obs_p8:'',
      D.obs_p9?'[P9-CONCENTR] '+D.obs_p9:'',
      D.obs_p10?'[P10-ESCALA] '+D.obs_p10:'',
      D.obs_intencao?'[INTENÇÃO] '+D.obs_intencao:'',
    ].filter(Boolean).join('\n\n'),
    status:statusDestino==='rascunho'?'rascunho':'em_avaliacao',
    plano:'gratuito',comissao_pct:10,
    config_versao:CONFIG.versao,
    updated_at:new Date().toISOString()
  };

  try{
    var res;
    if(NEG_ID){
      res=await sb.from('negocios').update(dados).eq('id',NEG_ID);
    }else{
      dados.created_at=new Date().toISOString();
      res=await sb.from('negocios').insert(dados).select('id').single();
      if(res.data&&res.data.id){
        NEG_ID=res.data.id;
        history.replaceState(null,'',window.location.pathname+'?negocio_id='+NEG_ID+'&vendedor_id='+VENDOR_ID);
        // Habilitar DRE no bloco 09
        document.getElementById('dre-mc-toolbar').style.display='flex';
        DRE_MC.negocioId=NEG_ID;
        DRE_MC.container=document.getElementById('dre-mc-container');
        DRE_MC.render();
      }
    }
    if(res&&res.error){
      if(!silencioso)toast('Erro ao salvar: '+res.error.message);
      console.error('salvar erro',res.error);
      return;
    }
    if(!silencioso)toast(statusDestino==='rascunho'?'Rascunho salvo! ✓':'Avaliação salva.');
    atualizarStatus(dados.status);
  }catch(e){
    if(!silencioso)toast('Erro inesperado: '+e.message);
    console.error('salvar catch',e);
  }
}

async function finalizarAvaliacao(){
  if(!VENDOR_ID){toast('Vincule um vendedor primeiro.');return;}
  if(!confirm('Finalizar a avaliação? O sistema vai gerar o laudo e o anúncio automaticamente. O vendedor será notificado para aprovar e definir o valor de venda.'))return;
  await salvar('em_avaliacao');
  if(!NEG_ID)return;
  // Atualizar para aguardando_aprovacao e registrar timestamps
  await sb.from('negocios').update({
    status:'aguardando_aprovacao',
    avaliacao_finalizada_em:new Date().toISOString(),
    avaliacao_finalizada_por:(await sb.auth.getSession()).data?.session?.user?.id||null,
    aprovacao_enviada_em:new Date().toISOString()
  }).eq('id',NEG_ID);
  // Criar item na fila do admin para acompanhar
  await sb.from('admin_fila').insert({tipo:'anuncio_revisao',titulo:'Avaliação finalizada — aguardando aprovação do vendedor',descricao:'Anúncio: '+(D.nome||D.detalhe||NEG_ID)+'. Aguardando aprovação e definição do valor de venda.',referencia_id:NEG_ID,referencia_tipo:'negocios',prioridade:'normal'});
  toast('Avaliação finalizada! Vendedor notificado para aprovar.');
  setTimeout(function(){window.location.href='/painel-admin.html';},2000);
}

function atualizarStatus(status){
  var b=document.getElementById('badge-status');
  var mapa={rascunho:{txt:'Rascunho',bg:'rgba(255,255,255,.06)',c:'var(--ink3)'},em_avaliacao:{txt:'Em avaliação',bg:'rgba(96,165,250,.1)',c:'var(--blue)'},aguardando_aprovacao:{txt:'Aguard. aprovação',bg:'rgba(245,158,11,.1)',c:'var(--amber)'},publicado:{txt:'Publicado',bg:'rgba(16,185,129,.1)',c:'var(--green)'}};
  var cfg=mapa[status]||mapa['rascunho'];
  b.textContent=cfg.txt;b.style.background=cfg.bg;b.style.color=cfg.c;b.style.border='.5px solid '+cfg.c+'44';
}

// ── UTILS ──────────────────────────────────────────────────────
function fmtBRL(v){if(!v&&v!==0)return'—';var s=v<0?'-':'';var a=Math.abs(v);if(a>=1e6)return s+'R$ '+(a/1e6).toFixed(2).replace('.',',')+'M';if(a>=1e3)return s+'R$ '+Math.round(a/1e3).toLocaleString('pt-BR')+' mil';return s+'R$ '+Math.round(a).toLocaleString('pt-BR');}
function maskMoney(el){var v=String(el.value).replace(/\D/g,'');if(!v){el.value='';return;}el.value=parseInt(v,10).toLocaleString('pt-BR');}
function parseMoney(v){if(!v)return 0;return parseFloat(String(v).replace(/\./g,'').replace(',','.'))||0;}
function statusLabel(s){return{rascunho:'Rascunho',em_avaliacao:'Em avaliação',aguardando_aprovacao:'Aguard. aprovação',publicado:'Publicado'}[s]||s||'Rascunho';}
function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function toast(msg){var el=document.getElementById('toast');el.textContent=msg;el.classList.add('on');setTimeout(function(){el.classList.remove('on');},3500);}

// ── SIDEBAR TOGGLE ─────────────────────────────────────────────
function toggleSidebar(){
  var sb=document.getElementById('admin-sidebar');
  var layout=document.querySelector('.layout');
  var btn=document.getElementById('sidebar-toggle-btn');
  sb.classList.toggle('collapsed');
  layout.classList.toggle('sidebar-collapsed');
  btn.title=sb.classList.contains('collapsed')?'Expandir':'Recolher';
}

// ── ATIVAR DRE MULTICANAL ──────────────────────────────────────
function ativarDREMC(){
  document.getElementById('dre-mc-toolbar').style.display='flex';
  if(NEG_ID){
    DRE_MC.init(NEG_ID,'dre-mc-container');
  } else {
    document.getElementById('dre-mc-container').innerHTML=
      '<div style="padding:12px;background:rgba(245,158,11,.06);border:.5px solid rgba(245,158,11,.2);font-size:11px;color:var(--amber)">Salve o rascunho primeiro para ativar a DRE multicanal.</div>';
  }
}

// ── DRE MULTICANAL (embutida no bloco 09) ─────────────────────
var DRE_MC={
  negocioId:null,colunas:[],linhas:[],celulas:{},despesas:[],container:null,

  async init(negocioId,containerId){
    this.negocioId=negocioId;
    this.container=document.getElementById(containerId);
    await this.carregar();
    this.render();
  },

  async carregar(){
    if(!this.negocioId)return;
    var[c,l,f,d]=await Promise.all([
      sb.from('dre_canais').select('*').eq('negocio_id',this.negocioId).order('ordem'),
      sb.from('dre_produtos').select('*').eq('negocio_id',this.negocioId).order('ordem'),
      sb.from('dre_fat_celulas').select('*').eq('negocio_id',this.negocioId),
      sb.from('dre_despesas').select('*').eq('negocio_id',this.negocioId).order('ordem'),
    ]);
    this.colunas=c.data||[];this.linhas=l.data||[];this.despesas=d.data||[];
    this.celulas={};
    (f.data||[]).forEach(function(x){
      if(!this.celulas[x.produto_id])this.celulas[x.produto_id]={};
      this.celulas[x.produto_id][x.canal_id]={id:x.id,valor:x.valor_mensal||0};
    }.bind(this));
  },

  fatCol(cid){return this.linhas.reduce(function(s,l){return s+(this.celulas[l.id]&&this.celulas[l.id][cid]?this.celulas[l.id][cid].valor:0);}.bind(this),0);},
  fatTotal(){return this.colunas.reduce(function(s,c){return s+this.fatCol(c.id);}.bind(this),0);},
  impCol(c){return this.fatCol(c.id)*(c.impostos_pct||0)/100;},
  cmvCol(c){return this.fatCol(c.id)*(c.cmv_pct||0)/100;},
  margCol(c){return this.fatCol(c.id)-this.impCol(c)-this.cmvCol(c);},
  totalDesp(){return this.despesas.reduce(function(s,d){return s+(d.valor_mensal||0);},0);},
  ebitda(){return this.colunas.reduce(function(s,c){return s+this.margCol(c);}.bind(this),0)-this.totalDesp();},
  fmt(n){if(!n&&n!==0)return'—';return'R$ '+Math.round(n).toLocaleString('pt-BR');},
  fmtA(n){return this.fmt((n||0)*12);},
  esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');},

  render(){
    if(!this.container)return;
    var C=this.colunas,L=this.linhas,self=this;
    if(!C.length&&!L.length){
      this.container.innerHTML='<div style="padding:16px;text-align:center;border:1px dashed var(--sep);font-size:10px;color:var(--ink3)">Use os botões acima para adicionar colunas e linhas.</div>';
      return;
    }
    var cw=C.length?Math.min(150,Math.floor(440/Math.max(C.length,1)))+'px':'150px';
    var grid='200px '+C.map(function(){return cw;}).join(' ')+' 120px 100px';
    var rd=function(bg,html){return '<div style="display:grid;grid-template-columns:'+grid+';gap:1px;background:'+bg+';margin-bottom:1px">'+html+'</div>';};

    var html='<div style="overflow-x:auto"><div style="min-width:500px">';

    // Cabeçalho colunas
    html+=rd('rgba(255,255,255,.06)',
      '<div class="dre-hd" style="color:var(--ink3)">—</div>'+
      C.map(function(c){return '<div class="dre-hd" style="position:relative"><input value="'+self.esc(c.nome)+'" onchange="DRE_MC.updCol(\''+c.id+'\',\'nome\',this.value)" style="background:transparent;border:none;color:var(--ink);font-family:inherit;font-size:9px;font-weight:700;letter-spacing:1px;text-transform:uppercase;width:calc(100% - 14px);text-align:center;outline:none"><button onclick="DRE_MC.delCol(\''+c.id+'\')" style="position:absolute;top:2px;right:2px;background:none;border:none;color:var(--red);cursor:pointer;font-size:10px">×</button></div>';}).join('')+
      '<div class="dre-hd" style="color:var(--green)">Total mês</div>'+
      '<div class="dre-hd" style="color:var(--ink3)">Anual ×12</div>'
    );

    // Impostos %
    html+=rd('rgba(255,255,255,.03)',
      '<div class="dre-sub-hd">Impostos % fat.</div>'+
      C.map(function(c){return '<div class="dre-cell-edit"><input type="number" value="'+(c.impostos_pct||0)+'" min="0" max="100" step="0.1" onchange="DRE_MC.updCol(\''+c.id+'\',\'impostos_pct\',parseFloat(this.value)||0)" style="width:50px;text-align:center;background:transparent;border:none;color:var(--amber);font-family:inherit;font-size:11px;outline:none">%</div>';}).join('')+
      '<div class="dre-cell-ro" style="color:var(--amber)">'+self.fmt(C.reduce(function(s,c){return s+self.impCol(c);},0))+'</div>'+
      '<div class="dre-cell-ro" style="color:var(--ink3)">—</div>'
    );

    // CMV %
    html+=rd('rgba(255,255,255,.03)',
      '<div class="dre-sub-hd">CMV % fat.</div>'+
      C.map(function(c){return '<div class="dre-cell-edit"><input type="number" value="'+(c.cmv_pct||0)+'" min="0" max="100" step="0.1" onchange="DRE_MC.updCol(\''+c.id+'\',\'cmv_pct\',parseFloat(this.value)||0)" style="width:50px;text-align:center;background:transparent;border:none;color:var(--red);font-family:inherit;font-size:11px;outline:none">%</div>';}).join('')+
      '<div class="dre-cell-ro" style="color:var(--red)">'+self.fmt(C.reduce(function(s,c){return s+self.cmvCol(c);},0))+'</div>'+
      '<div class="dre-cell-ro" style="color:var(--ink3)">—</div>'
    );

    // Linhas de receita
    html+='<div style="font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--ink3);padding:8px 0 4px;border-bottom:.5px solid var(--sep);margin-bottom:1px">Receita por linha × coluna</div>';
    L.forEach(function(l){
      html+=rd('rgba(255,255,255,.02)',
        '<div class="dre-row-label" style="display:flex;align-items:center;gap:4px"><input value="'+self.esc(l.nome)+'" onchange="DRE_MC.updLinha(\''+l.id+'\',\'nome\',this.value)" style="flex:1;background:transparent;border:none;color:var(--ink2);font-family:inherit;font-size:11px;outline:none"><button onclick="DRE_MC.delLinha(\''+l.id+'\')" style="background:none;border:none;color:var(--red);cursor:pointer;font-size:10px;opacity:.4">×</button></div>'+
        C.map(function(c){var v=self.celulas[l.id]&&self.celulas[l.id][c.id]?self.celulas[l.id][c.id].valor:0;return '<div class="dre-cell-input"><input type="text" value="'+(v?Math.round(v).toLocaleString('pt-BR'):'')+'" placeholder="0" onchange="DRE_MC.setCelula(\''+l.id+'\',\''+c.id+'\',parseMoney(this.value));maskMoney(this)" oninput="maskMoney(this)" style="width:100%;text-align:right;background:transparent;border:none;color:var(--ink);font-family:\'Syne\',sans-serif;font-size:12px;font-weight:700;outline:none"></div>';}).join('')+
        '<div class="dre-cell-ro">'+self.fmt(C.reduce(function(s,c){return s+(self.celulas[l.id]&&self.celulas[l.id][c.id]?self.celulas[l.id][c.id].valor:0);},0))+'</div>'+
        '<div class="dre-cell-ro" style="color:var(--ink3)">'+self.fmtA(C.reduce(function(s,c){return s+(self.celulas[l.id]&&self.celulas[l.id][c.id]?self.celulas[l.id][c.id].valor:0);},0))+'</div>'
      );
    });

    // Faturamento bruto
    html+=rd('rgba(16,185,129,.07)',
      '<div class="dre-total-label" style="color:var(--green);border-top:1px solid rgba(16,185,129,.3)">Faturamento Bruto</div>'+
      C.map(function(c){return '<div class="dre-cell-ro total" style="color:var(--green);border-top:1px solid rgba(16,185,129,.3)">'+self.fmt(self.fatCol(c.id))+'</div>';}).join('')+
      '<div class="dre-cell-ro total" style="color:var(--green);font-size:14px;border-top:1px solid rgba(16,185,129,.3)">'+self.fmt(self.fatTotal())+'</div>'+
      '<div class="dre-cell-ro" style="color:var(--ink3);border-top:1px solid rgba(16,185,129,.3)">'+self.fmtA(self.fatTotal())+'</div>'
    );

    // Impostos e CMV totais
    html+=rd('rgba(255,255,255,.02)',
      '<div class="dre-total-label" style="color:var(--ink3)">(−) Impostos</div>'+
      C.map(function(c){return '<div class="dre-cell-ro" style="color:var(--amber)">('+self.fmt(self.impCol(c))+')</div>';}).join('')+
      '<div class="dre-cell-ro" style="color:var(--amber)">('+self.fmt(C.reduce(function(s,c){return s+self.impCol(c);},0))+')</div>'+
      '<div class="dre-cell-ro" style="color:var(--ink3)">—</div>'
    );
    html+=rd('rgba(255,255,255,.02)',
      '<div class="dre-total-label" style="color:var(--ink3)">(−) CMV</div>'+
      C.map(function(c){return '<div class="dre-cell-ro" style="color:var(--red)">('+self.fmt(self.cmvCol(c))+')</div>';}).join('')+
      '<div class="dre-cell-ro" style="color:var(--red)">('+self.fmt(C.reduce(function(s,c){return s+self.cmvCol(c);},0))+')</div>'+
      '<div class="dre-cell-ro" style="color:var(--ink3)">—</div>'
    );

    // Margem de contribuição
    html+=rd('rgba(96,165,250,.06)',
      '<div class="dre-total-label" style="color:var(--blue);border-top:1px solid rgba(96,165,250,.25)">Margem Contribuição</div>'+
      C.map(function(c){var m=self.margCol(c),f=self.fatCol(c.id),p=f>0?Math.round(m/f*100):0;return '<div class="dre-cell-ro" style="color:var(--blue);border-top:1px solid rgba(96,165,250,.2)">'+self.fmt(m)+'<br><span style="font-size:9px;color:var(--ink3)">'+p+'%</span></div>';}).join('')+
      '<div class="dre-cell-ro total" style="color:var(--blue);font-size:14px;border-top:1px solid rgba(96,165,250,.25)">'+self.fmt(C.reduce(function(s,c){return s+self.margCol(c);},0))+'</div>'+
      '<div class="dre-cell-ro" style="color:var(--ink3);border-top:1px solid rgba(96,165,250,.2)">'+self.fmtA(C.reduce(function(s,c){return s+self.margCol(c);},0))+'</div>'
    );

    // Despesas fixas
    html+='<div style="font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--ink3);padding:8px 0 4px;border-bottom:.5px solid var(--sep);margin-bottom:1px">Despesas fixas</div>';
    self.despesas.forEach(function(d){
      html+=rd('rgba(255,255,255,.02)',
        '<div class="dre-row-label" style="display:flex;align-items:center;gap:4px"><input value="'+self.esc(d.nome)+'" onchange="DRE_MC.updDesp(\''+d.id+'\',\'nome\',this.value)" style="flex:1;background:transparent;border:none;color:var(--ink2);font-family:inherit;font-size:11px;outline:none"><button onclick="DRE_MC.delDesp(\''+d.id+'\')" style="background:none;border:none;color:var(--red);cursor:pointer;font-size:10px;opacity:.4">×</button></div>'+
        C.map(function(){return '<div class="dre-cell-ro" style="color:var(--ink3)">—</div>';}).join('')+
        '<div class="dre-cell-input"><input type="text" value="'+(d.valor_mensal?Math.round(d.valor_mensal).toLocaleString('pt-BR'):'')+'" placeholder="0" onchange="DRE_MC.updDesp(\''+d.id+'\',\'valor_mensal\',parseMoney(this.value));maskMoney(this)" oninput="maskMoney(this)" style="width:100%;text-align:right;background:transparent;border:none;color:var(--ink);font-family:\'Syne\',sans-serif;font-size:12px;font-weight:700;outline:none"></div>'+
        '<div class="dre-cell-ro" style="color:var(--ink3)">'+self.fmtA(d.valor_mensal)+'</div>'
      );
    });

    // Total despesas e EBITDA
    html+=rd('rgba(255,255,255,.03)',
      '<div class="dre-total-label" style="color:var(--ink3)">(−) Total despesas</div>'+
      C.map(function(){return '<div class="dre-cell-ro" style="color:var(--ink3)">—</div>';}).join('')+
      '<div class="dre-cell-ro" style="color:var(--red)">('+self.fmt(self.totalDesp())+')</div>'+
      '<div class="dre-cell-ro" style="color:var(--ink3)">('+self.fmtA(self.totalDesp())+')</div>'
    );
    var ebt=self.ebitda();
    html+='<div style="display:grid;grid-template-columns:'+grid+';gap:1px;background:rgba(16,185,129,.14);border-top:1px solid rgba(16,185,129,.5);border-bottom:1px solid rgba(16,185,129,.5)">'+
      '<div class="dre-total-label" style="color:var(--green);font-size:12px">EBITDA</div>'+
      C.map(function(){return '<div class="dre-cell-ro" style="color:var(--ink3)">—</div>';}).join('')+
      '<div class="dre-cell-ro total" style="color:'+(ebt>=0?'var(--green)':'var(--red)')+';font-size:16px;font-family:\'Syne\',sans-serif;font-weight:800">'+self.fmt(ebt)+'</div>'+
      '<div class="dre-cell-ro" style="color:var(--ink3)">'+self.fmtA(ebt)+'</div>'+
      '</div>';

    html+='</div></div>';
    this.container.innerHTML=html;
  },

  async addColuna(){
    var nome=prompt('Nome da coluna (canal, filial, região...):');if(!nome)return;
    if(!this.negocioId){toast('Salve o rascunho primeiro.');return;}
    var r=await sb.from('dre_canais').insert({negocio_id:this.negocioId,nome,ordem:this.colunas.length,impostos_pct:0,cmv_pct:0}).select().single();
    if(r.data){this.colunas.push(r.data);this.render();}
    else toast('Erro: '+(r.error?.message||''),true);
  },
  async addLinha(){
    var nome=prompt('Nome da linha (produto, serviço, unidade...):');if(!nome)return;
    if(!this.negocioId){toast('Salve o rascunho primeiro.');return;}
    var r=await sb.from('dre_produtos').insert({negocio_id:this.negocioId,nome,ordem:this.linhas.length}).select().single();
    if(r.data){this.linhas.push(r.data);this.render();}
  },
  async addDespesa(){
    var nome=prompt('Nome da despesa fixa (ex: Aluguel, Folha):');if(!nome)return;
    if(!this.negocioId){toast('Salve o rascunho primeiro.');return;}
    var r=await sb.from('dre_despesas').insert({negocio_id:this.negocioId,nome,valor_mensal:0,ordem:this.despesas.length}).select().single();
    if(r.data){this.despesas.push(r.data);this.render();}
  },
  async delCol(id){
    if(!confirm('Remover coluna?'))return;
    await sb.from('dre_fat_celulas').delete().eq('canal_id',id);
    await sb.from('dre_canais').delete().eq('id',id);
    this.colunas=this.colunas.filter(function(c){return c.id!==id;});
    Object.values(this.celulas).forEach(function(r){delete r[id];});
    this.render();
  },
  async delLinha(id){
    if(!confirm('Remover linha?'))return;
    await sb.from('dre_fat_celulas').delete().eq('produto_id',id);
    await sb.from('dre_produtos').delete().eq('id',id);
    this.linhas=this.linhas.filter(function(l){return l.id!==id;});
    delete this.celulas[id];
    this.render();
  },
  async delDesp(id){
    await sb.from('dre_despesas').delete().eq('id',id);
    this.despesas=this.despesas.filter(function(d){return d.id!==id;});
    this.render();
  },
  updCol(id,campo,val){var c=this.colunas.find(function(x){return x.id===id;});if(c){c[campo]=val;this.render();}},
  updLinha(id,campo,val){var l=this.linhas.find(function(x){return x.id===id;});if(l)l[campo]=val;},
  updDesp(id,campo,val){var d=this.despesas.find(function(x){return x.id===id;});if(d){d[campo]=val;this.render();}},
  setCelula(lid,cid,val){
    if(!this.celulas[lid])this.celulas[lid]={};
    if(!this.celulas[lid][cid])this.celulas[lid][cid]={};
    this.celulas[lid][cid].valor=val;
    this.render();
  },
  distribuirIgual(){
    var ts=prompt('Faturamento total mensal (R$):');var t=parseMoney(ts);
    if(!t||!this.colunas.length||!this.linhas.length)return;
    var pc=Math.round(t/(this.colunas.length*this.linhas.length));
    this.linhas.forEach(function(l){
      if(!this.celulas[l.id])this.celulas[l.id]={};
      this.colunas.forEach(function(c){this.celulas[l.id][c.id]={valor:pc};}.bind(this));
    }.bind(this));
    this.render();
    toast('Distribuído igualmente. Ajuste conforme necessário.');
  },
  async salvar(){
    if(!this.negocioId){toast('Salve o rascunho primeiro.');return;}
    try{
      for(var c of this.colunas)await sb.from('dre_canais').upsert({id:c.id,negocio_id:this.negocioId,nome:c.nome,impostos_pct:c.impostos_pct||0,cmv_pct:c.cmv_pct||0,ordem:c.ordem||0});
      for(var l of this.linhas)await sb.from('dre_produtos').upsert({id:l.id,negocio_id:this.negocioId,nome:l.nome,ordem:l.ordem||0});
      var ups=[];
      this.linhas.forEach(function(l){this.colunas.forEach(function(c){ups.push({negocio_id:this.negocioId,produto_id:l.id,canal_id:c.id,valor_mensal:this.celulas[l.id]&&this.celulas[l.id][c.id]?this.celulas[l.id][c.id].valor:0});}.bind(this));}.bind(this));
      if(ups.length)await sb.from('dre_fat_celulas').upsert(ups,{onConflict:'produto_id,canal_id'});
      for(var d of this.despesas)await sb.from('dre_despesas').upsert({id:d.id,negocio_id:this.negocioId,nome:d.nome,valor_mensal:d.valor_mensal||0,ordem:d.ordem||0});
      // Atualizar faturamento e EBITDA no negócio
      var fat=this.fatTotal(),ebt=this.ebitda();
      if(fat>0)await sb.from('negocios').update({faturamento_anual:fat*12,ebitda:ebt,updated_at:new Date().toISOString()}).eq('id',this.negocioId);
      toast('DRE salva! Faturamento e EBITDA atualizados. ✓');
    }catch(e){toast('Erro ao salvar DRE: '+e.message,true);}
  }
};

// ── CHAT IA FLUTUANTE ──────────────────────────────────────────
var CHAT_ABERTO=false;
var CHAT_HIST=[];

function toggleChat(){
  CHAT_ABERTO=!CHAT_ABERTO;
  document.getElementById('chat-ia-window').style.display=CHAT_ABERTO?'flex':'none';
  document.getElementById('chat-ia-badge').style.display='none';
  if(CHAT_ABERTO&&!CHAT_HIST.length){
    chatAddMsg('ia','Olá! Posso ajudar com análise dos documentos do repositório ou responder qualquer dúvida sobre o negócio, M&A, avaliação ou a plataforma. O que você precisa?');
  }
  if(CHAT_ABERTO)setTimeout(function(){document.getElementById('chat-ia-input').focus();},100);
}

function chatAddMsg(role,txt){
  CHAT_HIST.push({role:role,text:txt});
  renderChatMsgs();
}

function renderChatMsgs(){
  var el=document.getElementById('chat-ia-msgs');
  el.innerHTML=CHAT_HIST.map(function(m){
    var isIA=m.role==='ia';
    return '<div style="display:flex;gap:8px;margin-bottom:10px;align-items:flex-start;justify-content:'+(isIA?'flex-start':'flex-end')+'">'
      +(isIA?'<div style="width:20px;height:20px;background:rgba(167,139,250,.2);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0">✦</div>':'')
      +'<div style="max-width:85%;padding:8px 12px;background:'+(isIA?'var(--surface2)':'rgba(16,185,129,.12)')+';font-size:11px;color:var(--ink);line-height:1.6;white-space:pre-wrap">'+esc(m.text)+'</div>'
      +(isIA?'':'<div style="width:20px;height:20px;background:rgba(16,185,129,.2);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0">A</div>')
      +'</div>';
  }).join('');
  el.scrollTop=el.scrollHeight;
}

async function chatEnviar(){
  var inp=document.getElementById('chat-ia-input');
  var msg=inp.value.trim();if(!msg)return;
  inp.value='';
  chatAddMsg('user',msg);

  // Mostrar loading
  var loadId='load_'+Date.now();
  CHAT_HIST.push({role:'ia',text:'...',id:loadId});
  renderChatMsgs();

  // Montar contexto com info do negócio + docs
  var contexto='Você é um consultor de M&A da plataforma 1Negócio.com.br.\n';
  if(D.nome||D.detalhe)contexto+='Negócio em análise: '+(D.nome||D.detalhe||'')+' · Categoria: '+(D.categoria||'—')+' · Faturamento mensal: R$'+Math.round(D.fat||0).toLocaleString('pt-BR')+'\n';
  if(DOCS_REPO.length)contexto+='Documentos no repositório: '+DOCS_REPO.map(function(d){return d.nome;}).join(', ')+'\n';
  contexto+='\nResponda de forma direta e objetiva, em português.';

  var messages=[{role:'user',content:contexto+'\n\n---\n\n'+msg}];
  // Incluir histórico (últimas 6 trocas)
  var hist=CHAT_HIST.filter(function(m){return m.role!=='ia'||m.text!=='...';}).slice(-12);
  if(hist.length>1){
    messages=hist.slice(0,-1).map(function(m){return{role:m.role==='ia'?'assistant':'user',content:m.text};});
    messages.push({role:'user',content:msg});
    messages[0].content=contexto+'\n\n---\n\n'+messages[0].content;
  }

  try{
    var res=await fetch('https://dbijmgqlcrgjlcfrastg.supabase.co/functions/v1/chat-proxy',{
      method:'POST',
      headers:{'Content-Type':'application/json','apikey':'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRiaWptZ3FsY3JnamxjZnJhc3RnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMwNzYxNjMsImV4cCI6MjA4ODY1MjE2M30.mV2rANZ8Nb_AbifTmkEvdfX_nsm8zeT6Al_bPrCzNAA'},
      body:JSON.stringify({model:'claude-haiku-4-5-20251001',max_tokens:1000,messages:messages})
    });
    var data=await res.json();
    var reply=data.content?.[0]?.text||'Não consegui processar.';
    // Substituir loading pela resposta
    var idx=CHAT_HIST.findIndex(function(m){return m.id===loadId;});
    if(idx>=0)CHAT_HIST[idx]={role:'ia',text:reply};
    else CHAT_HIST.push({role:'ia',text:reply});
  }catch(e){
    var idx=CHAT_HIST.findIndex(function(m){return m.id===loadId;});
    if(idx>=0)CHAT_HIST[idx]={role:'ia',text:'Erro: '+e.message};
  }
  renderChatMsgs();
}
</script>

<!-- ── CHAT IA FLUTUANTE ── -->
<div style="position:fixed;bottom:24px;right:24px;z-index:600;display:flex;flex-direction:column;align-items:flex-end;gap:10px">

  <!-- Janela do chat -->
  <div id="chat-ia-window" style="display:none;flex-direction:column;width:360px;height:480px;background:var(--surface);border:.5px solid rgba(167,139,250,.3);box-shadow:0 8px 40px rgba(0,0,0,.6)">
    <!-- Header -->
    <div style="display:flex;align-items:center;gap:8px;padding:12px 16px;border-bottom:.5px solid var(--sep);background:var(--surface2)">
      <span style="width:24px;height:24px;background:rgba(167,139,250,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--purple)">✦</span>
      <span style="font-family:'Syne',sans-serif;font-size:12px;font-weight:700;color:var(--ink)">Chat IA</span>
      <span style="font-size:9px;color:var(--ink3);margin-left:4px">Consultor 1Negócio</span>
      <button onclick="toggleChat()" style="margin-left:auto;background:none;border:none;color:var(--ink3);cursor:pointer;font-size:16px;padding:0">×</button>
    </div>
    <!-- Mensagens -->
    <div id="chat-ia-msgs" style="flex:1;overflow-y:auto;padding:14px"></div>
    <!-- Input -->
    <div style="border-top:.5px solid var(--sep);padding:10px 12px;display:flex;gap:8px;background:var(--surface2)">
      <textarea id="chat-ia-input" placeholder="Pergunte sobre o negócio, M&A, avaliação..." 
        style="flex:1;background:var(--surface);border:.5px solid var(--sep);color:var(--ink);font-family:'DM Mono',monospace;font-size:11px;padding:8px 10px;resize:none;outline:none;height:56px;line-height:1.5"
        onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();chatEnviar();}"></textarea>
      <button onclick="chatEnviar()" style="background:var(--purple);border:none;color:#fff;width:36px;cursor:pointer;font-size:14px;font-family:'Syne',sans-serif;align-self:flex-end;height:36px">↑</button>
    </div>
  </div>

  <!-- Botão flutuante -->
  <button onclick="toggleChat()" style="width:52px;height:52px;border-radius:50%;background:rgba(167,139,250,.15);border:.5px solid rgba(167,139,250,.4);color:var(--purple);font-size:20px;cursor:pointer;position:relative;box-shadow:0 4px 20px rgba(167,139,250,.2);transition:all .15s" title="Chat IA">
    ✦
    <span id="chat-ia-badge" style="display:none;position:absolute;top:2px;right:2px;width:10px;height:10px;border-radius:50%;background:var(--amber)"></span>
  </button>
</div>
</body>
</html>
