    <div class="admin-comment-wrap">
      <div class="admin-comment-lbl">Comentário do admin — Concentração</div>
      <textarea class="admin-comment" id="obs-16" placeholder="Nomes dos principais clientes (interno), % de cada um, contratos vigentes..." oninput="D.obs_p9=this.value"></textarea>
    </div>
  </div>
</div>

<!-- ── BLOCO 17: P10 ESCALABILIDADE ── -->
<div class="bloco" id="bloco-17">
  <div class="bloco-hdr" onclick="toggleBloco(this)">
    <span class="bloco-num">17</span>
    <span class="bloco-title">P10 — Escalabilidade</span>
    <span class="bloco-status" id="bs-17" style="background:rgba(255,255,255,.05);color:var(--ink3)">Vazio</span>
    <span class="bloco-arrow">▼</span>
  </div>
  <div class="bloco-body">
    <div class="guia-consultor"><strong>Guia do consultor:</strong> Se os custos fixos ficassem iguais, quanto o negócio conseguiria crescer? 0% = sem espaço, 100% = dobraria sem aumentar custos. Peso: 10%</div>
    <div id="p10-slider"></div>
    <div class="admin-comment-wrap">
      <div class="admin-comment-lbl">Comentário do admin — Escalabilidade</div>
      <textarea class="admin-comment" id="obs-17" placeholder="Capacidade instalada, gargalos, oportunidades de expansão..." oninput="D.obs_p10=this.value"></textarea>
    </div>
  </div>
</div>

<!-- ── BLOCO 18: INTENÇÃO DE VENDA / APETITE ── -->
<div class="bloco" id="bloco-18">
  <div class="bloco-hdr" onclick="toggleBloco(this)">
    <span class="bloco-num">18</span>
    <span class="bloco-title">Intenção de venda e apetite</span>
    <span class="bloco-status" id="bs-18" style="background:rgba(255,255,255,.05);color:var(--ink3)">Vazio</span>
    <span class="bloco-arrow">▼</span>
  </div>
  <div class="bloco-body">
    <div class="guia-consultor">
      <strong>Guia do consultor:</strong>
      <ul>
        <li>Por que está pensando em vender agora?</li>
        <li>Qual a urgência real? (score apetite)</li>
        <li>Está aberto a negociar o preço? Quanto?</li>
        <li>Qual é a expectativa de preço do vendedor?</li>
      </ul>
    </div>
    <div class="field">
      <label class="lbl">Motivo de venda</label>
      <div class="opts-btn">
        <button class="opt-btn" id="mot-aposentadoria" onclick="setOpt('motivo','aposentadoria','mot-')">Aposentadoria</button>
        <button class="opt-btn" id="mot-societario" onclick="setOpt('motivo','societario','mot-')">Mudança societária</button>
        <button class="opt-btn" id="mot-oportunidade" onclick="setOpt('motivo','oportunidade','mot-')">Nova oportunidade</button>
        <button class="opt-btn" id="mot-financeiro" onclick="setOpt('motivo','financeiro','mot-')">Dificuldade financeira</button>
        <button class="opt-btn" id="mot-explorando" onclick="setOpt('motivo','explorando','mot-')">Explorando</button>
      </div>
    </div>
    <div class="field">
      <label class="lbl">Urgência para vender (1 = sem pressa · 10 = urgente)</label>
      <div class="slider-wrap">
        <input type="range" id="sl-urgencia" min="1" max="10" step="1" value="5" oninput="D.urgencia=parseInt(this.value);document.getElementById('sv-urg').textContent=this.value">
        <div class="slider-labels"><span>1 · Sem pressa</span><span>10 · Urgente</span></div>
        <div class="slider-val-display" id="sv-urg">5</div>
      </div>
    </div>
    <div class="field-row">
      <div class="field">
        <label class="lbl">Abertura para negociar preço</label>
        <div class="opts-btn" style="flex-direction:column;gap:5px">
          <button class="opt-btn" id="ap-0" onclick="setApetite('abertura',0,'ap-')">Preço fixo — não negocia</button>
          <button class="opt-btn" id="ap-1" onclick="setApetite('abertura',1,'ap-')">Pequena flexibilidade (até 5%)</button>
          <button class="opt-btn" id="ap-2" onclick="setApetite('abertura',2,'ap-')">Abertura real (até 15%)</button>
          <button class="opt-btn" id="ap-3" onclick="setApetite('abertura',3,'ap-')">Aberto a negociar</button>
        </div>
      </div>
      <div class="field">
        <label class="lbl">Label de apetite</label>
        <div id="apetite-label" style="padding:12px 16px;background:var(--surface2);border:.5px solid var(--sep);font-family:'Syne',sans-serif;font-size:14px;font-weight:700;color:var(--green);min-height:48px;display:flex;align-items:center">—</div>
        <div style="margin-top:8px;font-size:10px;color:var(--ink3)">Urgência + Abertura = score <span id="apetite-score">—</span></div>
      </div>
    </div>
    <div class="field">
      <label class="lbl">Expectativa de preço do vendedor (porteira fechada)</label>
      <div class="inp-prefix"><span>R$</span><input type="text" id="f-preco-esperado" placeholder="0" oninput="maskMoney(this);D.preco_esperado=parseMoney(this.value)"></div>
    </div>
    <div class="admin-comment-wrap">
      <div class="admin-comment-lbl">Comentário do admin — Intenção</div>
      <textarea class="admin-comment" id="obs-18" placeholder="Contexto da venda, percepção do consultor sobre urgência real..." oninput="D.obs_intencao=this.value"></textarea>
    </div>
  </div>
</div>

<!-- ── BLOCO 19: RESULTADO CALCULADO ── -->
<div class="bloco open" id="bloco-19">
  <div class="bloco-hdr" onclick="toggleBloco(this)">
    <span class="bloco-num">19</span>
    <span class="bloco-title">Resultado e valuation calculado</span>
    <span class="bloco-status" id="bs-19" style="background:rgba(255,255,255,.05);color:var(--ink3)">Aguardando</span>
    <span class="bloco-arrow">▼</span>
  </div>
  <div class="bloco-body">
    <div id="resultado-final"></div>
    <div class="score-display" id="score-pilares-display" style="margin-top:16px"></div>
  </div>
</div>

<!-- AÇÕES FINAIS -->
<div style="padding:24px;border:.5px solid var(--sep);background:var(--surface);margin-top:8px;display:flex;gap:10px;flex-wrap:wrap;align-items:center">
  <button class="btn btn-ghost" onclick="salvar('rascunho')">Salvar rascunho</button>
  <button class="btn btn-amber" onclick="finalizarAvaliacao()" style="font-size:11px;padding:10px 24px">
    Finalizar avaliação e enviar para aprovação do vendedor →
  </button>
  <span style="font-size:10px;color:var(--ink3);margin-left:4px">O sistema vai gerar o laudo e o anúncio automaticamente</span>
</div>

</div><!-- fim form-area -->

<!-- ════════════════════════════════════════════════════
     SIDEBAR ADMIN (encolhível)
════════════════════════════════════════════════════ -->
<div class="admin-sidebar" id="admin-sidebar">
  <div style="display:flex;align-items:center;border-bottom:1px solid var(--sep);height:44px">
    <button onclick="toggleSidebar()" id="sidebar-toggle-btn" style="width:36px;height:44px;background:none;border:none;color:var(--ink3);font-size:14px;cursor:pointer;flex-shrink:0" title="Recolher">⟩</button>
    <div class="sidebar-tab-bar" id="sidebar-tabs" style="flex:1;border-bottom:none">
      <div class="stab on" onclick="switchSTab('repositorio',this)">Repositório</div>
      <div class="stab" onclick="switchSTab('notas',this)">Notas</div>
    </div>
  </div>

  <!-- PAINEL: REPOSITÓRIO -->
  <div class="sidebar-panel on" id="stab-repositorio">
    <div style="padding:12px 16px;border-bottom:1px solid var(--sep);display:flex;align-items:center;justify-content:space-between">
      <span style="font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink3)">Documentos</span>
      <label style="font-size:9px;cursor:pointer;padding:4px 10px;background:rgba(96,165,250,.12);color:var(--blue);border:.5px solid rgba(96,165,250,.2);letter-spacing:.08em;text-transform:uppercase">
        + Upload <input type="file" style="display:none" multiple accept=".pdf,.doc,.docx,.txt,.csv,.md,.mp3,.mp4,.wav" onchange="uploadRepo(this)">
      </label>
    </div>
    <div style="flex:1;overflow-y:auto" id="repo-lista">
      <div style="padding:20px;text-align:center;color:var(--ink3);font-size:11px">Nenhum documento ainda</div>
    </div>

    <!-- ÁREA DE TEXTO: colar transcrição direto -->
    <div style="border-top:1px solid var(--sep)">
      <div style="padding:8px 16px;display:flex;align-items:center;justify-content:space-between">
        <span style="font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink3)">Colar transcrição ou texto</span>
        <button onclick="salvarTextoRepo()" style="font-size:9px;padding:3px 10px;background:rgba(16,185,129,.12);color:var(--green);border:.5px solid rgba(16,185,129,.2);cursor:pointer;letter-spacing:.06em;text-transform:uppercase">Salvar</button>
      </div>
      <textarea id="repo-texto-input"
        placeholder="Cole aqui transcrições de reunião, anotações, textos com informações do negócio..."
        style="width:100%;height:120px;background:rgba(255,255,255,.03);border:none;border-top:.5px solid var(--sep);color:var(--ink);font-family:'DM Mono',monospace;font-size:11px;padding:10px 16px;resize:none;outline:none;line-height:1.6"></textarea>
    </div>

    <div style="padding:10px 16px;border-top:1px solid var(--sep);font-size:9px;color:var(--ink3)">
      Use documentos e textos como base para o Copilot IA preencher os campos.
    </div>
  </div>

  <!-- PAINEL: NOTAS INTERNAS -->
  <div class="sidebar-panel" id="stab-notas">
    <div style="padding:12px 16px;border-bottom:1px solid var(--sep)">
      <div style="font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink3)">Notas internas do admin</div>
    </div>
    <div style="flex:1;padding:12px">
      <textarea id="notas-internas" style="width:100%;height:100%;min-height:300px;background:transparent;border:none;color:var(--ink2);font-family:'DM Mono',monospace;font-size:11px;resize:none;outline:none;line-height:1.7" placeholder="Anotações internas, impressões da reunião, pontos de atenção..." oninput="D.notas_admin=this.value"></textarea>
    </div>
    <div style="padding:8px 12px;border-top:1px solid var(--sep)">
      <button class="btn btn-ghost" style="width:100%;font-size:9px" onclick="salvar('rascunho')">Salvar notas</button>
    </div>
  </div>

</div><!-- fim sidebar -->

</div><!-- fim layout -->

