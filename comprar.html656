<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Comprar um negócio — 1Negócio</title>
<meta name="description" content="Negócios avaliados independentemente. Score de saúde. DRE real. Sem surpresas. Você é o nosso foco.">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=Instrument+Serif:ital@0;1&family=Syne:wght@700;800&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0c0c0a; --bg2:#111110; --bg3:#161614;
  --ink:rgba(255,255,255,.88); --ink2:rgba(255,255,255,.46);
  --ink3:rgba(255,255,255,.22); --ink4:rgba(255,255,255,.08);
  --sep:rgba(255,255,255,.07);
  --green:#10b981; --amber:#f59e0b; --blue:#60a5fa;
}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--ink);font-family:'DM Mono',monospace;overflow-x:hidden;}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:500;
  height:46px;background:rgba(12,12,10,.97);backdrop-filter:blur(12px);
  border-bottom:1px solid var(--sep);
  display:flex;align-items:center;
}
.logo{
  font-family:'Syne',sans-serif;font-weight:800;font-size:13px;
  letter-spacing:.08em;color:#fff;text-decoration:none;
  padding:0 20px;height:46px;display:flex;align-items:center;gap:8px;
  border-right:1px solid var(--sep);flex-shrink:0;
}
.logo em{color:var(--green);font-style:normal;}
.logo .dot{width:5px;height:5px;border-radius:50%;background:var(--green);animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.3;}}
.nav-links{display:flex;align-items:center;flex:1;}
.nav-link{
  font-size:8.5px;font-weight:400;letter-spacing:.12em;text-transform:uppercase;
  color:var(--ink2);background:none;border:none;cursor:pointer;text-decoration:none;
  padding:0 18px;height:46px;border-right:1px solid var(--sep);
  display:flex;align-items:center;transition:color .15s;white-space:nowrap;
}
.nav-link:hover{color:var(--ink);}
.nav-link.on{color:#fff;}
.nav-cta{
  font-family:'Syne',sans-serif;font-weight:800;
  background:var(--green);color:#fff;border:none;
  padding:0 20px;height:46px;cursor:pointer;
  transition:all .2s;flex-shrink:0;white-space:nowrap;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;
  text-decoration:none;margin-left:auto;
}
.nav-cta-main{font-size:10px;letter-spacing:.08em;text-transform:uppercase;line-height:1;font-weight:800;}
.nav-cta-sub{font-size:6.5px;letter-spacing:.18em;text-transform:uppercase;opacity:.7;line-height:1;}
.nav-cta:hover{background:#0ea371;}

/* ── WRAP ── */
.wrap{max-width:900px;margin:0 auto;padding:0 32px;}

/* ── HERO ── */
.hero{padding:110px 0 72px;border-bottom:1px solid var(--sep);}
.hero-eyebrow{
  font-size:7px;letter-spacing:.24em;text-transform:uppercase;
  color:var(--green);margin-bottom:24px;
  display:flex;align-items:center;gap:12px;
}
.hero-eyebrow::after{content:'';flex:1;height:1px;background:rgba(16,185,129,.2);}
.hero-h1{
  font-family:'Syne',sans-serif;font-size:clamp(28px,5vw,64px);
  font-weight:800;line-height:1.0;letter-spacing:-.03em;color:#fff;
  margin-bottom:20px;
}
.hero-h1 em{
  font-family:'Instrument Serif',serif;font-style:italic;
  font-weight:400;color:var(--green);
}
.hero-sub{
  font-size:11px;font-weight:300;line-height:1.9;
  color:var(--ink2);max-width:580px;margin-bottom:36px;
}
.hero-actions{display:flex;gap:12px;flex-wrap:wrap;align-items:center;}
.btn-primary{
  font-family:'Syne',sans-serif;font-weight:800;font-size:10px;
  letter-spacing:.1em;text-transform:uppercase;
  background:var(--green);color:#fff;border:none;
  padding:14px 28px;cursor:pointer;transition:all .2s;
  text-decoration:none;display:inline-flex;align-items:center;gap:8px;
}
.btn-primary:hover{background:#0ea371;}
.btn-ghost{
  font-size:9px;letter-spacing:.14em;text-transform:uppercase;
  color:var(--ink3);text-decoration:none;transition:color .2s;
}
.btn-ghost:hover{color:var(--ink);}

/* ── DIFERENCIAL HERO ── */
.dif-strip{
  padding:32px 0;border-bottom:1px solid var(--sep);
  display:flex;gap:0;
}
.dif-item{
  flex:1;padding:0 28px;border-right:1px solid var(--sep);
  display:flex;flex-direction:column;gap:6px;
}
.dif-item:first-child{padding-left:0;}
.dif-item:last-child{border:none;}
.dif-n{
  font-family:'Syne',sans-serif;font-size:18px;font-weight:800;
  color:var(--green);line-height:1;
}
.dif-label{font-size:8px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink3);}
.dif-desc{font-size:9px;font-weight:300;line-height:1.6;color:var(--ink2);}

/* ── SECTION ── */
.sec{padding:72px 0;border-bottom:1px solid var(--sep);}
.sec-eyebrow{
  font-size:7px;letter-spacing:.22em;text-transform:uppercase;
  color:var(--ink3);margin-bottom:32px;
  display:flex;align-items:center;gap:10px;
}
.sec-eyebrow::after{content:'';flex:1;height:1px;background:var(--sep);}
.sec-h{
  font-family:'Syne',sans-serif;font-size:clamp(20px,3.2vw,38px);
  font-weight:800;line-height:1.05;letter-spacing:-.02em;
  color:#fff;margin-bottom:16px;
}
.sec-h em{font-family:'Instrument Serif',serif;font-style:italic;font-weight:400;color:var(--green);}
.sec-sub{font-size:11px;font-weight:300;line-height:1.9;color:var(--ink2);max-width:560px;margin-bottom:40px;}

/* ── CARD ANÚNCIO EXEMPLO ── */
.card-exemplo{
  border:1px solid var(--sep);padding:28px;
  display:flex;flex-direction:column;gap:16px;
  position:relative;overflow:hidden;
  background:rgba(16,185,129,.02);
}
.card-exemplo::before{
  content:'EXEMPLO DE ANÚNCIO';
  position:absolute;top:16px;right:16px;
  font-size:6.5px;letter-spacing:.2em;color:var(--ink4);
}
.card-tag{
  display:inline-flex;align-items:center;gap:8px;
  font-size:7px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink3);
}
.card-tag span{width:1px;height:10px;background:var(--sep);}
.card-title{
  font-family:'Syne',sans-serif;font-size:clamp(16px,2.5vw,24px);
  font-weight:800;color:#fff;letter-spacing:-.02em;line-height:1.1;
}
.card-analise{
  font-size:10px;font-weight:300;line-height:1.8;color:var(--ink2);
  border-left:2px solid rgba(16,185,129,.3);padding-left:16px;
}
.card-indicators{
  display:flex;gap:24px;padding-top:16px;border-top:1px solid var(--sep);
  flex-wrap:wrap;
}
.card-ind{display:flex;flex-direction:column;gap:4px;}
.card-ind-label{font-size:7px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink4);}
.card-ind-val{font-family:'Syne',sans-serif;font-size:16px;font-weight:800;color:#fff;line-height:1;}
.card-ind-val.green{color:var(--green);}
.card-ind-val.amber{color:var(--amber);}
.score-bar-wrap{display:flex;flex-direction:column;gap:4px;}
.score-bar-bg{width:80px;height:4px;background:var(--sep);border-radius:2px;overflow:hidden;}
.score-bar-fill{height:100%;border-radius:2px;background:var(--green);}

/* ── COMO FUNCIONA COMPRADOR ── */
.steps{display:flex;flex-direction:column;gap:0;}
.step{
  display:grid;grid-template-columns:48px 1fr;gap:0;
  padding:28px 0;border-bottom:1px solid var(--sep);
}
.step:last-child{border-bottom:none;}
.step-n{
  font-family:'Syne',sans-serif;font-size:11px;font-weight:800;
  color:var(--ink4);letter-spacing:.04em;padding-top:2px;
}
.step-body{display:flex;flex-direction:column;gap:6px;}
.step-title{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:#fff;letter-spacing:-.01em;}
.step-desc{font-size:10px;font-weight:300;line-height:1.8;color:var(--ink2);}
.step-tag{
  display:inline-flex;align-items:center;gap:4px;
  font-size:7px;letter-spacing:.16em;text-transform:uppercase;
  color:var(--green);border:1px solid rgba(16,185,129,.2);
  padding:3px 8px;margin-top:4px;width:fit-content;
}

/* ── NIVEIS INFORMAÇÃO ── */
.niveis{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--sep);border:1px solid var(--sep);}
.nivel{background:var(--bg);padding:28px;display:flex;flex-direction:column;gap:10px;}
.nivel-n{
  font-family:'Syne',sans-serif;font-size:28px;font-weight:800;
  color:var(--ink4);line-height:1;
}
.nivel-title{font-family:'Syne',sans-serif;font-size:10px;font-weight:700;color:#fff;letter-spacing:.02em;}
.nivel-desc{font-size:9px;font-weight:300;line-height:1.7;color:var(--ink2);}
.nivel-tag{
  font-size:7px;letter-spacing:.14em;text-transform:uppercase;
  color:var(--green);margin-top:4px;
}

/* ── POSICIONAMENTO ── */
.pos-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--sep);border:1px solid var(--sep);}
.pos-card{background:var(--bg);padding:28px;display:flex;flex-direction:column;gap:8px;}
.pos-ico{font-size:18px;margin-bottom:4px;}
.pos-title{font-family:'Syne',sans-serif;font-size:11px;font-weight:700;color:#fff;letter-spacing:-.01em;}
.pos-desc{font-size:9px;font-weight:300;line-height:1.8;color:var(--ink2);}

/* ── CTA FINAL ── */
.cta-final{padding:80px 0;text-align:center;}
.cta-final-h{
  font-family:'Syne',sans-serif;font-size:clamp(22px,4vw,48px);
  font-weight:800;line-height:1.0;letter-spacing:-.02em;color:#fff;margin-bottom:16px;
}
.cta-final-h em{font-family:'Instrument Serif',serif;font-style:italic;font-weight:400;color:var(--green);}
.cta-final-sub{font-size:10px;font-weight:300;line-height:1.8;color:var(--ink3);margin-bottom:32px;}


/* ── PRÉVIA ── */
.preview-wrap{border:1px solid var(--sep);overflow:hidden;}
.preview-tabs{display:flex;border-bottom:1px solid var(--sep);}
.preview-tab{
  font-size:7.5px;letter-spacing:.16em;text-transform:uppercase;
  padding:10px 20px;cursor:pointer;color:var(--ink3);border:none;background:none;
  border-right:1px solid var(--sep);transition:all .15s;
}
.preview-tab.on{color:var(--green);background:rgba(16,185,129,.04);}
.preview-tab:hover{color:var(--ink2);}
.preview-pane{display:none;padding:28px;}
.preview-pane.on{display:block;}
.preview-label{
  font-size:6.5px;letter-spacing:.22em;text-transform:uppercase;
  color:var(--ink4);margin-bottom:20px;
  display:flex;align-items:center;gap:10px;
}
.preview-label::after{content:'';flex:1;height:1px;background:var(--sep);}
.pcard{border:1px solid var(--sep);padding:20px 24px;display:flex;justify-content:space-between;align-items:center;gap:20px;background:rgba(255,255,255,.018);flex-wrap:wrap;}
.pcard-left{display:flex;flex-direction:column;gap:8px;flex:1;min-width:200px;}
.pcard-tag{font-size:7px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink3);}
.pcard-nome{font-family:'Syne',sans-serif;font-size:15px;font-weight:800;color:#fff;line-height:1.1;}
.pcard-desc{font-size:9.5px;font-weight:300;line-height:1.7;color:var(--ink2);}
.pcard-right{display:flex;flex-direction:column;align-items:flex-end;gap:8px;flex-shrink:0;}
.pcard-preco{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;color:#fff;}
.pcard-preco span{font-family:'DM Mono',monospace;font-size:9px;font-weight:300;color:var(--ink3);vertical-align:.4em;}
.pcard-score{display:flex;align-items:center;gap:8px;}
.pcard-score-bar{width:64px;height:4px;background:var(--sep);border-radius:2px;overflow:hidden;}
.pcard-score-fill{height:100%;border-radius:2px;background:var(--green);}
.pcard-score-n{font-family:'Syne',sans-serif;font-size:11px;font-weight:800;color:var(--green);}
.pcard-badges{display:flex;gap:6px;flex-wrap:wrap;}
.pcard-badge{font-size:6.5px;letter-spacing:.14em;text-transform:uppercase;padding:3px 8px;border:1px solid var(--sep);color:var(--ink3);}
.pexp{border:1px solid var(--sep);background:rgba(255,255,255,.018);}
.pexp-head{padding:16px 24px;border-bottom:1px solid var(--sep);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;}
.pexp-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border-top:1px solid var(--sep);}
.pexp-item{padding:14px 20px;border-right:1px solid var(--sep);display:flex;flex-direction:column;gap:4px;}
.pexp-item:last-child{border:none;}
.pexp-label{font-size:7px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink4);}
.pexp-val{font-family:'Syne',sans-serif;font-size:14px;font-weight:800;color:#fff;}
.pexp-val.g{color:var(--green);}
.pexp-val.a{color:var(--amber);}
.pexp-analise{border-left:2px solid rgba(16,185,129,.3);padding:0 0 0 16px;margin:16px 24px;font-size:10px;font-weight:300;line-height:1.8;color:var(--ink2);}
.pexp-atencao{margin:0 24px 20px;padding:12px 16px;border:1px solid rgba(245,158,11,.15);background:rgba(245,158,11,.04);font-size:9px;font-weight:300;line-height:1.7;color:var(--ink2);}
.pexp-atencao-hd{font-size:7px;letter-spacing:.16em;text-transform:uppercase;color:var(--amber);margin-bottom:6px;}
.pdossie{border:1px solid var(--sep);background:var(--bg);}
.pdossie-head{padding:20px 24px;border-bottom:1px solid var(--sep);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;}
.pdossie-section{padding:20px 24px;border-bottom:1px solid var(--sep);}
.pdossie-section-hd{font-size:7px;letter-spacing:.2em;text-transform:uppercase;color:var(--ink4);margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.pdossie-section-hd::after{content:'';flex:1;height:1px;background:var(--sep);}
.pdossie-dre{display:flex;flex-direction:column;gap:6px;}
.pdossie-dre-row{display:flex;justify-content:space-between;align-items:center;font-size:9.5px;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.03);}
.pdossie-dre-row:last-child{border:none;}
.pdossie-dre-row.total{font-family:'Syne',sans-serif;font-weight:800;font-size:11px;color:#fff;border-top:1px solid var(--sep);padding-top:10px;margin-top:4px;}
.pdr-l{color:var(--ink2);}
.pdr-v{color:var(--ink);}
.pdossie-dims{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.pdossie-dim{display:flex;flex-direction:column;gap:5px;}
.pdossie-dim-hd{display:flex;justify-content:space-between;align-items:center;}
.pdossie-dim-label{font-size:7.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink3);}
.pdossie-dim-n{font-family:'Syne',sans-serif;font-size:12px;font-weight:800;}
.pdossie-dim-bar{height:3px;background:var(--sep);border-radius:2px;overflow:hidden;}
.pdossie-dim-fill{height:100%;border-radius:2px;}
.pdossie-tese{font-size:10px;font-weight:300;line-height:1.8;color:var(--ink2);border-left:2px solid rgba(96,165,250,.3);padding-left:16px;}


/* ── IFRAME HOME ── */
.home-preview-wrap{
  position:relative;border:1px solid var(--sep);overflow:hidden;
  background:var(--bg2);
}
.home-preview-bar{
  display:flex;align-items:center;gap:10px;
  padding:10px 16px;border-bottom:1px solid var(--sep);
  background:#060606;
}
.home-preview-dots{display:flex;gap:5px;}
.home-preview-dot{width:8px;height:8px;border-radius:50%;}
.home-preview-url{
  flex:1;background:rgba(255,255,255,.05);border:1px solid var(--sep);
  border-radius:3px;padding:4px 10px;
  font-size:8.5px;color:var(--ink3);letter-spacing:.04em;
}
.home-preview-frame{
  width:100%;height:600px;border:none;
  display:block;pointer-events:none;
  transform-origin:top left;
}
.home-preview-overlay{
  position:absolute;bottom:0;left:0;right:0;
  height:80px;
  background:linear-gradient(to bottom, transparent, var(--bg));
  pointer-events:none;
}
.home-preview-cta{
  position:absolute;bottom:20px;left:50%;transform:translateX(-50%);
  white-space:nowrap;
}


/* ── PRÉVIA REAL ── */
.rp-wrap{border:1px solid var(--sep);overflow:hidden;margin-top:32px;}
.rp-tabs{display:flex;border-bottom:1px solid var(--sep);}
.rp-tab{
  font-size:7.5px;letter-spacing:.16em;text-transform:uppercase;
  padding:10px 20px;cursor:pointer;color:var(--ink3);border:none;background:none;
  border-right:1px solid var(--sep);transition:all .15s;
}
.rp-tab.on{color:var(--green);background:rgba(16,185,129,.04);}
.rp-tab:hover{color:var(--ink2);}
.rp-pane{display:none;padding:24px;}
.rp-pane.on{display:block;}
.rp-notice{
  font-size:7.5px;letter-spacing:.14em;text-transform:uppercase;
  color:var(--ink4);margin-bottom:20px;
  display:flex;align-items:center;gap:10px;
}
.rp-notice::after{content:'';flex:1;height:1px;background:var(--sep);}

/* ── FICHA (copied from homepage) ── */
.rficha{border-bottom:1px solid var(--sep);position:relative;background:rgba(255,255,255,.018);}
.rf-acc{position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--rfc);}
.rf-row{display:flex;align-items:stretch;min-height:68px;padding-left:3px;}
.rf-id{flex:1;min-width:0;padding:12px 14px 12px 13px;display:flex;flex-direction:column;justify-content:center;gap:4px;}
.rf-cat-row{display:flex;align-items:center;gap:8px;}
.rf-cat{font-size:6.5px;font-weight:500;letter-spacing:.2em;text-transform:uppercase;color:var(--rfc);display:flex;align-items:center;gap:5px;}
.rf-cat::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--rfc);flex-shrink:0;}
.rf-nome{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;line-height:1.1;text-transform:uppercase;letter-spacing:.04em;color:#fff;}
.rf-health{display:flex;align-items:center;gap:6px;margin-top:3px;}
.rfh-num{font-family:'DM Mono',monospace;font-size:10px;font-weight:500;line-height:1;color:var(--rsc);}
.rfh-bar{width:48px;height:2px;background:rgba(255,255,255,.08);border-radius:1px;overflow:hidden;flex-shrink:0;}
.rfh-fill{height:100%;border-radius:1px;background:var(--rsc);}
.rfh-lbl{font-size:6px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--rsc);}
.rf-tags{display:flex;gap:5px;overflow:hidden;margin-top:4px;}
.rf-tag{display:inline-flex;align-items:center;padding:2px 7px;border-radius:2px;font-size:7px;letter-spacing:.07em;white-space:nowrap;flex-shrink:0;}
.rf-prices{flex-shrink:0;display:flex;flex-direction:column;justify-content:center;align-items:flex-start;padding:8px 18px;gap:3px;min-width:190px;}
.rfp-lbl{font-size:5.5px;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.5);white-space:nowrap;width:100%;text-align:center;}
.rfp-row{display:flex;align-items:baseline;gap:6px;width:100%;justify-content:center;}
.rfp-rs{font-family:'DM Mono',monospace;font-size:8px;margin-right:1px;vertical-align:top;line-height:1.9;}
.rfp-ask{font-family:'Syne',sans-serif;font-size:20px;font-weight:700;line-height:1;letter-spacing:-.02em;color:#fff;}
.rfp-ask .rfp-rs{opacity:.45;}
.rfp-sep{font-size:10px;color:rgba(255,255,255,.2);font-weight:300;padding:0 1px;}
.rfp-aval{font-family:'Syne',sans-serif;font-size:20px;font-weight:700;line-height:1;letter-spacing:-.02em;color:rgba(255,255,255,.2);}
.rfp-aval .rfp-rs{opacity:.3;}
.rfp-tag{display:flex;align-items:center;justify-content:center;padding:2px 8px;border-radius:2px;font-size:6.5px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;white-space:nowrap;color:var(--rft-c);background:var(--rft-bg);border:1px solid var(--rft-bd);width:100%;box-sizing:border-box;}

/* ── EXPANDED (dossiê) ── */
.rf-dossier{padding:20px 16px 24px;display:grid;grid-template-columns:1fr 1fr;gap:16px 20px;border-top:1px solid var(--sep);}
.rdos-analise{grid-column:1/-1;display:flex;gap:10px;}
.rdos-a-ico{width:22px;height:22px;border-radius:4px;flex-shrink:0;background:rgba(96,165,250,.08);border:1px solid rgba(96,165,250,.16);display:flex;align-items:center;justify-content:center;color:#60a5fa;font-size:9px;}
.rdos-a-lbl{font-size:6px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--ink3);margin-bottom:3px;}
.rdos-a-txt{font-size:10px;font-weight:300;line-height:1.75;color:var(--ink2);text-transform:none;}
.rdos-title{font-size:6px;letter-spacing:.2em;text-transform:uppercase;color:var(--ink3);margin-bottom:8px;display:flex;align-items:center;gap:7px;}
.rdos-title::after{content:'';flex:1;height:1px;background:var(--sep);}
.rdim-r{display:grid;grid-template-columns:68px 1fr 18px;align-items:center;gap:6px;padding:2.5px 0;}
.rdim-n{font-size:6.5px;font-weight:300;letter-spacing:.06em;color:var(--ink2);text-transform:uppercase;white-space:nowrap;}
.rdim-bg{height:2px;background:var(--ink4);border-radius:1px;overflow:hidden;}
.rdim-fill{height:100%;border-radius:1px;}
.rdim-s{font-size:8px;font-weight:400;text-align:right;}
.rkv-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--sep);border-radius:4px;overflow:hidden;}
.rkv{background:var(--bg3);padding:7px 10px;}
.rkv-k{font-size:6px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink3);margin-bottom:2px;}
.rkv-v{font-size:10px;font-weight:400;color:var(--ink);}
.rdos-atencao{grid-column:1/-1;display:flex;gap:8px;align-items:flex-start;padding:9px 11px;border-radius:4px;background:rgba(245,158,11,.04);border:1px solid rgba(245,158,11,.12);}
.rdos-at-ico{color:var(--amber);font-size:10px;flex-shrink:0;}
.rdos-at-lbl{font-size:6px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:rgba(245,158,11,.6);margin-bottom:2px;}
.rdos-at-txt{font-size:9.5px;font-weight:300;line-height:1.65;color:var(--ink2);text-transform:none;}
.rdos-cta{grid-column:1/-1;display:flex;gap:6px;align-items:center;padding-top:4px;border-top:1px solid var(--sep);}
.rdos-btn{font-family:'Syne',sans-serif;font-size:7.5px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;background:var(--green);color:#fff;border:none;padding:8px 16px;border-radius:3px;cursor:pointer;}
.rdos-btn-sec{font-size:7.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink2);background:none;border:1px solid var(--sep);padding:8px 12px;border-radius:3px;cursor:pointer;}

/* ── FOOTER ── */
footer{
  border-top:1px solid var(--sep);padding:24px 32px;
  display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;
}
.footer-logo{font-family:'Syne',sans-serif;font-size:11px;font-weight:800;letter-spacing:.08em;color:var(--ink3);}
.footer-logo em{color:var(--green);font-style:normal;}
.footer-links{display:flex;gap:20px;}
.footer-links a{font-size:8px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink4);text-decoration:none;transition:color .15s;}
.footer-links a:hover{color:var(--ink2);}

@media(max-width:680px){
  .niveis,.pos-grid{grid-template-columns:1fr;}
  .dif-strip{flex-direction:column;gap:24px;}
  .dif-item{padding:0;border:none;}
  .wrap{padding:0 20px;}
}
</style>
</head>
