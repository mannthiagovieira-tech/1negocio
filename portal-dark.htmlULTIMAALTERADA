/* ticker */
function buildTicker(list){
  const fat=list.reduce((s,x)=>s+n(x.faturamento_anual),0);
  const val=list.reduce((s,x)=>s+n(x.valor_1n),0);
  const res=list.reduce((s,x)=>s+n(x.resultado_liquido_mensal)*12,0);
  const il=list.filter(x=>n(x.score_saude)>0);
  const ise=il.length?Math.round(il.reduce((s,x)=>s+n(x.score_saude),0)/il.length):0;
  const items=[
    {l:'Empresas a venda',v:String(list.length),c:''},
    {l:'Fat. combinado',v:'R$ '+brlS(fat),c:'g'},
    {l:'Valor avaliado',v:'R$ '+brlS(val),c:'g'},
    {l:'Resultado anual',v:'R$ '+brlS(res),c:'g'},
    {l:'ISE medio',v:String(ise)+'/100',c:ise>=70?'g':'a'},
    {l:'Setores',v:String(new Set(list.map(x=>x.categoria).filter(Boolean)).size),c:''},
    {l:'Estados',v:String(new Set(list.map(x=>x.estado).filter(Boolean)).size),c:''},
    {l:'Independente',v:'100%',c:'g'},
  ];
  const a=[...items,...items];
  document.getElementById('tickerT').innerHTML=a.map(i=>`<div class="ti"><span class="ti-l">${i.l}</span><span class="ti-v ${i.c}">${i.v}</span></div>`).join('');
}

