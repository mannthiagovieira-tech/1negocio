/* carrossel */
function goTo(i){
  cur=Math.max(0,Math.min(NS-1,i));
  document.getElementById('carTrack').style.transform=`translateX(-${cur*(100/NS)}%)`;
  document.querySelectorAll('#dots .dot').forEach((d,j)=>d.classList.toggle('on',j===cur));
  document.getElementById('cNum').textContent=`${cur+1} / ${NS}`;
  document.getElementById('cPrev').disabled=cur===0;
  document.getElementById('cNext').disabled=cur===NS-1;
}
const nav=d=>goTo(cur+d);
let sx=0,sy2=0;
document.getElementById('sheet').addEventListener('touchstart',e=>{sx=e.touches[0].clientX;sy2=e.touches[0].clientY;},{passive:true});
