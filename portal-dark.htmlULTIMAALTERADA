const gf=cat=>CMAP[(cat||'').toLowerCase().trim()]||'outros';
const gclass=cat=>'p-'+gf(cat);

/* helpers */
const brl=v=>{if(v==null)return'—';v=parseFloat(v);if(v>=1e9)return'R$\u00a0'+(v/1e9).toFixed(1)+'B';if(v>=1e6)return'R$\u00a0'+(v/1e6).toFixed(1)+'M';if(v>=1e3)return'R$\u00a0'+Math.round(v/1e3)+'k';return'R$\u00a0'+Math.round(v).toLocaleString('pt-BR')};
const brlS=v=>{if(v==null)return'—';v=parseFloat(v);if(v>=1e9)return(v/1e9).toFixed(1)+'B';if(v>=1e6)return(v/1e6).toFixed(1)+'M';if(v>=1e3)return Math.round(v/1e3)+'k';return Math.round(v).toLocaleString('pt-BR')};
const pct=v=>v!=null?parseFloat(v).toFixed(0)+'%':'—';
const n=v=>v?parseFloat(v):0;
const calcIO=nd=>{
  const d=n(nd.valor_1n)&&n(nd.preco_pedido)?Math.max(0,(n(nd.valor_1n)-n(nd.preco_pedido))/n(nd.valor_1n)):0;
  const tags=Array.isArray(nd.tags_calculadas)?nd.tags_calculadas:[];
  return Math.round((d>=.15?35:d>=.05?22:d>0?12:0)+(n(nd.score_saude)||0)/100*25+(tags.length>=3?20:tags.length>=2?14:8)+(nd.abertura_negociacao==='negociavel'?15:8));
};
const iseL=s=>s>=80?{t:'SOLIDO',c:'#3DFF7A'}:s>=65?{t:'ESTAVEL',c:'#3DFF7A'}:s>=50?{t:'OPERACIONAL',c:'#FFB03A'}:s>=30?{t:'EM DESENVOLVIMENTO',c:'#FFB03A'}:{t:'FRAGILIZADO',c:'#FF5C5C'};
const calcPL=nd=>{
  const a=nd.ativos_json&&typeof nd.ativos_json==='object'?Object.values(nd.ativos_json).reduce((s,v)=>s+n(v),0):0;
  const p=nd.passivos_json&&typeof nd.passivos_json==='object'?Object.values(nd.passivos_json).reduce((s,v)=>s+n(v),0):0;
  return a-p;
};
const ader=nd=>{const b={'Saúde & Estética':21,'Tecnologia / SaaS':28,'Alimentação':18,'Educação':22,'Comércio / Distribuição':12};const m=n(nd.margem_ebitda);return m?Math.round(m-(b[nd.categoria]||18)):null};

/* NOVO: Comparativo 1N vs Pedido */
const calc1NvsPedido=nd=>{
  const val1n=n(nd.valor_1n);
  const pedido=n(nd.preco_pedido);
  if(!val1n||!pedido)return{txt:'—',cls:'eq'};
  const diff=val1n-pedido;
  const pctDiff=Math.round((diff/pedido)*100);
  if(diff>0){
    return{txt:`+${brlS(diff)} vs pedido`,cls:'pos'};
  }else if(diff<0){
    return{txt:`${pctDiff}% vs pedido`,cls:'neg'};
  }
  return{txt:'= pedido',cls:'eq'};
};

/* ICD helper */
const icdClass=v=>{
  if(v==null)return{cls:'parcial',lbl:'—',txt:'Sem dados'};
