<title>1Negócio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;500;700;800&family=DM+Mono:wght@400;500&family=Syne:wght@800;900&display=swap" rel="stylesheet">
<style>
/* ─── RESET ─────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{background:#080D0A;-webkit-font-smoothing:antialiased}
body{
  font-family:'Cabinet Grotesk',sans-serif;
  background:#080D0A;color:#F0F5F1;
  max-width:680px;margin:0 auto;min-height:100vh;
}

/* ─── TOKENS ─────────────────────────────── */
:root{
  --green:#3DFF7A;
  --amber:#FFB03A;
  --bg:#080D0A;
  --surface:#0d1109;
  --border:rgba(255,255,255,.07);
  --dim:rgba(240,245,241,.45);
  --faint:rgba(240,245,241,.18);
}

/* ─── CABEÇALHO ──────────────────────────── */
.hdr{
  background:var(--bg);
  border-radius:0 0 20px 20px;
  overflow:hidden;
  position:sticky;top:0;z-index:200;
}

/* linha 1 — logo + botão */
.h1{display:flex;align-items:center;justify-content:space-between;height:40px;padding:0 13px;border-bottom:.5px solid var(--border)}
.logo{font-family:'Syne',sans-serif;font-weight:800;font-size:15px;letter-spacing:-.02em;color:#F0F5F1;text-decoration:none}
.logo em{color:var(--green);font-style:normal}
.btn-av{font-family:'Cabinet Grotesk',sans-serif;font-weight:700;font-size:9px;text-transform:uppercase;letter-spacing:.07em;color:var(--bg);background:var(--green);padding:5px 13px;border:none;border-radius:20px;cursor:pointer;white-space:nowrap;text-decoration:none}

/* linha 2 — ticker */
.ticker{height:24px;overflow:hidden;border-bottom:.5px solid var(--border);position:relative}
.ticker::before,.ticker::after{content:'';position:absolute;top:0;bottom:0;width:24px;z-index:2;pointer-events:none}
.ticker::before{left:0;background:linear-gradient(90deg,var(--bg),transparent)}
.ticker::after{right:0;background:linear-gradient(-90deg,var(--bg),transparent)}
.ticker-t{display:flex;align-items:center;height:100%;white-space:nowrap;animation:tick 32s linear infinite}
.ticker-t:hover{animation-play-state:paused}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.ti{display:inline-flex;align-items:center;gap:5px;padding:0 11px;border-right:.5px solid var(--border);height:100%;flex-shrink:0}
.ti-l{font-family:'DM Mono',monospace;font-size:6.5px;text-transform:uppercase;letter-spacing:.08em;color:var(--faint)}
.ti-v{font-family:'Cabinet Grotesk',sans-serif;font-weight:800;font-size:10px;color:#F0F5F1;letter-spacing:-.02em}
.ti-v.g{color:var(--green)}.ti-v.a{color:var(--amber)}

/* linha 3 — nav */
.nav{display:flex;align-items:stretch;height:26px;border-bottom:.5px solid var(--border);overflow-x:auto}
.nav::-webkit-scrollbar{display:none}
.nl{font-family:'Cabinet Grotesk',sans-serif;font-weight:500;font-size:9px;color:var(--faint);padding:0 11px;display:flex;align-items:center;border-right:.5px solid rgba(255,255,255,.05);white-space:nowrap;flex-shrink:0;text-decoration:none}
.nl.on{color:var(--green);font-weight:700}

/* linha 4 — categorias */
.cats{display:flex;align-items:center;height:34px;padding:0 8px;gap:5px;overflow-x:auto;border-bottom:.5px solid var(--border)}
.cats::-webkit-scrollbar{display:none}
.tag-all{font-family:'Cabinet Grotesk',sans-serif;font-weight:700;font-size:8px;text-transform:uppercase;letter-spacing:.05em;padding:3px 10px;border-radius:20px;border:none;cursor:pointer;white-space:nowrap;flex-shrink:0;background:rgba(240,245,241,.88);color:var(--bg);transition:all .15s}
.tag-all.off{background:rgba(255,255,255,.08);color:var(--faint)}
.cat-tag{font-family:'Cabinet Grotesk',sans-serif;font-weight:700;font-size:8px;text-transform:uppercase;letter-spacing:.04em;padding:3px 10px;border-radius:20px;border:1.5px solid transparent;cursor:pointer;white-space:nowrap;flex-shrink:0;opacity:.42;transition:all .15s}
.cat-tag.on{opacity:1}

/* linha 5 — estados */
.ests{display:flex;align-items:center;height:28px;padding:0 8px;gap:5px;overflow-x:auto}
.ests::-webkit-scrollbar{display:none}
.est-tag{font-family:'Cabinet Grotesk',sans-serif;font-weight:600;font-size:8px;text-transform:uppercase;letter-spacing:.06em;padding:2px 8px;border-radius:20px;border:.5px solid rgba(255,255,255,.15);background:transparent;color:rgba(255,255,255,.38);cursor:pointer;white-space:nowrap;flex-shrink:0;transition:all .15s}
.est-tag.on{border-color:rgba(255,255,255,.45);color:rgba(255,255,255,.85);background:rgba(255,255,255,.06)}
.est-tag.sem{opacity:.18;cursor:default;pointer-events:none}

/* ponte */
.bridge{height:16px;background:var(--bg)}

/* ─── CARDS ──────────────────────────────── */
.main{padding:8px 8px 32px}

.card{
  border-radius:14px;
  overflow:hidden;
  border:1px solid rgba(255,255,255,.1);
  height:168px;
  cursor:pointer;
  display:flex;
  position:relative;
  margin-top:-48px;
  box-shadow:0 -4px 18px rgba(0,0,0,.4);
  animation:rise .38s cubic-bezier(.34,1.4,.64,1) both;
}
.card:first-child{margin-top:0;box-shadow:none}
@keyframes rise{from{transform:translateY(16px);opacity:.4}to{transform:translateY(0);opacity:1}}

/* coluna esquerda */
.cl{flex:1;min-width:0;padding:10px 8px 10px 12px;display:flex;flex-direction:column;gap:4px}
.c-code{font-family:'DM Mono',monospace;font-size:8px;letter-spacing:.1em;text-transform:uppercase;opacity:.7}
.c-title{font-family:'Syne',sans-serif;font-weight:800;font-size:13px;letter-spacing:.02em;text-transform:uppercase;line-height:1.2;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.c-ise{font-family:'Cabinet Grotesk',sans-serif;font-size:7.5px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;padding:2px 8px;border-radius:20px;display:inline-block;white-space:nowrap;align-self:flex-start}

/* linha de KPIs — logo abaixo do ISE */
.c-kpis{display:flex;border-top:.5px solid rgba(0,0,0,.14);padding-top:6px;margin-top:2px}
.kp{display:flex;flex-direction:column;gap:2px;flex:1;min-width:0;padding-right:6px;border-right:.5px solid rgba(0,0,0,.12)}
.kp:last-child{border-right:none;padding-right:0}
.kp+.kp{padding-left:6px}
.kp-l{font-family:'DM Mono',monospace;font-size:7px;font-weight:400;text-transform:uppercase;letter-spacing:.07em;opacity:.5}
.kp-v{font-family:'Cabinet Grotesk',sans-serif;font-size:15px;font-weight:800;letter-spacing:-.02em;white-space:nowrap}

/* divisor vertical */
.cd{width:.5px;background:rgba(0,0,0,.18);flex-shrink:0}

/* coluna direita */
.cr{width:104px;flex-shrink:0;padding:10px;display:flex;flex-direction:column;align-items:center;text-align:center;gap:0;justify-content:center}
.cr-vl{font-family:'DM Mono',monospace;font-size:6px;text-transform:uppercase;letter-spacing:.1em;opacity:.3}
/* pontinho oportunidade ao lado do label */
.cr-vl.op{display:flex;align-items:center;justify-content:center;gap:3px}
.op-dot{width:5px;height:5px;border-radius:50%;background:var(--green);flex-shrink:0}
.cr-vv{font-family:'Cabinet Grotesk',sans-serif;font-weight:800;font-size:24px;letter-spacing:-.025em;line-height:1.1;display:flex;align-items:baseline;gap:1px;margin-top:2px}
.cr-rs{font-size:10px;font-weight:700;opacity:.55}
.cr-sep{width:100%;height:.5px;background:rgba(0,0,0,.14);margin:6px 0}
.cr-obs{display:flex;flex-direction:column;gap:2px;width:100%}
.cr-ol{font-family:'DM Mono',monospace;font-size:5.5px;text-transform:uppercase;letter-spacing:.08em;opacity:.28}
.cr-ov{font-family:'Cabinet Grotesk',sans-serif;font-weight:500;font-size:8.5px;opacity:.4}
/* NOVO: comparativo 1N vs Pedido */
.cr-cmp{font-family:'Cabinet Grotesk',sans-serif;font-weight:700;font-size:9px;margin-top:4px;padding:3px 8px;border-radius:20px}
.cr-cmp.pos{background:rgba(61,255,122,.12);color:#3DFF7A}
.cr-cmp.neg{background:rgba(255,176,58,.12);color:#FFB03A}
.cr-cmp.eq{background:rgba(255,255,255,.08);color:rgba(255,255,255,.5)}

/* ─── PALETA POR CATEGORIA ───────────────── */
.p-alim  {background:#1A2E1E;color:#6EE87A;border-color:rgba(110,232,122,.18)}
.p-tech  {background:#1B2438;color:#7AB0F5;border-color:rgba(122,176,245,.18)}
.p-serv  {background:#251C38;color:#C4A5F7;border-color:rgba(196,165,247,.18)}
.p-varejo{background:#2E2010;color:#F5C26B;border-color:rgba(245,194,107,.18)}
.p-saude {background:#2E1818;color:#F58A8A;border-color:rgba(245,138,138,.18)}
.p-edu   {background:#182828;color:#7DD4C8;border-color:rgba(125,212,200,.18)}
.p-ind   {background:#281E10;color:#E8A96E;border-color:rgba(232,169,110,.18)}
.p-outros{background:#1E1E1E;color:#A0A0A0;border-color:rgba(160,160,160,.18)}

/* ─── OVERLAY — CARD EXPANDIDO ──────────── */
.overlay{display:none;position:fixed;inset:0;z-index:500;background:rgba(0,0,0,.65);align-items:flex-end;justify-content:center}
.overlay.on{display:flex}
.sheet{
  width:100%;max-width:680px;
  height:calc(100dvh - 44px);
  border-radius:20px 20px 0 0;
  overflow:hidden;display:flex;flex-direction:column;
  transform:translateY(100%);
  transition:transform .3s cubic-bezier(.32,0,.15,1);
  background:inherit;
}
.overlay.on .sheet{transform:translateY(0)}

/* topo do sheet — cor do card */
.sh-hdr{flex-shrink:0;padding:12px 14px 14px;position:relative;border-bottom:.5px solid rgba(0,0,0,.1)}
.sh-handle{width:36px;height:4px;border-radius:2px;background:rgba(0,0,0,.12);margin:0 auto 9px}
.sh-close{position:absolute;top:10px;right:12px;width:28px;height:28px;border-radius:50%;background:rgba(0,0,0,.1);border:.5px solid rgba(0,0,0,.1);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:12px;color:inherit;font-family:'Cabinet Grotesk',sans-serif}
.sh-code{font-family:'DM Mono',monospace;font-size:8px;letter-spacing:.12em;text-transform:uppercase;opacity:.4;margin-bottom:2px}
.sh-title{font-family:'Syne',sans-serif;font-weight:800;font-size:14px;letter-spacing:.03em;text-transform:uppercase;line-height:1.2;margin-bottom:10px}
.sh-vals{display:flex;border-top:.5px solid rgba(0,0,0,.1);padding-top:9px}
.sv{display:flex;flex-direction:column;gap:2px;flex:1;padding-right:10px;border-right:.5px solid rgba(0,0,0,.1)}
.sv:last-child{border-right:none;padding-right:0}
.sv+.sv{padding-left:10px}
.sv-l{font-family:'DM Mono',monospace;font-size:7px;text-transform:uppercase;letter-spacing:.1em;color:currentColor;opacity:.42}
.sv-v{font-family:'Cabinet Grotesk',sans-serif;font-weight:800;font-size:14px;letter-spacing:-.02em;line-height:1;color:currentColor}

/* carrossel */
.car{flex:1;overflow:hidden;display:flex;flex-direction:column;background:inherit;min-height:0}
.car-vp{flex:1;overflow:hidden;min-height:0}
.car-track{display:flex;height:100%;transition:transform .3s cubic-bezier(.4,0,.2,1)}
.slide{min-width:100%;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:13px 13px 10px;display:flex;flex-direction:column;gap:8px;background:inherit;font-family:'DM Mono',monospace}

/* dots + nav */
.car-dots{display:flex;align-items:center;justify-content:center;gap:5px;padding:6px 0;background:rgba(0,0,0,.15);border-top:.5px solid rgba(0,0,0,.12);flex-shrink:0}
.dot{width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,.14);cursor:pointer;transition:all .2s}
.dot.on{width:16px;border-radius:3px;background:var(--green)}
.car-hint{font-family:'DM Mono',monospace;font-size:8px;color:var(--faint);margin-left:8px}
.car-nav{display:flex;align-items:center;justify-content:space-between;padding:5px 14px 6px;background:rgba(0,0,0,.15);border-top:.5px solid rgba(0,0,0,.12);flex-shrink:0}
.car-btn{background:rgba(0,0,0,.08);border:.5px solid rgba(0,0,0,.12);font-family:'DM Mono',monospace;font-size:10px;color:currentColor;opacity:.55;padding:4px 12px;cursor:pointer;border-radius:20px}
.car-btn:disabled{opacity:.2;pointer-events:none}
.car-n{font-family:'DM Mono',monospace;font-size:10px;color:currentColor;opacity:.45}

/* rodapé fixo */
.car-foot{display:flex;gap:8px;padding:10px 14px 14px;background:rgba(0,0,0,.1);border-top:.5px solid rgba(0,0,0,.12);flex-shrink:0}
.btn-sol{flex:1;background:#3DFF7A;color:#080D0A;border:2px solid #3DFF7A;font-family:'Cabinet Grotesk',sans-serif;font-weight:800;font-size:12px;padding:12px;cursor:pointer;border-radius:10px;text-transform:uppercase;letter-spacing:.04em;display:flex;align-items:center;justify-content:center;gap:6px}
.btn-shr{background:transparent;border:1.5px solid currentColor;opacity:.45;font-family:'DM Mono',monospace;font-size:10px;color:currentColor;padding:12px 14px;cursor:pointer;border-radius:10px;display:flex;align-items:center;gap:5px}

/* ─── SLIDES ─────────────────────────────── */
.sl{font-family:'DM Mono',monospace;font-size:.55rem;text-transform:uppercase;letter-spacing:.14em;color:var(--faint)}
.blk{background:rgba(0,0,0,.12);border:.5px solid rgba(0,0,0,.1);border-radius:10px;padding:10px 12px;font-family:'DM Mono',monospace}
.blk-h{font-family:'Cabinet Grotesk',sans-serif;font-weight:700;font-size:.78rem;color:var(--green);margin-bottom:4px}
.blk-p{font-size:.67rem;color:var(--dim);line-height:1.65}
.nums{display:grid;grid-template-columns:1fr 1fr;gap:5px}
.nc{background:rgba(0,0,0,.12);border:.5px solid rgba(0,0,0,.1);border-radius:8px;padding:8px 10px}
.nc-l{font-family:'DM Mono',monospace;font-size:.5rem;text-transform:uppercase;letter-spacing:.1em;color:var(--faint);margin-bottom:2px}
.nc-v{font-family:'Cabinet Grotesk',sans-serif;font-weight:800;font-size:.95rem;color:#F0F5F1;letter-spacing:-.02em;line-height:1}
.nc-v.g{color:var(--green)}.nc-v.a{color:var(--amber)}
.nc-s{font-family:'DM Mono',monospace;font-size:.5rem;color:var(--faint);margin-top:2px}
.dre,.vb,.bp{background:rgba(0,0,0,.12);border:.5px solid rgba(0,0,0,.1);border-radius:10px;padding:10px 12px}
.bp{background:rgba(0,0,0,.12);border:.5px solid rgba(0,0,0,.1);border-radius:10px;padding:10px 12px;display:flex;flex-direction:column;gap:8px}
.dr,.vr,.bpr{display:flex;align-items:baseline;justify-content:space-between;padding:4px 0;border-bottom:.5px solid rgba(255,255,255,.04)}
.dr:last-child,.vr:last-child,.bpr:last-child{border-bottom:none}
.dr.tot{border-top:.5px solid rgba(255,255,255,.07);margin-top:2px;padding-top:6px}
.dr-l,.vr-l,.bpr-l{font-family:'DM Mono',monospace;font-size:.63rem;color:currentColor;opacity:.55}
.dr-l.i{padding-left:10px;font-size:.58rem;color:rgba(255,255,255,.22)}
.bps{font-family:'DM Mono',monospace;font-size:.5rem;text-transform:uppercase;letter-spacing:.12em;color:var(--faint);margin-bottom:3px}
.dr-v,.vr-v,.bpr-v{font-family:'Cabinet Grotesk',sans-serif;font-weight:700;font-size:.7rem;color:currentColor;opacity:.85}
.dr-v.g,.vr-v.g{color:var(--green)}.dr-v.r{color:var(--amber)}.dr-v.b{font-size:.82rem;font-weight:800;color:currentColor;opacity:1}
.vr-v.ink{color:#F0F5F1}
.bp-tot{display:flex;justify-content:space-between;padding-top:6px;border-top:.5px solid rgba(255,255,255,.07)}
.bp-tot-l{font-family:'DM Mono',monospace;font-size:.63rem;color:var(--dim)}
.bp-tot-v{font-family:'Cabinet Grotesk',sans-serif;font-weight:800;font-size:.85rem;color:var(--green)}
.ise-h{display:flex;align-items:center;gap:10px;padding:10px 12px;background:rgba(61,255,122,.05);border:.5px solid rgba(61,255,122,.18);border-radius:10px}
.ise-n{font-family:'Cabinet Grotesk',sans-serif;font-weight:800;font-size:2.2rem;color:var(--green);letter-spacing:-.03em;line-height:1}
.ise-t{font-family:'Cabinet Grotesk',sans-serif;font-size:.68rem;color:rgba(61,255,122,.85);font-weight:600}
.ise-s{font-family:'DM Mono',monospace;font-size:.55rem;color:rgba(61,255,122,.42);margin-top:2px}
.pilar{margin-bottom:6px}
.pi-h{display:flex;justify-content:space-between;margin-bottom:2px;font-family:'DM Mono',monospace;font-size:.58rem}
.pi-n{color:var(--faint)}.pi-s{font-weight:500}
.pi-bg{height:2px;background:rgba(255,255,255,.05);border-radius:2px;overflow:hidden}
.pi-f{height:100%;border-radius:2px}
.bench{margin-bottom:8px}
.be-h{display:flex;justify-content:space-between;margin-bottom:3px;font-family:'DM Mono',monospace;font-size:.58rem}
.be-l{color:var(--faint)}.be-v{font-weight:500;color:var(--green)}.be-r{color:rgba(255,255,255,.22)}
.be-bar{height:4px;background:rgba(255,255,255,.05);border-radius:3px;position:relative}
.be-ref{position:absolute;left:0;top:0;height:100%;background:rgba(255,255,255,.1);border-radius:3px}
.be-val{position:absolute;left:0;top:0;height:100%;background:var(--green);border-radius:3px}
.be-val.lo{background:var(--amber)}
.up-c{background:rgba(61,255,122,.04);border:.5px solid rgba(61,255,122,.13);border-radius:10px;overflow:hidden;margin-bottom:5px}
.up-h{padding:8px 12px 6px}
.up-t{font-family:'Cabinet Grotesk',sans-serif;font-weight:800;font-size:.72rem;color:var(--green);margin-bottom:2px}
.up-d{font-family:'DM Mono',monospace;font-size:.58rem;color:var(--faint);line-height:1.5}
.up-ks{display:grid;grid-template-columns:1fr 1fr;border-top:.5px solid rgba(61,255,122,.1)}
.uk{padding:6px 12px;border-right:.5px solid rgba(61,255,122,.1)}
.uk:last-child{border-right:none}
.uk-l{font-family:'DM Mono',monospace;font-size:.5rem;text-transform:uppercase;letter-spacing:.1em;color:rgba(61,255,122,.4);margin-bottom:1px}
.uk-v{font-family:'Cabinet Grotesk',sans-serif;font-weight:800;font-size:.72rem;color:var(--green)}
.mais{background:var(--surface);border:.5px solid var(--border);border-radius:10px;padding:8px 12px;display:flex;align-items:center;gap:8px}
.mais-i{width:26px;height:26px;border-radius:50%;background:rgba(61,255,122,.1);display:flex;align-items:center;justify-content:center;font-family:'Cabinet Grotesk',sans-serif;font-weight:800;font-size:11px;color:var(--green);flex-shrink:0}
.mais-t{font-family:'Cabinet Grotesk',sans-serif;flex:1;font-size:.63rem;color:var(--dim);font-weight:500}
.mais-s{font-family:'DM Mono',monospace;font-size:.56rem;color:var(--faint);margin-top:1px}
.vb-tag{font-family:'Cabinet Grotesk',sans-serif;font-size:.5rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:2px 7px;border-radius:20px}
.desc-b{background:rgba(61,255,122,.06);border:.5px solid rgba(61,255,122,.18);border-radius:8px;padding:8px 12px;display:flex;align-items:center;justify-content:space-between}
.db-l{font-family:'DM Mono',monospace;font-size:.6rem;color:rgba(61,255,122,.65)}
.db-v{font-family:'Cabinet Grotesk',sans-serif;font-weight:800;font-size:.82rem;color:var(--green)}
.nota{font-family:'DM Mono',monospace;font-size:.52rem;color:rgba(255,255,255,.18);line-height:1.7;padding-top:5px}

/* modal estado */
.modal{display:none;position:fixed;inset:0;z-index:600;background:rgba(0,0,0,.72);align-items:flex-end;justify-content:center}
.modal.on{display:flex}
.modal-sh{width:100%;max-width:680px;background:var(--surface);border-radius:22px 22px 0 0;padding:18px 16px 36px;border:.5px solid var(--border)}
.modal-h{width:36px;height:4px;border-radius:2px;background:rgba(255,255,255,.1);margin:0 auto 14px}
.modal-sh h3{font-family:'Cabinet Grotesk',sans-serif;font-weight:800;font-size:14px;color:#F0F5F1;margin-bottom:12px}
.modal-opts{display:flex;flex-wrap:wrap;gap:7px}
.opt{font-family:'Cabinet Grotesk',sans-serif;font-weight:600;font-size:11px;padding:6px 13px;border-radius:20px;border:.5px solid rgba(255,255,255,.1);background:transparent;color:var(--faint);cursor:pointer;transition:all .12s}
