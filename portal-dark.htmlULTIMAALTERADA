  const cnt={};list.forEach(x=>{const f=gf(x.categoria);cnt[f]=(cnt[f]||0)+1;});
  const sc=document.getElementById('cats');
  sc.querySelectorAll('.cat-tag').forEach(t=>t.remove());
  CATS.filter(f=>cnt[f]).sort((a,b)=>cnt[b]-cnt[a]).forEach(f=>{
    const p=PAL[f];
    const b=document.createElement('button');
    b.className='cat-tag';b.dataset.f=f;
    b.style.cssText=`background:${p.fill};color:${p.dot};border-color:${p.dot}40`;
    b.textContent=p.lbl.toUpperCase();
    b.onclick=()=>filtCat(f);
    sc.appendChild(b);
  });
}
function filtCat(f){
  catF=f;
  document.getElementById('tagAll').classList.toggle('off',f!==null);
  document.querySelectorAll('.cat-tag').forEach(t=>t.classList.toggle('on',t.dataset.f===f));
  aplicar();
}

/* estados */
function buildEsts(list){
  const cnt={};list.forEach(x=>{if(x.estado)cnt[x.estado]=(cnt[x.estado]||0)+1;});
  const com=ESTADOS.filter(e=>cnt[e]).sort((a,b)=>cnt[b]-cnt[a]);
  const sem=ESTADOS.filter(e=>!cnt[e]);
  const el=document.getElementById('ests');el.innerHTML='';
  [...com,...sem].forEach(e=>{
    const b=document.createElement('button');
    b.className='est-tag'+(estF===e?' on':'')+(cnt[e]?'':' sem');
    b.textContent=e;
    if(cnt[e])b.onclick=()=>filtEst(estF===e?null:e);
    el.appendChild(b);
  });
}
function filtEst(e){
  estF=e;
  document.querySelectorAll('.est-tag:not(.sem)').forEach(t=>t.classList.toggle('on',t.textContent===e));
  aplicar();
}
function abrirModal(){document.getElementById('modal').classList.add('on');document.body.style.overflow='hidden'}
function fecharModal(){document.getElementById('modal').classList.remove('on');document.body.style.overflow=''}

/* render */
function aplicar(){
  let l=[...all];
  if(catF)l=l.filter(x=>gf(x.categoria)===catF);
  if(estF)l=l.filter(x=>x.estado===estF);
  l.sort((a,b)=>calcIO(b)-calcIO(a));
  fil=l;render();
}
function render(){
  const s=document.getElementById('stack');s.innerHTML='';
  if(!fil.length){s.innerHTML='<p style="text-align:center;padding:3rem 0;font-size:12px;color:#fff3">Nenhum anuncio com estes filtros.</p>';return;}
  fil.forEach((nd,i)=>s.appendChild(mkCard(nd,i,fil.length)));
}

(async()=>{
  try{
    all=await load();
    all.sort((a,b)=>calcIO(b)-calcIO(a));
    fil=[...all];
    buildTicker(all);buildCats(all);buildEsts(all);render();
  }catch(e){
    document.getElementById('stack').innerHTML=`<p style="text-align:center;padding:3rem 0;font-size:12px;color:#f874">Erro: ${e.message}</p>`;
    console.error(e);
  }
})();
</script>
</body>
</html>
