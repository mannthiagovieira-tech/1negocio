{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/entre",       "destination": "/auth.html" },
    { "source": "/auth",        "destination": "/auth.html" },
    { "source": "/diagnostico", "destination": "/diagnostico.html" },
    { "source": "/laudo",       "destination": "/laudo.html" },
    { "source": "/portal",      "destination": "/portal-usuario.html" },
    { "source": "/admin",       "destination": "/painel-admin.html" }
  ],
  "redirects": [
    { "source": "/laudo-v2",      "destination": "/laudo", "permanent": true },
    { "source": "/laudo-v2.html", "destination": "/laudo", "permanent": true },
    { "source": "/entre.html",    "destination": "/auth",  "permanent": true },
    { "source": "/avaliar",       "destination": "/diagnostico", "permanent": true },
    { "source": "/vender",        "destination": "/diagnostico", "permanent": true }
  ]
}
